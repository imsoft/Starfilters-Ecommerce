---
import WebsiteLayout from "@/layouts/websiteLayout.astro";
import SEO from "@/components/shared/SEO.astro";
import CleanroomsContent from "@/components/shared/CleanroomsContent.astro";
import { generateBreadcrumbSchema } from "@/lib/seo-utils";

const siteUrl = Astro.site?.href || Astro.url.origin;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Inicio', url: siteUrl },
  { name: 'Cuartos Limpios', url: `${siteUrl}/cuartos-limpios` }
]);
---

<WebsiteLayout
  title="Cuartos Limpios"
  seoTitle="Cuartos Limpios Industriales - Diseño e Instalación | Star Filters"
  description="Diseño, fabricación e instalación de cuartos limpios industriales. Soluciones profesionales con certificación ISO para industrias farmacéutica, electrónica y alimentaria en México."
  keywords={[
    'cuartos limpios',
    'salas limpias',
    'cuartos limpios industriales',
    'diseño cuartos limpios',
    'instalación salas limpias',
    'cuartos limpios México',
    'certificación ISO cuartos limpios'
  ]}
>
  <SEO
    slot="seo"
    title="Cuartos Limpios Industriales"
    description="Diseño, fabricación e instalación de cuartos limpios industriales. Soluciones profesionales con certificación ISO para industrias farmacéutica, electrónica y alimentaria en México."
    ogType="website"
    keywords={['cuartos limpios', 'salas limpias', 'cuartos limpios industriales']}
  />
  <script slot="seo" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- ── Hero ── -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-primary/80 py-28 sm:py-36">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid-cl" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid-cl)" />
      </svg>
    </div>
    <!-- imagen de fondo con overlay -->
    <div class="absolute inset-0 z-0">
      <img
        src="/images/cleanrooms-page/Construccion%20Cuartos%20Limpios%20Star%20Filters.JPG"
        alt=""
        class="h-full w-full object-cover opacity-20"
      />
    </div>
    <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 text-center">
      <p class="reveal text-sm font-semibold uppercase tracking-widest text-primary-foreground/70 mb-4">
        Star Filters
      </p>
      <h1 class="reveal text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight">
        Cuartos Limpios
        <span class="block text-primary mt-1">Industriales</span>
      </h1>
      <p class="reveal mt-6 text-lg text-slate-300 max-w-3xl mx-auto">
        Diseño, fabricación e instalación de salas limpias con certificación ISO 14644. Soluciones a medida para industrias farmacéutica, electrónica y alimentaria en México.
      </p>
      <div class="reveal mt-8 flex flex-wrap justify-center gap-3">
        {['ISO 14644', 'GMP', 'NEBB', 'FDA'].map((norm) => (
          <span class="inline-flex items-center rounded-full border border-white/20 bg-white/10 px-4 py-1.5 text-xs font-semibold text-white/90 backdrop-blur-sm">
            {norm}
          </span>
        ))}
      </div>
      <div class="reveal mt-10 flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contenido" class="inline-flex items-center justify-center rounded-md bg-primary px-8 py-3.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors">
          Conocer más
        </a>
        <a href="https://wa.me/523322569541?text=Hola%2C%20me%20gustar%C3%ADa%20informaci%C3%B3n%20sobre%20cuartos%20limpios."
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 justify-center rounded-md border border-white/30 px-8 py-3.5 text-sm font-semibold text-white hover:bg-white/10 transition-colors">
          Solicitar cotización
        </a>
      </div>
    </div>
  </section>

  <div id="contenido">
    <CleanroomsContent />
  </div>
</WebsiteLayout>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('visible'), i * 80);
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });
  reveals.forEach(el => observer.observe(el));
</script>
