---
import AuthLayout from "@/layouts/authLayout.astro";
import { verifyUserEmail } from "@/lib/database";

// Activa la cuenta a partir del token enviado por correo en el registro.
const token = Astro.url.searchParams.get('token');

let verified = false;
if (token && token.trim()) {
  try {
    verified = await verifyUserEmail(token.trim());
  } catch (error) {
    console.error('Error verificando email:', error);
  }
}
---

<AuthLayout title={verified ? 'Cuenta verificada' : 'Enlace no válido'}>
  <div class="flex min-h-screen flex-col justify-center px-6 py-12 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-sm text-center">
      {verified ? (
        <>
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
            <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
            </svg>
          </div>
          <h2 class="mt-6 text-2xl/9 font-bold tracking-tight text-foreground">¡Cuenta verificada!</h2>
          <p class="mt-4 text-sm text-muted-foreground">
            Tu correo fue confirmado y tu cuenta ya está activa. Ya puedes iniciar sesión.
          </p>
          <a
            href="/login"
            class="mt-8 flex w-full justify-center rounded-md bg-primary px-3 py-2 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary/90"
          >
            Iniciar sesión
          </a>
        </>
      ) : (
        <>
          <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-red-100">
            <svg class="h-8 w-8 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </div>
          <h2 class="mt-6 text-2xl/9 font-bold tracking-tight text-foreground">Enlace no válido</h2>
          <p class="mt-4 text-sm text-muted-foreground">
            El enlace de verificación no es válido o ya fue utilizado. Si tu cuenta ya está
            verificada, simplemente inicia sesión.
          </p>
          <a
            href="/login"
            class="mt-8 flex w-full justify-center rounded-md bg-primary px-3 py-2 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary/90"
          >
            Ir a iniciar sesión
          </a>
          <a
            href="/"
            class="mt-3 flex w-full justify-center rounded-md bg-background border border-border px-3 py-2 text-sm font-semibold text-foreground shadow-sm hover:bg-muted"
          >
            Volver al inicio
          </a>
        </>
      )}
    </div>
  </div>
</AuthLayout>
