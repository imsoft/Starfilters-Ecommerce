---
import WebsiteLayout from "@/layouts/websiteLayout.astro";
import SEO from "@/components/shared/SEO.astro";
import SplitCTA from "@/components/shared/SplitCTA.astro";
import { getActiveCategories } from "@/lib/filter-category-service";
import { generateBreadcrumbSchema } from "@/lib/seo-utils";

export const prerender = false;

const categories = await getActiveCategories();

const siteUrl = Astro.site?.href || Astro.url.origin;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Inicio', url: siteUrl },
  { name: 'Soluciones de Filtración', url: `${siteUrl}/soluciones` },
]);

const whatsappNumber = '523322569541';
const whatsappCotizacion = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola, me gustaría solicitar una cotización de filtros industriales.')}`;
const whatsappAsesoria = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent('Hola, me gustaría recibir asesoramiento técnico sobre filtración industrial.')}`;
---

<WebsiteLayout
  title="Filtros de Aire"
  seoTitle="Filtros de Aire: Baja, Media y HEPA | Star Filters"
  description="Fabricamos filtros de aire industriales de alto rendimiento: baja, media y alta eficiencia HEPA. Normativas EN779, ISO 16890, ASHRAE 52.2 y EN 1822. Stock permanente en Guadalajara y CDMX."
  keywords={[
    'filtros industriales México',
    'filtros HEPA',
    'filtros baja eficiencia',
    'filtros media eficiencia',
    'póliza mantenimiento filtros',
    'Star Filters Guadalajara',
  ]}
>
  <SEO
    slot="seo"
    title="Filtros de Aire"
    description="Filtros de aire industriales: baja, media y alta eficiencia HEPA. Stock permanente en Guadalajara y CDMX."
    ogType="website"
    keywords={['filtros HEPA', 'filtración industrial', 'Star Filters']}
  />
  <script slot="seo" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <!-- ── Intro + Foto de portafolio ─────────────────────────────────────────────── -->
  <section class="bg-white py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-4">Nuestra Fabricación</p>
          <h2 class="text-3xl font-bold text-gray-900 sm:text-4xl leading-tight">
            Filtros industriales fabricados con control total de calidad
          </h2>
          <p class="mt-5 text-base/7 text-gray-600">
            Fabricamos filtros de aire industriales de alto rendimiento para entornos exigentes. Nuestras soluciones garantizan una filtración eficiente, larga vida útil y adaptación a cada proceso industrial.
          </p>
          <p class="mt-4 text-base/7 text-gray-600">
            Nuestros filtros de aire cumplen con las normativas <strong class="text-gray-900">EN 779</strong>, <strong class="text-gray-900">ISO 16890</strong>, <strong class="text-gray-900">ASHRAE 52.2</strong> (filtros de baja y mediana eficiencia) y <strong class="text-gray-900">EN 1822</strong> (filtros HEPA y ULPA).
          </p>
          <!-- Video placeholder -->
          <div class="mt-8 rounded-xl border-2 border-dashed border-gray-200 bg-gray-50 p-6 text-center">
            <svg class="mx-auto h-10 w-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
            </svg>
            <p class="mt-2 text-sm font-medium text-gray-400">Video de filtros de aire — próximamente</p>
          </div>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-lg">
          <img
            src="/images/home-page/Filtros%20de%20estrella%20productos.png"
            alt="Portafolio completo de filtros industriales Star Filters"
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ── Fabricación propia + Disponibilidad ────────────────────────────────────── -->
  <section class="bg-muted/30 py-20 border-t border-border">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">

        <!-- Fabricación propia -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10">
              <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Fabricación propia de filtros industriales</h2>
          </div>
          <ul class="space-y-4">
            {[
              { icon: '🏭', text: 'Producción propia con control total de calidad' },
              { icon: '📐', text: 'Filtros a medida según instalación' },
              { icon: '🚚', text: 'Entregas rápidas y flexibles' },
              { icon: '🔬', text: 'Asesoramiento técnico especializado' },
            ].map(({ icon, text }) => (
              <li class="flex items-start gap-4 rounded-xl bg-white p-4 shadow-sm border border-border">
                <span class="text-2xl flex-shrink-0">{icon}</span>
                <span class="text-sm/6 font-medium text-gray-700">{text}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Disponibilidad y logística -->
        <div>
          <div class="flex items-center gap-3 mb-6">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-primary/10">
              <svg class="h-5 w-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h2 class="text-2xl font-bold text-gray-900">Disponibilidad y logística</h2>
          </div>
          <!-- Almacenes -->
          <div class="grid grid-cols-2 gap-4 mb-6">
            <div class="rounded-xl bg-primary p-5 text-center text-white shadow-md">
              <p class="text-3xl font-bold">GDL</p>
              <p class="mt-1 text-sm font-medium text-primary-foreground/80">Almacén principal</p>
              <p class="mt-1 text-xs text-primary-foreground/70">Guadalajara, Jalisco</p>
            </div>
            <div class="rounded-xl bg-slate-800 p-5 text-center text-white shadow-md">
              <p class="text-3xl font-bold">CDMX</p>
              <p class="mt-1 text-sm font-medium text-slate-300">Almacén estratégico</p>
              <p class="mt-1 text-xs text-slate-400">Ciudad de México</p>
            </div>
          </div>
          <ul class="space-y-3">
            {[
              'Stock permanente de filtros industriales',
              'Entregas rápidas a nivel nacional',
              'Tiempos de respuesta competitivos',
              'Alta disponibilidad para clientes industriales',
            ].map((item) => (
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <svg class="h-4 w-4 text-primary flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Tipos de filtros ───────────────────────────────────────────────────────── -->
  <section id="tipos-filtros" class="bg-white py-20 border-t border-border">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">Catálogo Técnico</p>
        <h2 class="mt-2 text-3xl font-bold text-gray-900 sm:text-4xl">Tipos de filtros industriales</h2>
        <p class="mt-4 text-gray-500 max-w-xl mx-auto">
          Selecciona el nivel de eficiencia que requiere tu proceso productivo.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Baja Eficiencia -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl border border-border shadow-sm hover:shadow-md transition-shadow">
          <div class="relative h-56 overflow-hidden bg-blue-50">
            <img
              src="/images/home-page/Filtros%20de%20aire.png"
              alt="Filtros de baja eficiencia"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-blue-900/60 to-transparent"></div>
            <span class="absolute top-4 left-4 rounded-full bg-blue-100 px-3 py-1 text-xs font-bold text-blue-700">G1 – G4</span>
            <span class="absolute bottom-4 left-4 text-lg font-bold text-white">Baja Eficiencia</span>
          </div>
          <div class="flex flex-1 flex-col bg-white p-6">
            <ul class="space-y-2 flex-1">
              {[
                'Filtros pleat (prefiltración de partículas gruesas)',
                'Filtros metálicos',
                'Filtros de carbón activado (control de olores y gases)',
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <span class="mt-1 h-2 w-2 rounded-full bg-blue-400 flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
            <a
              href="/filtros"
              class="mt-6 inline-flex items-center justify-center rounded-md bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors"
            >
              Ver en catálogo
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Media Eficiencia -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl border-2 border-primary shadow-md hover:shadow-lg transition-shadow">
          <div class="absolute -top-px left-1/2 -translate-x-1/2 rounded-b-full bg-primary px-6 py-1 text-xs font-bold text-white z-10">
            Más solicitado
          </div>
          <div class="relative h-56 overflow-hidden bg-yellow-50">
            <img
              src="/images/home-page/Filtros%20de%20Aire%20Star.png"
              alt="Filtros de media eficiencia"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-yellow-900/60 to-transparent"></div>
            <span class="absolute top-4 left-4 rounded-full bg-yellow-100 px-3 py-1 text-xs font-bold text-yellow-700">M5 – M9</span>
            <span class="absolute bottom-4 left-4 text-lg font-bold text-white">Media Eficiencia</span>
          </div>
          <div class="flex flex-1 flex-col bg-white p-6">
            <ul class="space-y-2 flex-1">
              {[
                'Filtros de bolsa (para altos volúmenes de aire)',
                'Filtros W (V-bank)',
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <span class="mt-1 h-2 w-2 rounded-full bg-yellow-400 flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
            <a
              href="/filtros"
              class="mt-6 inline-flex items-center justify-center rounded-md bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors"
            >
              Ver en catálogo
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- HEPA / Alta Eficiencia -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl border border-border shadow-sm hover:shadow-md transition-shadow">
          <div class="relative h-56 overflow-hidden bg-red-50">
            <img
              src="/images/services/Prueba%20de%20Integridad%20Filtros%20HEPA.png"
              alt="Filtros HEPA alta eficiencia"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-red-900/60 to-transparent"></div>
            <span class="absolute top-4 left-4 rounded-full bg-red-100 px-3 py-1 text-xs font-bold text-red-700">H10 – U17</span>
            <span class="absolute bottom-4 left-4 text-lg font-bold text-white">HEPA / Alta Eficiencia</span>
          </div>
          <div class="flex flex-1 flex-col bg-white p-6">
            <ul class="space-y-2 flex-1">
              {[
                'Sello gel',
                'Neopreno',
                'Alta capacidad',
                'Alta temperatura',
                'Colector de polvo',
              ].map((item) => (
                <li class="flex items-start gap-2 text-sm text-gray-600">
                  <span class="mt-1 h-2 w-2 rounded-full bg-red-400 flex-shrink-0"></span>
                  {item}
                </li>
              ))}
            </ul>
            <a
              href="/filtros"
              class="mt-6 inline-flex items-center justify-center rounded-md bg-red-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-red-700 transition-colors"
            >
              Ver en catálogo
              <svg class="ml-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Catálogo por categorías (si hay) ──────────────────────────────────────── -->
  {categories.length > 0 && (
    <section class="bg-muted/20 py-16 border-t border-border">
      <div class="mx-auto max-w-7xl px-6 lg:px-8">
        <div class="text-center mb-10">
          <h2 class="text-2xl font-bold text-gray-900">Categorías de filtros disponibles</h2>
          <p class="mt-2 text-gray-500 text-sm">Haz clic en cualquier categoría para ver tamaños y precios.</p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
          {categories.map((cat) => (
            <a
              href={`/filtros/${cat.slug}`}
              class="group flex flex-col overflow-hidden rounded-xl border border-border bg-white shadow-sm hover:shadow-md hover:border-primary/40 transition-all"
            >
              {cat.main_image ? (
                <div class="h-32 overflow-hidden">
                  <img src={cat.main_image} alt={cat.name} class="h-full w-full object-contain transition-transform duration-300 group-hover:scale-105" loading="lazy" />
                </div>
              ) : (
                <div class="h-32 bg-muted/40 flex items-center justify-center">
                  <svg class="h-10 w-10 text-muted-foreground/30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                  </svg>
                </div>
              )}
              <div class="p-3">
                <p class="text-xs font-semibold text-gray-700 leading-snug group-hover:text-primary transition-colors line-clamp-2">{cat.name}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-8 text-center">
          <a href="/filtros" class="inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary/80 transition-colors">
            Ver catálogo completo
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- ── Paquetes de servicios ──────────────────────────────────────────────────── -->
  <section class="bg-white py-20 border-t border-border" id="paquetes">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">Servicios</p>
        <h2 class="mt-2 text-3xl font-bold text-gray-900 sm:text-4xl">Paquetes de servicios de filtros</h2>
        <p class="mt-4 text-gray-500 max-w-xl mx-auto">
          Mantén tu sistema de filtración en óptimas condiciones con nuestros paquetes especializados.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Cambio de filtros -->
        <div class="group flex flex-col overflow-hidden rounded-2xl border border-border shadow-sm hover:shadow-md transition-shadow">
          <div class="relative h-48 overflow-hidden">
            <img
              src="/images/home-page/Filtros%20Star%20Cuarto%20Limpio.png"
              alt="Cambio de filtros industriales"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            <span class="absolute bottom-4 left-4 text-base font-bold text-white">Cambio de Filtros</span>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <p class="text-sm text-gray-600 flex-1">
              Servicio de sustitución de filtros industriales en tus instalaciones. Incluye inspección del sistema, retiro de filtros usados e instalación de nuevos con reporte técnico.
            </p>
            <a href={whatsappCotizacion} target="_blank" rel="noopener noreferrer"
              class="mt-5 inline-flex items-center justify-center rounded-md border border-border px-5 py-2.5 text-sm font-semibold text-gray-900 hover:bg-muted transition-colors">
              Solicitar servicio
            </a>
          </div>
        </div>

        <!-- Paquete Filtro HEPA -->
        <div class="group relative flex flex-col overflow-hidden rounded-2xl border-2 border-primary shadow-md hover:shadow-lg transition-shadow">
          <div class="absolute -top-px left-1/2 -translate-x-1/2 rounded-b-full bg-primary px-6 py-1 text-xs font-bold text-white z-10">
            Más completo
          </div>
          <div class="relative h-48 overflow-hidden">
            <img
              src="/images/services/Prueba%20de%20Integridad%20Filtros%20HEPA.png"
              alt="Paquete filtro HEPA"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            <span class="absolute bottom-4 left-4 text-base font-bold text-white">Paquete Filtro HEPA</span>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <p class="text-sm text-gray-600 flex-1">
              Sustitución de filtros HEPA con prueba de integridad DOP/PAO incluida. Garantizamos el cumplimiento de normativas ISO 14644 y GMP para cuartos limpios críticos.
            </p>
            <a href={whatsappCotizacion} target="_blank" rel="noopener noreferrer"
              class="mt-5 inline-flex items-center justify-center rounded-md bg-primary px-5 py-2.5 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors">
              Solicitar paquete
            </a>
          </div>
        </div>

        <!-- Póliza anual UMA -->
        <div class="group flex flex-col overflow-hidden rounded-2xl border border-border shadow-sm hover:shadow-md transition-shadow">
          <div class="relative h-48 overflow-hidden">
            <img
              src="/images/services/Validacion%20Cuartos%20Limpios.jpeg"
              alt="Póliza anual de mantenimiento UMA"
              class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent"></div>
            <span class="absolute bottom-4 left-4 text-base font-bold text-white">Póliza Anual UMA</span>
          </div>
          <div class="flex flex-1 flex-col p-6">
            <p class="text-sm text-gray-600 flex-1">
              Póliza anual de mantenimiento integral: visitas programadas, reemplazo de filtros, reporte técnico, soporte prioritario y certificación de cumplimiento normativo.
            </p>
            <a href={whatsappCotizacion} target="_blank" rel="noopener noreferrer"
              class="mt-5 inline-flex items-center justify-center rounded-md border border-border px-5 py-2.5 text-sm font-semibold text-gray-900 hover:bg-muted transition-colors">
              Solicitar póliza
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Aplicaciones industriales ─────────────────────────────────────────────── -->
  <section class="bg-muted/30 py-20 border-t border-border">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">Sectores</p>
        <h2 class="mt-2 text-3xl font-bold text-gray-900 sm:text-4xl">Aplicaciones industriales</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-6">
        {[
          { icon: '⚙️', label: 'Industria manufacturera' },
          { icon: '🌬️', label: 'Sistemas HVAC industriales' },
          { icon: '🍎', label: 'Industria alimentaria' },
          { icon: '💊', label: 'Farmacéutica y laboratorios' },
          { icon: '💾', label: 'Microelectrónica' },
          { icon: '🚗', label: 'Industria automotriz' },
        ].map(({ icon, label }) => (
          <div class="flex flex-col items-center text-center rounded-2xl bg-white border border-border p-6 shadow-sm hover:shadow-md hover:border-primary/30 transition-all">
            <span class="text-4xl">{icon}</span>
            <p class="mt-3 text-sm font-medium text-gray-700">{label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Ventajas clave ─────────────────────────────────────────────────────────── -->
  <section class="bg-white py-20 border-t border-border">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="text-center mb-14">
