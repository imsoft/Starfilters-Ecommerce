---
import WebsiteLayout from "@/layouts/websiteLayout.astro";
import SEO from "@/components/shared/SEO.astro";
import LazyImage from "@/components/shared/LazyImage.astro";
import { getActiveProducts, getProductsByFilterCategory, getProductsByFilterCategory as getVariantsByCategory } from "@/lib/product-service";
import { getCategoryById, getCategoryBySlug, getActiveCategories } from "@/lib/filter-category-service";
import { getProductPlaceholderImage } from "@/lib/image-utils";
import { getProductImages } from "@/lib/database";
import { generateBreadcrumbSchema } from "@/lib/seo-utils";
import { getExchangeRate } from "@/lib/currency-service";
import { getProductPriceAndCurrency, formatPriceByCurrency } from "@/lib/i18n-helpers";
import { getLangFromUrl } from "@/i18n/utils";
import { getProductName, getProductDescription, getProductCategory, getCategoryName, getCategoryDescription } from "@/lib/i18n-helpers";

export const prerender = false;

// Detectar idioma actual
const lang = getLangFromUrl(Astro.url);

// Obtener parámetros de la URL (soporta filter_category_id o category slug)
const filterCategoryIdParam = Astro.url.searchParams.get('filter_category_id');
const categorySlugParam = Astro.url.searchParams.get('category');

// Determinar el ID de categoría (por ID directo o buscando por slug)
let filterCategoryId: number | null = null;

// Obtener información de la categoría si existe
let categoryInfo: { id: number; name: string; description?: string } | null = null;

if (filterCategoryIdParam) {
  filterCategoryId = parseInt(filterCategoryIdParam);
  try {
    const category = await getCategoryById(filterCategoryId);
    if (category) {
      categoryInfo = {
        id: category.id,
        name: getCategoryName(category, lang),
        description: getCategoryDescription(category, lang)
      };
    }
  } catch (error) {
    console.error('❌ Error obteniendo información de categoría por ID:', error);
  }
} else if (categorySlugParam) {
  try {
    const category = await getCategoryBySlug(categorySlugParam);
    if (category) {
      filterCategoryId = category.id;
      categoryInfo = {
        id: category.id,
        name: getCategoryName(category, lang),
        description: getCategoryDescription(category, lang)
      };
    }
  } catch (error) {
    console.error('❌ Error obteniendo información de categoría por slug:', error);
  }
}

// Obtener tasa de cambio actual
const exchangeRate = await getExchangeRate();

const convertPriceToMXN = (price: number, currency: string): number => {
  if (currency === 'USD') return price * exchangeRate;
  return price;
};

let products: Array<{
  id: number;
  uuid: string;
  name: string;
  description: string;
  category: string;
  price: number;
  stock: number;
  imageUrl: string;
  nominal_size?: string;
  real_size?: string;
  bind_code?: string;
  filter_category_id?: number | null;
  variantCount?: number;
  minPrice?: number;
  maxPrice?: number;
}> = [];

try {
  let allProducts;
  if (filterCategoryId) {
    allProducts = await getProductsByFilterCategory(filterCategoryId);
  } else {
    allProducts = await getActiveProducts();
  }

  products = await Promise.all(allProducts.map(async (product) => {
    const imgs = await getProductImages(product.id);
    const primary = imgs.find((i) => i.is_primary) ?? imgs[0];
    const imageUrl = primary?.image_url ?? product.image_url ?? getProductPlaceholderImage(product.category || 'productos');

    let variantCount = 0;
    let minPrice = product.price || 0;
    let maxPrice = product.price || 0;

    if (product.filter_category_id) {
      try {
        const variants = await getVariantsByCategory(product.filter_category_id);
        variantCount = variants.length;
        if (variants.length > 0) {
          const prices = variants.map(v => v.price || 0).filter(p => p > 0);
          if (prices.length > 0) {
            minPrice = Math.min(...prices);
            maxPrice = Math.max(...prices);
          }
        }
      } catch (error) {
        console.error('Error obteniendo variantes para producto', product.id, error);
      }
    }

    const { price: displayPrice, currency: displayCurrency } = getProductPriceAndCurrency(product, lang);
    let finalPrice = displayPrice;
    let finalCurrency = displayCurrency;
    if (lang === 'es' && displayCurrency === 'USD') {
      finalPrice = convertPriceToMXN(displayPrice, 'USD');
      finalCurrency = 'MXN';
    }

    return {
      id: product.id,
      uuid: product.uuid,
      name: getProductName(product, lang),
      description: getProductDescription(product, lang),
      category: getProductCategory(product, lang),
      price: finalPrice,
      currency: finalCurrency,
      originalPrice: product.price || 0,
      originalCurrency: product.currency || 'MXN',
      priceUSD: product.price_usd || null,
      stock: product.stock || 0,
      imageUrl: imageUrl,
      nominal_size: product.nominal_size || undefined,
      real_size: product.real_size || undefined,
      bind_code: product.bind_code || undefined,
      filter_category_id: product.filter_category_id || undefined,
      variantCount: variantCount,
      minPrice: minPrice,
      maxPrice: maxPrice
    };
  }));
} catch (error) {
  console.error('❌ Error en página /productos:', error);
}

const formatPrice = (price: number, currency: 'MXN' | 'USD' = 'MXN'): string => {
  return formatPriceByCurrency(price, currency);
};

// Categorías de tipo de filtro (client-side, categoría 2 de BIND)
const categories = [...new Set(products.map(p => p.category).filter(Boolean))];

// Categorías de BIND (tipo de producto — categoría 1)
let bindCategories: any[] = [];
try {
  bindCategories = await getActiveCategories();
} catch (e) {
  bindCategories = [];
}

// SEO
const siteUrl = Astro.site?.href || Astro.url.origin;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: lang === 'en' ? 'Home' : 'Inicio', url: siteUrl },
  { name: lang === 'en' ? 'Products' : 'Productos', url: `${siteUrl}/productos` }
]);
---

<WebsiteLayout
  title={lang === 'en' ? 'Products' : 'Productos'}
  seoTitle={lang === 'en' ? 'Products - Star Filters Catalog' : 'Productos - Catálogo Star Filters'}
  description={lang === 'en' ? 'Explore our full catalog of industrial air filters, cleanroom accessories, UMA units, air showers and laminar flow cabinets.' : 'Explora nuestro catálogo completo de filtros de aire industriales, accesorios para cuarto limpio, unidades UMA, air showers y cabinas de flujo laminar.'}
  keywords={lang === 'en' ? ['air filters', 'HEPA filters', 'cleanroom', 'UMA', 'air shower'] : ['filtros de aire', 'filtros HEPA', 'cuarto limpio', 'UMA', 'air shower']}
>
  <SEO
    slot="seo"
    title={lang === 'en' ? 'Products - Star Filters' : 'Productos - Star Filters'}
    description={lang === 'en' ? 'Industrial air filter catalog.' : 'Catálogo de filtros de aire industriales.'}
    ogType="website"
    keywords={lang === 'en' ? ['air filters', 'HEPA filters'] : ['filtros de aire', 'filtros HEPA']}
  />
  <script slot="seo" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="bg-background min-h-screen pt-24 pb-16">
    <div class="reveal mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

      <!-- ── Barra superior: búsqueda + contador ──────────────────────── -->
      <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <h1 class="text-2xl font-bold text-foreground">
          {categoryInfo ? categoryInfo.name : (lang === 'en' ? 'Products' : 'Productos')}
        </h1>
        <div class="relative w-full sm:w-72">
          <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            <svg class="h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
          </div>
          <input
            type="text"
            id="search-products"
            placeholder={lang === 'en' ? 'Search products...' : 'Buscar producto...'}
            class="w-full rounded-full border border-border bg-background pl-9 pr-4 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
          />
        </div>
      </div>

      <!-- ── Chips de categoría (tipo de producto) ────────────────────── -->
      {bindCategories.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          <a
            href={lang === 'en' ? '/en/products' : '/productos'}
            class={`rounded-full px-4 py-1.5 text-sm font-medium border transition-colors ${!categorySlugParam && !filterCategoryIdParam ? 'bg-primary text-primary-foreground border-primary' : 'border-border bg-background text-foreground hover:bg-muted'}`}
          >
            {lang === 'en' ? 'All' : 'Todos'}
          </a>
          {bindCategories.map((cat) => {
            const isActive = categorySlugParam === cat.slug || filterCategoryId === cat.id;
            return (
              <a
                href={`${lang === 'en' ? '/en/products' : '/productos'}?category=${cat.slug}`}
                class={`rounded-full px-4 py-1.5 text-sm font-medium border transition-colors ${isActive ? 'bg-primary text-primary-foreground border-primary' : 'border-border bg-background text-foreground hover:bg-muted'}`}
              >
                {getCategoryName(cat, lang)}
              </a>
            );
          })}
        </div>
      )}

      <!-- ── Chips de tipo de filtro (categoría 2, client-side) ──────── -->
      {categoryInfo && categories.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-6">
          <button
            class="filter-btn rounded-full px-4 py-1.5 text-sm font-medium border bg-primary text-primary-foreground border-primary transition-colors"
            data-category="all"
          >
            {lang === 'en' ? 'All types' : 'Todos los tipos'}
          </button>
          {categories.map((cat) => (
            <button
              class="filter-btn rounded-full px-4 py-1.5 text-sm font-medium border border-border bg-background text-foreground hover:bg-muted transition-colors"
              data-category={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      )}

      <!-- ── Contador de resultados ────────────────────────────────────── -->
      <p class="text-xs text-muted-foreground mb-4">
        <span id="results-count">{products.length}</span> {lang === 'en' ? 'products found' : 'productos encontrados'}
      </p>

      <!-- ── Grid de productos ─────────────────────────────────────────── -->
      <div class="grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 lg:grid-cols-4 xl:gap-x-6" id="products-grid">
        {products.map((product) => (
          <div
            class="group product-card relative flex flex-col"
            data-product-uuid={product.uuid}
            data-category={product.category}
            data-price={product.price}
            data-stock={product.stock}
            data-currency={product.currency || 'MXN'}
            data-price-usd={product.priceUSD || ''}
          >
            <a href={`/product/${product.uuid}`} class="block flex-shrink-0">
              <div class="w-full aspect-square overflow-hidden rounded-xl bg-muted">
                <LazyImage
                  src={product.imageUrl}
                  alt={product.name}
                  class="h-full w-full object-cover object-center group-hover:opacity-80 transition-opacity duration-300"
                />
              </div>
              <h3 class="mt-3 text-sm font-medium text-foreground line-clamp-2 min-h-[2.5rem]">
                {product.name}
              </h3>
            </a>
            <p class="mt-0.5 text-xs text-muted-foreground">{product.category}</p>

            {product.variantCount > 0 && (
              <div class="mt-1">
                <p class="text-xs text-primary font-medium">
                  {product.variantCount} {product.variantCount === 1 ? (lang === 'en' ? 'size available' : 'tamaño disponible') : (lang === 'en' ? 'sizes available' : 'tamaños disponibles')}
                </p>
                {product.minPrice !== product.maxPrice ? (
                  <p class="text-sm font-semibold text-foreground mt-0.5">
                    {formatPrice(product.minPrice, product.currency || 'MXN')} – {formatPrice(product.maxPrice, product.currency || 'MXN')}
                  </p>
                ) : (
                  <p class="text-sm font-semibold text-foreground mt-0.5">
                    {formatPrice(product.price, product.currency || 'MXN')}
                  </p>
                )}
              </div>
            )}

            {product.variantCount === 0 && (
              <div class="mt-1 flex items-center justify-between">
                <p class="text-sm font-semibold text-foreground">
                  {formatPrice(product.price, product.currency || 'MXN')}
                </p>
                {product.stock > 0 ? (
                  <span class="text-xs text-green-600 font-medium">{lang === 'en' ? 'In stock' : 'En stock'}</span>
                ) : (
                  <span class="text-xs text-red-500 font-medium">{lang === 'en' ? 'Out of stock' : 'Agotado'}</span>
                )}
              </div>
            )}

            <div class="mt-auto pt-3">
              {product.variantCount > 0 ? (
                <a
                  href={`/product/${product.uuid}`}
                  class="w-full inline-flex items-center justify-center rounded-lg bg-primary px-3 py-2 text-xs font-semibold text-primary-foreground hover:bg-primary/90 transition-colors"
                >
                  {lang === 'en' ? 'View sizes' : 'Ver tamaños'}
                </a>
              ) : product.stock > 0 ? (
                <button
                  type="button"
                  class="w-full rounded-lg bg-primary px-3 py-2 text-xs font-semibold text-primary-foreground hover:bg-primary/90 transition-colors"
                  onclick={`event.stopPropagation(); addToCartQuick('${product.uuid}', ${product.id}, '${product.name}', ${product.price}, '${product.imageUrl}', '${product.category || ''}', '${product.currency || 'MXN'}')`}
                >
                  {lang === 'en' ? 'Add to cart' : 'Agregar al carrito'}
                </button>
              ) : (
                <button
                  type="button"
                  disabled
                  class="w-full rounded-lg bg-muted px-3 py-2 text-xs font-semibold text-muted-foreground cursor-not-allowed"
                >
                  {lang === 'en' ? 'Unavailable' : 'No disponible'}
                </button>
              )}
            </div>
          </div>
        ))}
      </div>

      {products.length === 0 && (
        <div class="text-center py-24">
          <svg class="mx-auto h-12 w-12 text-muted-foreground/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
          <h3 class="mt-4 text-lg font-medium text-foreground">
            {lang === 'en' ? 'No products available' : 'Sin productos disponibles'}
          </h3>
          <p class="mt-2 text-sm text-muted-foreground">
            {lang === 'en' ? 'Check back soon for new arrivals.' : 'Vuelve pronto para ver novedades.'}
          </p>
        </div>
      )}

    </div>
  </div>
</WebsiteLayout>

<script>
  const allProducts = document.querySelectorAll('.product-card');
  let currentCategory = 'all';
  let currentSearchTerm = '';

  function applyFilters(): void {
    let visibleCount = 0;
    allProducts.forEach(card => {
      const el = card as HTMLElement;
      const name = el.querySelector('h3')?.textContent?.toLowerCase() || '';
      const cat = el.getAttribute('data-category') || '';
      const matchSearch = currentSearchTerm === '' || name.includes(currentSearchTerm.toLowerCase());
      const matchCat = currentCategory === 'all' || cat === currentCategory;
      if (matchSearch && matchCat) { el.style.display = ''; visibleCount++; }
      else { el.style.display = 'none'; }
    });
    const counter = document.getElementById('results-count');
    if (counter) counter.textContent = visibleCount.toString();
  }

  function filterByCategory(category: string): void {
    currentCategory = category;
    document.querySelectorAll('.filter-btn').forEach(btn => {
      const active = btn.getAttribute('data-category') === category;
      btn.classList.toggle('bg-primary', active);
      btn.classList.toggle('text-primary-foreground', active);
      btn.classList.toggle('border-primary', active);
      btn.classList.toggle('bg-background', !active);
      btn.classList.toggle('text-foreground', !active);
      btn.classList.toggle('border-border', !active);
    });
    applyFilters();
  }

  async function addToCartQuick(uuid: string, product_id: number, name: string, price: number, image_url: string, category: string, currency: string = 'MXN'): Promise<void> {
    const cartData = localStorage.getItem('starfilters_cart');
    let cart = cartData ? JSON.parse(cartData) : { items: [], total: 0, itemCount: 0, currency };
    if (!cart.currency) cart.currency = currency;

    const idx = cart.items.findIndex((item: any) => item.uuid === uuid);
    if (idx >= 0) {
      cart.items[idx].quantity += 1;
      cart.items[idx].price = price;
      cart.items[idx].currency = currency;
    } else {
      cart.items.push({ uuid, product_id, name, price, currency, quantity: 1, image_url, category });
    }
    cart.total = cart.items.reduce((t: number, i: any) => t + i.price * i.quantity, 0);
    cart.itemCount = cart.items.reduce((c: number, i: any) => c + i.quantity, 0);
    localStorage.setItem('starfilters_cart', JSON.stringify(cart));

    showNotification(`${name} agregado al carrito`);
    window.dispatchEvent(new CustomEvent('cartUpdated', { detail: cart }));
  }

  function showNotification(message: string): void {
    const n = document.createElement('div');
    n.className = 'fixed top-20 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 transition-all duration-300';
    n.innerHTML = `<div class="flex items-center gap-2"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg><span>${message}</span></div>`;
    document.body.appendChild(n);
    setTimeout(() => { n.style.opacity = '0'; setTimeout(() => n.remove(), 300); }, 3000);
  }

  (window as any).addToCartQuick = addToCartQuick;

  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('search-products');
    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        currentSearchTerm = (e.target as HTMLInputElement).value;
        applyFilters();
      });
    }
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        filterByCategory(btn.getAttribute('data-category') || 'all');
      });
    });
  });
</script>
