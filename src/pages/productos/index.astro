---
import WebsiteLayout from "@/layouts/websiteLayout.astro";
import SEO from "@/components/shared/SEO.astro";
import WebshopContent from "@/components/shared/WebshopContent.astro";
import { generateBreadcrumbSchema } from "@/lib/seo-utils";
import { getLangFromUrl } from "@/i18n/utils";

export const prerender = false;

const lang = getLangFromUrl(Astro.url);
const siteUrl = Astro.site?.href || Astro.url.origin;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: lang === 'en' ? 'Home' : 'Inicio', url: siteUrl },
  { name: lang === 'en' ? 'Products' : 'Productos', url: `${siteUrl}/productos` }
]);
---

<WebsiteLayout
  title={lang === 'en' ? 'Products' : 'Productos'}
  seoTitle={lang === 'en' ? 'Products - Star Filters Catalog' : 'Productos - Catálogo Star Filters'}
  description={lang === 'en' ? 'Explore our full catalog of industrial air filters, cleanroom accessories, UMA units, air showers and laminar flow cabinets.' : 'Explora nuestro catálogo completo de filtros de aire industriales, accesorios para cuarto limpio, unidades UMA, air showers y cabinas de flujo laminar.'}
  keywords={lang === 'en' ? ['air filters', 'HEPA filters', 'cleanroom', 'UMA', 'air shower'] : ['filtros de aire', 'filtros HEPA', 'cuarto limpio', 'UMA', 'air shower']}
>
  <SEO
    slot="seo"
    title={lang === 'en' ? 'Products - Star Filters' : 'Productos - Star Filters'}
    description={lang === 'en' ? 'Industrial air filter catalog.' : 'Catálogo de filtros de aire industriales.'}
    ogType="website"
    keywords={lang === 'en' ? ['air filters', 'HEPA filters'] : ['filtros de aire', 'filtros HEPA']}
  />
  <script slot="seo" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />

  <WebshopContent />
</WebsiteLayout>
