---
import WebsiteLayout from "@/layouts/websiteLayout.astro";
import { getLangFromUrl } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
---

<WebsiteLayout
  title={lang === 'en' ? 'Page not found' : 'Página no encontrada'}
  seoTitle={lang === 'en' ? '404 – Page not found | Star Filters' : '404 – Página no encontrada | Star Filters'}
  description={lang === 'en' ? 'The page you are looking for does not exist.' : 'La página que buscas no existe.'}
>
  <div class="min-h-[70vh] flex items-center justify-center px-6 py-24">
    <div class="text-center max-w-lg mx-auto">

      <!-- Número 404 grande -->
      <p class="text-8xl font-bold text-primary/20 select-none">404</p>

      <!-- Ícono filtro -->
      <div class="mt-2 flex justify-center">
        <svg class="w-16 h-16 text-primary/40" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
        </svg>
      </div>

      <h1 class="mt-6 text-3xl font-semibold text-gray-900">
        {lang === 'en' ? 'Page not found' : 'Página no encontrada'}
      </h1>
      <p class="mt-4 text-base text-gray-500 leading-relaxed">
        {lang === 'en'
          ? 'The page you are looking for may have moved or no longer exists. Try searching from the home page.'
          : 'La página que buscas puede haber cambiado de lugar o ya no existe. Intenta desde la página de inicio.'}
      </p>

      <!-- Buscador rápido -->
      <form
        action={lang === 'en' ? '/en/filters' : '/filtros'}
        method="get"
        class="mt-8 flex gap-2"
      >
        <input
          type="text"
          name="q"
          placeholder={lang === 'en' ? 'Search filters...' : 'Buscar filtros...'}
          class="flex-1 rounded-full border border-gray-300 px-5 py-3 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-primary/40"
        />
        <button
          type="submit"
          class="rounded-full bg-primary px-5 py-3 text-sm font-semibold text-white hover:bg-primary/90 transition-colors"
        >
          {lang === 'en' ? 'Search' : 'Buscar'}
        </button>
      </form>

      <!-- Links rápidos -->
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <a href={lang === 'en' ? '/en' : '/'} class="rounded-full border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 hover:border-primary hover:text-primary transition-colors">
          {lang === 'en' ? '← Home' : '← Inicio'}
        </a>
        <a href={lang === 'en' ? '/en/filters' : '/filtros'} class="rounded-full border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 hover:border-primary hover:text-primary transition-colors">
          {lang === 'en' ? 'Air Filters' : 'Filtros de Aire'}
        </a>
        <a href={lang === 'en' ? '/en/cleanrooms' : '/cuartos-limpios'} class="rounded-full border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 hover:border-primary hover:text-primary transition-colors">
          {lang === 'en' ? 'Cleanrooms' : 'Cuartos Limpios'}
        </a>
        <a href={lang === 'en' ? '/en/contact' : '/contacto'} class="rounded-full bg-primary px-5 py-2.5 text-sm font-semibold text-white hover:bg-primary/90 transition-colors">
          {lang === 'en' ? 'Contact us' : 'Contáctanos'}
        </a>
      </div>

    </div>
  </div>
</WebsiteLayout>
