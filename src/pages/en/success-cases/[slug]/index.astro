---
import WebsiteLayout from "@/layouts/websiteLayout.astro";
import SEO from "@/components/shared/SEO.astro";
import SplitCTA from "@/components/shared/SplitCTA.astro";
import { getCaseStudyBySlug, getActiveCaseStudies } from "@/lib/database";
import { generateBreadcrumbSchema } from "@/lib/seo-utils";

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/en/success-cases');

const caseStudy = await getCaseStudyBySlug(slug);
if (!caseStudy) return Astro.redirect('/en/success-cases');

const title = caseStudy.title_en || caseStudy.title;
const excerpt = caseStudy.excerpt_en || caseStudy.excerpt;
const challenge = caseStudy.challenge_en || caseStudy.challenge;
const solution = caseStudy.solution_en || caseStudy.solution;
const results = caseStudy.results_en || caseStudy.results;
const industry = caseStudy.industry_en || caseStudy.industry;

const related = (await getActiveCaseStudies())
  .filter((c) => c.slug !== slug && c.industry === caseStudy.industry)
  .slice(0, 3);

const siteUrl = Astro.site?.href || Astro.url.origin;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: siteUrl },
  { name: 'Success Cases', url: `${siteUrl}/en/success-cases` },
  { name: title, url: `${siteUrl}/en/success-cases/${caseStudy.slug}` },
]);

const getTagsArray = (tags?: string) =>
  tags ? tags.split(',').map((t) => t.trim()).filter(Boolean) : [];
const tags = getTagsArray(caseStudy.tags);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long' }).format(new Date(date));
---

<WebsiteLayout
  title={title}
  seoTitle={`${title} | Success Cases | Star Filters`}
  description={excerpt || `Star Filters success case in ${industry}: challenge, solution, and results.`}
  keywords={[...tags, 'Star Filters', industry, 'industrial filtration']}
  ogImage={caseStudy.featured_image}
>
  <SEO
    slot="seo"
    title={`${title} | Star Filters`}
    description={excerpt || `Industrial filtration success case in ${industry}.`}
    ogType="article"
    ogImage={caseStudy.featured_image}
    keywords={[...tags, 'Star Filters', industry]}
  />
  <script slot="seo" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <article class="bg-background">
    <div>
      {caseStudy.featured_image ? (
        <div class="h-56 sm:h-96 overflow-hidden">
          <img src={caseStudy.featured_image} alt={title} class="h-full w-full object-cover" />
        </div>
      ) : (
        <div class="h-40 bg-gradient-to-br from-primary/10 to-primary/5"></div>
      )}
      <div class="bg-primary/5 border-b border-border">
        <div class="max-w-4xl mx-auto px-6 py-8">
          <div class="flex flex-wrap items-center gap-3 mb-3">
            <span class="inline-flex items-center rounded-full bg-primary px-3 py-1 text-xs font-semibold text-primary-foreground">
              {industry}
            </span>
            {caseStudy.client_name && (
              <span class="inline-flex items-center rounded-full bg-background px-3 py-1 text-xs font-medium text-foreground">{caseStudy.client_name}</span>
            )}
            <span class="inline-flex items-center rounded-full bg-background px-3 py-1 text-xs font-medium text-foreground">{formatDate(caseStudy.created_at)}</span>
          </div>
          <h1 class="text-3xl sm:text-4xl font-bold text-foreground leading-tight">{title}</h1>
          {excerpt && <p class="mt-3 text-lg text-muted-foreground max-w-2xl">{excerpt}</p>}
        </div>
      </div>
    </div>

    <div class="border-b border-border bg-primary/10">
      <div class="mx-auto max-w-4xl px-6 py-3">
        <nav class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
          <a href="/en" class="hover:text-foreground transition-colors">Home</a>
          <svg class="h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
          <a href="/en/success-cases" class="hover:text-foreground transition-colors">Success Cases</a>
          <svg class="h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
          <span class="text-foreground font-medium">{title}</span>
        </nav>
      </div>
    </div>

    <div class="mx-auto max-w-4xl px-6 py-16">
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-10">
          {tags.map((tag) => (
            <span class="inline-flex items-center rounded-md bg-muted px-3 py-1 text-sm text-muted-foreground">{tag}</span>
          ))}
        </div>
      )}

      <div class="space-y-14">
        {challenge && (
          <section>
            <div class="flex items-center gap-3 mb-5">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-red-100 text-red-700 font-bold text-sm flex-shrink-0">1</span>
              <h2 class="text-2xl font-semibold text-foreground">The Challenge</h2>
            </div>
            <div class="pl-11 prose prose-gray max-w-none text-muted-foreground leading-relaxed whitespace-pre-line">
              {challenge}
            </div>
          </section>
        )}

        {solution && (
          <section>
            <div class="flex items-center gap-3 mb-5">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-blue-100 text-blue-700 font-bold text-sm flex-shrink-0">2</span>
              <h2 class="text-2xl font-semibold text-foreground">The Solution</h2>
            </div>
            <div class="pl-11 prose prose-gray max-w-none text-muted-foreground leading-relaxed whitespace-pre-line">
              {solution}
            </div>
          </section>
        )}

        {results && (
          <section>
            <div class="flex items-center gap-3 mb-5">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-green-100 text-green-700 font-bold text-sm flex-shrink-0">3</span>
              <h2 class="text-2xl font-semibold text-foreground">The Results</h2>
            </div>
            <div class="pl-11 prose prose-gray max-w-none text-muted-foreground leading-relaxed whitespace-pre-line">
              {results}
            </div>
          </section>
        )}
      </div>

      <!-- Project gallery -->
      {caseStudy.gallery_images && caseStudy.gallery_images.length > 0 && (
        <div class="mt-14">
          <h2 class="text-2xl font-semibold text-foreground mb-6">Project Gallery</h2>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
            {caseStudy.gallery_images.map((url, i) => (
              <button
                type="button"
                class="gallery-thumb group relative aspect-square overflow-hidden rounded-xl focus:outline-none focus:ring-2 focus:ring-primary"
                data-src={url}
                data-index={i}
                aria-label={`View image ${i + 1}`}
              >
                <img
                  src={url}
                  alt={`${title} – image ${i + 1}`}
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center">
                  <svg class="h-8 w-8 text-white opacity-0 group-hover:opacity-100 transition-opacity" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/>
                  </svg>
                </div>
              </button>
            ))}
          </div>
        </div>
      )}

      <!-- Lightbox -->
      <div id="lightbox" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/90 p-4" role="dialog" aria-modal="true">
        <button id="lb-prev" class="absolute left-4 top-1/2 -translate-y-1/2 text-white hover:text-gray-300 transition-colors p-2" aria-label="Previous">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
        </button>
        <img id="lb-img" src="" alt="" class="max-h-[90vh] max-w-full rounded-lg object-contain" />
        <button id="lb-next" class="absolute right-4 top-1/2 -translate-y-1/2 text-white hover:text-gray-300 transition-colors p-2" aria-label="Next">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </button>
        <button id="lb-close" class="absolute top-4 right-4 text-white hover:text-gray-300 transition-colors p-2" aria-label="Close">
          <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
        <span id="lb-counter" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-sm text-white/70"></span>
      </div>

      {related.length > 0 && (
        <div class="mt-16">
          <h3 class="text-lg font-semibold text-foreground mb-6">More cases in {industry}</h3>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {related.map((r) => {
              const relTitle = r.title_en || r.title;
              return (
                <a
                  href={`/en/success-cases/${r.slug}`}
                  class="group rounded-xl border border-border bg-background p-4 hover:border-primary/50 hover:shadow-sm transition-all"
                >
                  {r.featured_image && (
                    <div class="h-28 overflow-hidden rounded-md mb-3">
                      <img src={r.featured_image} alt={relTitle} class="h-full w-full object-cover group-hover:scale-105 transition-transform" loading="lazy" />
                    </div>
                  )}
                  <p class="text-sm font-medium text-foreground group-hover:text-primary transition-colors line-clamp-2">{relTitle}</p>
                </a>
              );
            })}
          </div>
        </div>
      )}

      <div class="mt-10">
        <a href="/en/success-cases" class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          View all success cases
        </a>
      </div>
    </div>
  </article>

  <script>
    const thumbs = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery-thumb'));
    const lightbox = document.getElementById('lightbox')!;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbCounter = document.getElementById('lb-counter')!;
    let current = 0;

    const srcs = thumbs.map((t) => t.dataset.src!);

    function show(index: number) {
      current = (index + srcs.length) % srcs.length;
      lbImg.src = srcs[current];
      lbCounter.textContent = `${current + 1} / ${srcs.length}`;
      lightbox.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function close() {
      lightbox.classList.add('hidden');
      document.body.style.overflow = '';
    }

    thumbs.forEach((btn, i) => btn.addEventListener('click', () => show(i)));
    document.getElementById('lb-close')!.addEventListener('click', close);
    document.getElementById('lb-prev')!.addEventListener('click', () => show(current - 1));
    document.getElementById('lb-next')!.addEventListener('click', () => show(current + 1));
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) close(); });
    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(current - 1);
      if (e.key === 'ArrowRight') show(current + 1);
    });
  </script>

  <SplitCTA
    badge="Specialized Engineering"
    title="Do you face a similar challenge?"
    description="Our engineers are ready to analyze your case and propose the most efficient filtration solution for your process and industry."
    whatsappMessage="Hello, I read one of your success cases and I would like help with a similar filtration challenge."
  />
</WebsiteLayout>
