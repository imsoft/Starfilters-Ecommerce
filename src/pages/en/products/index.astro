---
import WebsiteLayout from "@/layouts/websiteLayout.astro";
import SEO from "@/components/shared/SEO.astro";
import WebshopContent from "@/components/shared/WebshopContent.astro";
import { generateBreadcrumbSchema } from "@/lib/seo-utils";

export const prerender = false;

const siteUrl = Astro.site?.href || Astro.url.origin;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Home', url: `${siteUrl}/en` },
  { name: 'Products', url: `${siteUrl}/en/products` }
]);
---

<WebsiteLayout
  title="Products"
  seoTitle="Products - Star Filters Catalog"
  description="Explore our full catalog of industrial air filters, cleanroom accessories, UMA units, air showers and laminar flow cabinets."
  keywords={['air filters', 'HEPA filters', 'cleanroom', 'UMA', 'air shower']}
>
  <SEO
    slot="seo"
    title="Products - Star Filters"
    description="Industrial air filter catalog."
    ogType="website"
    keywords={['air filters', 'HEPA filters']}
  />
  <script slot="seo" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />

  <WebshopContent />
</WebsiteLayout>
