---
import AdminLayout from "@/layouts/adminLayout.astro";
import { Button } from "@/components/ui/button";
import { getCaseStudyByUuid, updateCaseStudy } from "@/lib/database";

const { uuid } = Astro.params;
if (!uuid) return Astro.redirect('/admin/casos-de-exito');

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();

  const slug = (formData.get('slug') as string || '').trim().toLowerCase().replace(/\s+/g, '-');
  const title = formData.get('title') as string;
  const title_en = formData.get('title_en') as string | null;
  const industry = formData.get('industry') as string;
  const industry_en = formData.get('industry_en') as string | null;
  const excerpt = formData.get('excerpt') as string | null;
  const excerpt_en = formData.get('excerpt_en') as string | null;
  const challenge = formData.get('challenge') as string | null;
  const challenge_en = formData.get('challenge_en') as string | null;
  const solution = formData.get('solution') as string | null;
  const solution_en = formData.get('solution_en') as string | null;
  const results = formData.get('results') as string | null;
  const results_en = formData.get('results_en') as string | null;
  const client_name = formData.get('client_name') as string | null;
  const featured_image = formData.get('featured_image') as string | null;
  const gallery_images_raw = formData.get('gallery_images') as string | null;
  const gallery_images: string[] = gallery_images_raw ? JSON.parse(gallery_images_raw) : [];
  const tags = formData.get('tags') as string | null;
  const is_active = formData.get('is_active') === '1';

  if (!slug || !title || !industry) {
    return Astro.redirect(`/admin/casos-de-exito/edit/${uuid}?error=missing_fields`);
  }

  try {
    const updated = await updateCaseStudy(uuid, {
      slug,
      title,
      title_en: title_en || undefined,
      industry,
      industry_en: industry_en || undefined,
      excerpt: excerpt || undefined,
      excerpt_en: excerpt_en || undefined,
      challenge: challenge || undefined,
      challenge_en: challenge_en || undefined,
      solution: solution || undefined,
      solution_en: solution_en || undefined,
      results: results || undefined,
      results_en: results_en || undefined,
      client_name: client_name || undefined,
      featured_image: featured_image || undefined,
      gallery_images,
      tags: tags || undefined,
      is_active,
    });

    if (updated) return Astro.redirect('/admin/casos-de-exito?success=updated');
    return Astro.redirect(`/admin/casos-de-exito/edit/${uuid}?error=update_failed`);
  } catch (error) {
    console.error(error);
    return Astro.redirect(`/admin/casos-de-exito/edit/${uuid}?error=update_failed`);
  }
}

const caseStudy = await getCaseStudyByUuid(uuid);
if (!caseStudy) return Astro.redirect('/admin/casos-de-exito');

const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');
---

<AdminLayout title={`Editar: ${caseStudy.title}`}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="mt-10 mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">Editar Caso de Éxito</h1>
        <p class="mt-2 text-muted-foreground">{caseStudy.title}</p>
      </div>
      <div class="flex gap-2">
        <a href={`/casos-de-exito/${caseStudy.slug}`} target="_blank">
          <Button variant="outline" className="border-border text-foreground hover:bg-muted">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
            Ver
          </Button>
        </a>
        <a href="/admin/casos-de-exito">
          <Button variant="outline" className="border-border text-foreground hover:bg-muted">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Volver
          </Button>
        </a>
      </div>
    </div>

    {error === 'missing_fields' && (
      <div class="mb-6 rounded-md bg-yellow-50 p-4">
        <p class="text-sm font-medium text-yellow-800">Por favor completa todos los campos requeridos (Slug, Título, Industria).</p>
      </div>
    )}
    {error === 'update_failed' && (
      <div class="mb-6 rounded-md bg-red-50 p-4">
        <p class="text-sm font-medium text-red-800">Error al actualizar el caso. Verifica que el slug sea único e inténtalo de nuevo.</p>
      </div>
    )}

    <form method="POST" class="space-y-6">
      <!-- Imagen destacada -->
      <div class="rounded-lg border border-border bg-background p-6">
        <h2 class="text-lg font-semibold text-foreground mb-4">Imagen Destacada</h2>
        {caseStudy.featured_image ? (
          <div id="image-preview-wrap" class="mb-4">
            <img id="image-preview" src={caseStudy.featured_image} alt="Preview" class="h-48 w-full object-cover rounded-lg" />
          </div>
        ) : (
          <div id="image-preview-wrap" class="hidden mb-4">
            <img id="image-preview" src="" alt="Preview" class="h-48 w-full object-cover rounded-lg" />
          </div>
        )}
        <div
          id="drop-zone"
          class={`flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-border p-10 cursor-pointer hover:border-primary transition-colors ${caseStudy.featured_image ? 'hidden' : ''}`}
        >
          <svg class="h-10 w-10 text-muted-foreground mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <p class="text-sm text-muted-foreground mb-1">Arrastra una imagen o haz clic para seleccionar</p>
          <p class="text-xs text-muted-foreground">JPG, PNG, WEBP · Máx. 10MB</p>
          <input id="image-file-input" type="file" accept="image/*" class="hidden" />
        </div>
        {caseStudy.featured_image && (
          <button type="button" id="change-image-btn" class="mt-2 text-xs text-primary hover:underline">
            Cambiar imagen
          </button>
        )}
        <p id="upload-status" class="mt-2 text-xs text-muted-foreground"></p>
        <input type="hidden" id="featured_image" name="featured_image" value={caseStudy.featured_image || ''} />
      </div>

      <!-- Identificación -->
      <div class="rounded-lg border border-border bg-background p-6">
        <h2 class="text-lg font-semibold text-foreground mb-4">Identificación</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label for="slug" class="block text-sm font-medium text-foreground mb-1">Slug (URL) *</label>
            <input type="text" id="slug" name="slug" required value={caseStudy.slug}
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
            <p class="mt-1 text-xs text-muted-foreground">Solo minúsculas, números y guiones.</p>
          </div>
          <div>
            <label for="client_name" class="block text-sm font-medium text-foreground mb-1">Cliente (opcional)</label>
            <input type="text" id="client_name" name="client_name" value={caseStudy.client_name || ''}
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary"
              placeholder="Pfizer México" />
          </div>
          <div>
            <label for="industry" class="block text-sm font-medium text-foreground mb-1">Industria * 🇲🇽</label>
            <input type="text" id="industry" name="industry" required value={caseStudy.industry}
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary"
              list="industry-suggestions" />
            <datalist id="industry-suggestions">
              <option value="Farmacéutica" />
              <option value="Automotriz" />
              <option value="Alimentaria" />
              <option value="Electrónica" />
              <option value="Aeroespacial" />
              <option value="Hospitalaria" />
              <option value="Química" />
              <option value="Cosmética" />
            </datalist>
          </div>
          <div>
            <label for="industry_en" class="block text-sm font-medium text-foreground mb-1">Industry 🇺🇸</label>
            <input type="text" id="industry_en" name="industry_en" value={caseStudy.industry_en || ''}
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary"
              placeholder="Pharmaceutical" />
          </div>
          <div class="sm:col-span-2">
            <label for="tags" class="block text-sm font-medium text-foreground mb-1">Etiquetas (separadas por coma)</label>
            <input type="text" id="tags" name="tags" value={caseStudy.tags || ''}
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary"
              placeholder="HEPA, ISO 5, cuarto limpio, validación" />
          </div>
        </div>
      </div>

      <!-- Título -->
      <div class="rounded-lg border border-border bg-background p-6">
        <h2 class="text-lg font-semibold text-foreground mb-6">Título y Resumen</h2>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-foreground mb-1">🇲🇽 Título *</label>
            <input type="text" name="title" required value={caseStudy.title}
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium text-foreground mb-1">🇺🇸 Title</label>
            <input type="text" name="title_en" value={caseStudy.title_en || ''}
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary" />
          </div>
          <div>
            <label class="block text-sm font-medium text-foreground mb-1">🇲🇽 Resumen breve</label>
            <textarea name="excerpt" rows="3"
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary">{caseStudy.excerpt || ''}</textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-foreground mb-1">🇺🇸 Excerpt</label>
            <textarea name="excerpt_en" rows="3"
              class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary">{caseStudy.excerpt_en || ''}</textarea>
          </div>
        </div>
      </div>

      <!-- Contenido del caso -->
      <div class="rounded-lg border border-border bg-background p-6">
        <h2 class="text-lg font-semibold text-foreground mb-6">Contenido del Caso</h2>

        <div class="mb-8">
          <h3 class="text-base font-semibold text-foreground mb-4 flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-red-100 text-red-700 text-xs font-bold">1</span>
            El Reto
          </h3>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-foreground mb-1">🇲🇽 Descripción del reto</label>
              <textarea name="challenge" rows="5"
                class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary">{caseStudy.challenge || ''}</textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-foreground mb-1">🇺🇸 Challenge description</label>
              <textarea name="challenge_en" rows="5"
                class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary">{caseStudy.challenge_en || ''}</textarea>
            </div>
          </div>
        </div>

        <div class="mb-8">
          <h3 class="text-base font-semibold text-foreground mb-4 flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-blue-100 text-blue-700 text-xs font-bold">2</span>
            La Solución
          </h3>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-foreground mb-1">🇲🇽 Solución implementada</label>
              <textarea name="solution" rows="5"
                class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary">{caseStudy.solution || ''}</textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-foreground mb-1">🇺🇸 Implemented solution</label>
              <textarea name="solution_en" rows="5"
                class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary">{caseStudy.solution_en || ''}</textarea>
            </div>
          </div>
        </div>

        <div>
          <h3 class="text-base font-semibold text-foreground mb-4 flex items-center gap-2">
            <span class="flex h-6 w-6 items-center justify-center rounded-full bg-green-100 text-green-700 text-xs font-bold">3</span>
            Los Resultados
          </h3>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-foreground mb-1">🇲🇽 Resultados obtenidos</label>
              <textarea name="results" rows="5"
                class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary">{caseStudy.results || ''}</textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-foreground mb-1">🇺🇸 Results achieved</label>
              <textarea name="results_en" rows="5"
                class="w-full rounded-md border border-border bg-background px-3 py-2 text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary">{caseStudy.results_en || ''}</textarea>
            </div>
          </div>
        </div>
      </div>

      <!-- Galería de imágenes -->
      <div class="rounded-lg border border-border bg-background p-6">
        <h2 class="text-lg font-semibold text-foreground mb-1">Galería de Imágenes</h2>
        <p class="text-sm text-muted-foreground mb-4">Sube varias fotos del proyecto. Se mostrarán como galería en la página pública.</p>

        <div id="gallery-grid" class="grid grid-cols-3 sm:grid-cols-4 gap-3 mb-4"></div>

        <div
          id="gallery-drop-zone"
          class="flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-border p-8 cursor-pointer hover:border-primary transition-colors"
        >
          <svg class="h-8 w-8 text-muted-foreground mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
          </svg>
          <p class="text-sm text-muted-foreground">Arrastra imágenes o haz clic para agregar</p>
          <p class="text-xs text-muted-foreground mt-1">JPG, PNG, WEBP · Máx. 10MB por imagen</p>
          <input id="gallery-file-input" type="file" accept="image/*" multiple class="hidden" />
        </div>
        <p id="gallery-status" class="mt-2 text-xs text-muted-foreground"></p>
        <input type="hidden" id="gallery_images" name="gallery_images"
          value={JSON.stringify(caseStudy.gallery_images || [])} />
      </div>

      <!-- Configuración -->
      <div class="rounded-lg border border-border bg-background p-6">
        <h2 class="text-lg font-semibold text-foreground mb-4">Configuración</h2>
        <div>
          <label class="block text-sm font-medium text-foreground mb-2">Estado</label>
          <div class="flex gap-4">
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="is_active" value="1" checked={caseStudy.is_active} class="text-primary" />
              <span class="text-sm text-foreground">Activo (visible en el sitio)</span>
            </label>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="radio" name="is_active" value="0" checked={!caseStudy.is_active} class="text-primary" />
              <span class="text-sm text-foreground">Inactivo (oculto)</span>
            </label>
          </div>
        </div>
      </div>

      <div class="flex justify-end gap-4">
        <a href="/admin/casos-de-exito">
          <Button type="button" variant="outline" className="border-border text-foreground hover:bg-muted">
            Cancelar
          </Button>
        </a>
        <Button type="submit" className="bg-primary text-primary-foreground hover:bg-primary/90">
          Guardar Cambios
        </Button>
      </div>
    </form>
  </div>
</AdminLayout>

<script>
  const dropZone = document.getElementById('drop-zone') as HTMLElement;
  const fileInput = document.getElementById('image-file-input') as HTMLInputElement;
  const imageUrlInput = document.getElementById('featured_image') as HTMLInputElement;
  const statusEl = document.getElementById('upload-status') as HTMLElement;
  const previewWrap = document.getElementById('image-preview-wrap') as HTMLElement;
  const previewImg = document.getElementById('image-preview') as HTMLImageElement;
  const changeBtn = document.getElementById('change-image-btn') as HTMLButtonElement;

  changeBtn?.addEventListener('click', () => {
    previewWrap.classList.add('hidden');
    dropZone.classList.remove('hidden');
    changeBtn.classList.add('hidden');
    fileInput.click();
  });

  dropZone?.addEventListener('click', () => fileInput.click());
  dropZone?.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('border-primary'); });
  dropZone?.addEventListener('dragleave', () => dropZone.classList.remove('border-primary'));
  dropZone?.addEventListener('drop', (e) => {
    e.preventDefault();
    dropZone.classList.remove('border-primary');
    const file = e.dataTransfer?.files[0];
    if (file) uploadFile(file);
  });
  fileInput?.addEventListener('change', () => {
    if (fileInput.files?.[0]) uploadFile(fileInput.files[0]);
  });

  async function uploadFile(file: File) {
    statusEl.textContent = 'Subiendo imagen...';
    statusEl.style.color = '';
    const fd = new FormData();
    fd.append('image', file);
    try {
      const res = await fetch('/api/case-studies/upload-image', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.success) {
        imageUrlInput.value = data.url;
        previewImg.src = data.url;
        previewWrap.classList.remove('hidden');
        dropZone.classList.add('hidden');
        statusEl.textContent = '✅ Imagen subida correctamente';
        statusEl.style.color = 'green';
      } else {
        statusEl.textContent = '❌ ' + data.message;
        statusEl.style.color = 'red';
      }
    } catch {
      statusEl.textContent = '❌ Error al subir la imagen';
      statusEl.style.color = 'red';
    }
  }

  // ── Galería múltiple ─────────────────────────────────────────────────────────
  const galleryDropZone = document.getElementById('gallery-drop-zone') as HTMLElement;
  const galleryFileInput = document.getElementById('gallery-file-input') as HTMLInputElement;
  const galleryHidden = document.getElementById('gallery_images') as HTMLInputElement;
  const galleryGrid = document.getElementById('gallery-grid') as HTMLElement;
  const galleryStatus = document.getElementById('gallery-status') as HTMLElement;
  let galleryUrls: string[] = JSON.parse(galleryHidden.value || '[]');

  function renderGallery() {
    galleryGrid.innerHTML = '';
    galleryUrls.forEach((url, i) => {
      const wrap = document.createElement('div');
      wrap.className = 'relative group aspect-square rounded-lg overflow-hidden border border-border';
      wrap.innerHTML = `
        <img src="${url}" alt="Imagen ${i + 1}" class="h-full w-full object-cover" />
        <button type="button" data-i="${i}" class="gallery-remove absolute top-1 right-1 bg-black/60 text-white rounded-full p-0.5 transition-opacity" aria-label="Eliminar">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>`;
      galleryGrid.appendChild(wrap);
    });
    galleryGrid.querySelectorAll<HTMLButtonElement>('.gallery-remove').forEach((btn) => {
      btn.addEventListener('click', () => {
        galleryUrls.splice(Number(btn.dataset.i), 1);
        galleryHidden.value = JSON.stringify(galleryUrls);
        renderGallery();
      });
    });
  }

  async function uploadGalleryFile(file: File) {
    galleryStatus.textContent = `Subiendo ${file.name}...`;
    const fd = new FormData();
    fd.append('image', file);
    try {
      const res = await fetch('/api/case-studies/upload-image', { method: 'POST', body: fd });
      const data = await res.json();
      if (data.success) {
        galleryUrls.push(data.url);
        galleryHidden.value = JSON.stringify(galleryUrls);
        renderGallery();
        galleryStatus.textContent = `✅ ${galleryUrls.length} imagen(es) en galería`;
      } else {
        galleryStatus.textContent = '❌ ' + data.message;
      }
    } catch {
      galleryStatus.textContent = '❌ Error al subir imagen';
    }
  }

  async function uploadGalleryFiles(files: FileList) {
    for (const file of Array.from(files)) await uploadGalleryFile(file);
  }

  galleryDropZone.addEventListener('click', () => galleryFileInput.click());
  galleryDropZone.addEventListener('dragover', (e) => { e.preventDefault(); galleryDropZone.classList.add('border-primary'); });
  galleryDropZone.addEventListener('dragleave', () => galleryDropZone.classList.remove('border-primary'));
  galleryDropZone.addEventListener('drop', (e) => {
    e.preventDefault();
    galleryDropZone.classList.remove('border-primary');
    if (e.dataTransfer?.files.length) uploadGalleryFiles(e.dataTransfer.files);
  });
  galleryFileInput.addEventListener('change', () => {
    if (galleryFileInput.files?.length) uploadGalleryFiles(galleryFileInput.files);
  });

  renderGallery();
</script>
