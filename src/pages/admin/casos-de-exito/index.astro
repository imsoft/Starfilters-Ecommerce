---
import AdminLayout from "@/layouts/adminLayout.astro";
import { Button } from "@/components/ui/button";
import { getAllCaseStudies } from "@/lib/database";
import type { CaseStudy } from "@/lib/database";

const url = new URL(Astro.request.url);
const success = url.searchParams.get('success');

let cases: CaseStudy[] = [];
try {
  cases = await getAllCaseStudies();
} catch (error) {
  console.error('Error obteniendo casos de éxito:', error);
}
---

<AdminLayout title="Casos de Éxito">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mt-10 mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-foreground">Casos de Éxito</h1>
          <p class="mt-2 text-muted-foreground">
            Arrastra las filas para cambiar el orden de aparición
          </p>
        </div>
        <a href="/admin/casos-de-exito/create">
          <Button className="bg-primary text-primary-foreground hover:bg-primary/90">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Nuevo Caso
          </Button>
        </a>
      </div>
    </div>

    {success === 'created' && (
      <div class="mb-6 rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800">Caso de éxito creado exitosamente.</p>
      </div>
    )}
    {success === 'updated' && (
      <div class="mb-6 rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800">Caso de éxito actualizado exitosamente.</p>
      </div>
    )}
    {success === 'deleted' && (
      <div class="mb-6 rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800">Caso de éxito eliminado exitosamente.</p>
      </div>
    )}

    <div id="save-toast" class="hidden mb-4 rounded-md bg-green-50 p-3 text-sm font-medium text-green-800">
      ✅ Orden guardado correctamente
    </div>

    <div class="rounded-lg border border-border bg-background">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-muted">
            <tr>
              <th class="px-3 py-3 w-10"></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Caso</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Industria</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Cliente</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Estado</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody id="sortable-list" class="divide-y divide-border">
            {cases.length === 0 ? (
              <tr>
                <td colspan="6" class="px-6 py-12 text-center">
                  <div class="flex flex-col items-center">
                    <svg class="h-12 w-12 text-muted-foreground mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    <h3 class="text-lg font-medium text-foreground mb-2">No hay casos de éxito</h3>
                    <p class="text-muted-foreground mb-4">Documenta el primer proyecto resuelto por Starfilters.</p>
                    <a href="/admin/casos-de-exito/create">
                      <Button className="bg-primary text-primary-foreground hover:bg-primary/90">
                        Agregar Caso
                      </Button>
                    </a>
                  </div>
                </td>
              </tr>
            ) : (
              cases.map((c) => (
                <tr
                  class="hover:bg-muted/50 cursor-grab active:cursor-grabbing drag-row"
                  draggable="true"
                  data-uuid={c.uuid}
                >
                  <td class="px-3 py-4 text-muted-foreground">
                    <svg class="h-5 w-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"></path>
                    </svg>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center gap-3">
                      {c.featured_image ? (
                        <img
                          src={c.featured_image}
                          alt={c.title}
                          class="h-12 w-16 rounded-md object-cover flex-shrink-0"
                        />
                      ) : (
                        <div class="h-12 w-16 rounded-md bg-muted flex items-center justify-center flex-shrink-0">
                          <svg class="h-6 w-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                        </div>
                      )}
                      <div>
                        <div class="text-sm font-medium text-foreground">{c.title}</div>
                        <div class="text-xs text-muted-foreground font-mono">{c.slug}</div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-sm text-foreground">{c.industry}</span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class="text-sm text-muted-foreground">{c.client_name || '—'}</span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class={`inline-flex px-2 py-1 text-xs font-semibold rounded-full ${c.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'}`}>
                      {c.is_active ? 'Activo' : 'Inactivo'}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <div class="flex space-x-2">
                      <a href={`/casos-de-exito/${c.slug}`} target="_blank">
                        <Button variant="outline" size="sm" className="border-border text-foreground hover:bg-muted" title="Ver en sitio">
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                          </svg>
                        </Button>
                      </a>
                      <a href={`/admin/casos-de-exito/edit/${c.uuid}`}>
                        <Button variant="outline" size="sm" className="border-border text-foreground hover:bg-muted">
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                          </svg>
                        </Button>
                      </a>
                      <Button
                        variant="outline"
                        size="sm"
                        className="border-border text-red-600 hover:bg-red-50 delete-btn"
                        data-uuid={c.uuid}
                        data-title={c.title}
                      >
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                      </Button>
                    </div>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
      {cases.length > 0 && (
        <div class="px-6 py-4 border-t border-border">
          <p class="text-sm text-muted-foreground">
            <span class="font-medium text-foreground">{cases.length}</span> caso{cases.length !== 1 ? 's' : ''} en total
          </p>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  document.querySelectorAll<HTMLElement>('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const uuid = btn.dataset.uuid || '';
      const title = btn.dataset.title || '';
      if (!confirm(`¿Eliminar el caso "${title}"? Esta acción no se puede deshacer.`)) return;

      fetch('/api/case-studies/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ uuid }),
      })
        .then((r) => r.json())
        .then((data) => {
          if (data.success) window.location.href = '/admin/casos-de-exito?success=deleted';
          else alert('Error al eliminar: ' + data.message);
        })
        .catch(() => alert('Error al eliminar el caso.'));
    });
  });

  const tbody = document.getElementById('sortable-list') as HTMLElement;
  const toast = document.getElementById('save-toast') as HTMLElement;
  let dragRow: HTMLElement | null = null;

  function showToast() {
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 3000);
  }

  tbody?.addEventListener('dragstart', (e) => {
    dragRow = (e.target as HTMLElement).closest('tr');
    setTimeout(() => dragRow?.classList.add('opacity-40'), 0);
  });

  tbody?.addEventListener('dragend', () => {
    dragRow?.classList.remove('opacity-40');
    dragRow = null;
    document.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over', 'border-t-2', 'border-primary'));
  });

  tbody?.addEventListener('dragover', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('tr') as HTMLElement;
    if (!target || target === dragRow) return;
    document.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over', 'border-t-2', 'border-primary'));
    target.classList.add('drag-over', 'border-t-2', 'border-primary');
  });

  tbody?.addEventListener('drop', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('tr') as HTMLElement;
    if (!target || target === dragRow || !dragRow) return;

    const rows = Array.from(tbody.querySelectorAll('tr[data-uuid]'));
    const fromIndex = rows.indexOf(dragRow);
    const toIndex = rows.indexOf(target);
    if (fromIndex === -1 || toIndex === -1) return;

    if (fromIndex < toIndex) target.after(dragRow);
    else target.before(dragRow);

    const updated = Array.from(tbody.querySelectorAll('tr[data-uuid]')).map((row, i) => ({
      uuid: (row as HTMLElement).dataset.uuid!,
      sort_order: i,
    }));

    fetch('/api/case-studies/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: updated }),
    })
      .then((r) => r.json())
      .then((data) => { if (data.success) showToast(); })
      .catch(() => {});
  });
</script>
