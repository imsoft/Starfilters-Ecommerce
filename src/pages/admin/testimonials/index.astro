---
import AdminLayout from "@/layouts/adminLayout.astro";
import { Button } from "@/components/ui/button";
import { getAllTestimonials } from "@/lib/database";
import type { Testimonial } from "@/lib/database";

const url = new URL(Astro.request.url);
const success = url.searchParams.get('success');

let testimonials: Testimonial[] = [];
try {
  testimonials = await getAllTestimonials();
} catch (error) {
  console.error('Error obteniendo testimonios:', error);
}
---

<AdminLayout title="Testimonios">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mt-10 mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold tracking-tight text-foreground">Testimonios</h1>
          <p class="mt-2 text-muted-foreground">
            Arrastra las filas para cambiar el orden de aparición
          </p>
        </div>
        <a href="/admin/testimonials/create">
          <Button className="bg-primary text-primary-foreground hover:bg-primary/90">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
            </svg>
            Nuevo Testimonio
          </Button>
        </a>
      </div>
    </div>

    {success === 'created' && (
      <div class="mb-6 rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800">Testimonio creado exitosamente.</p>
      </div>
    )}
    {success === 'updated' && (
      <div class="mb-6 rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800">Testimonio actualizado exitosamente.</p>
      </div>
    )}
    {success === 'deleted' && (
      <div class="mb-6 rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800">Testimonio eliminado exitosamente.</p>
      </div>
    )}

    <div id="save-toast" class="hidden mb-4 rounded-md bg-green-50 p-3 text-sm font-medium text-green-800">
      ✅ Orden guardado correctamente
    </div>

    <!-- Tabla -->
    <div class="rounded-lg border border-border bg-background">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-muted">
            <tr>
              <th class="px-3 py-3 w-10"></th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Cliente</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Testimonio</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Imagen proyecto</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Estado</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-muted-foreground uppercase tracking-wider">Acciones</th>
            </tr>
          </thead>
          <tbody id="sortable-list" class="divide-y divide-border">
            {testimonials.length === 0 ? (
              <tr>
                <td colspan="6" class="px-6 py-12 text-center">
                  <div class="flex flex-col items-center">
                    <svg class="h-12 w-12 text-muted-foreground mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-3 3v-3z"></path>
                    </svg>
                    <h3 class="text-lg font-medium text-foreground mb-2">No hay testimonios</h3>
                    <p class="text-muted-foreground mb-4">Ejecuta la migración SQL para cargar los testimonios existentes.</p>
                    <a href="/admin/testimonials/create">
                      <Button className="bg-primary text-primary-foreground hover:bg-primary/90">Agregar Testimonio</Button>
                    </a>
                  </div>
                </td>
              </tr>
            ) : (
              testimonials.map((t) => (
                <tr
                  class="hover:bg-muted/50 cursor-grab active:cursor-grabbing drag-row"
                  draggable="true"
                  data-uuid={t.uuid}
                >
                  <td class="px-3 py-4 text-muted-foreground">
                    <svg class="h-5 w-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"></path>
                    </svg>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <div class="flex items-center gap-3">
                      {t.company_logo_url ? (
                        <div class="flex h-10 w-14 items-center justify-center rounded bg-white border border-border p-1 flex-shrink-0">
                          <img src={t.company_logo_url} alt={t.author} class="max-h-full max-w-full object-contain" />
                        </div>
                      ) : (
                        <div class="flex h-10 w-14 items-center justify-center rounded bg-muted flex-shrink-0">
                          <svg class="h-5 w-5 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                          </svg>
                        </div>
                      )}
                      <div>
                        <div class="text-sm font-semibold text-foreground">{t.author}</div>
                        <div class="text-xs text-muted-foreground">{t.role}</div>
                      </div>
                    </div>
                  </td>
                  <td class="px-6 py-4">
                    <p class="text-sm text-muted-foreground line-clamp-2 max-w-sm">{t.body}</p>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    {t.project_image_url ? (
                      <img src={t.project_image_url} alt="Proyecto" class="h-12 w-20 rounded object-cover" />
                    ) : (
                      <span class="text-xs text-muted-foreground italic">Sin imagen</span>
                    )}
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap">
                    <span class={`inline-flex px-2 py-1 text-xs font-semibold rounded-full ${t.is_active ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'}`}>
                      {t.is_active ? 'Activo' : 'Inactivo'}
                    </span>
                  </td>
                  <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                    <div class="flex space-x-2">
                      <a href={`/admin/testimonials/edit/${t.uuid}`}>
                        <Button variant="outline" size="sm" className="border-border text-foreground hover:bg-muted">
                          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                          </svg>
                        </Button>
                      </a>
                      <Button
                        variant="outline"
                        size="sm"
                        className="border-border text-red-600 hover:bg-red-50 delete-btn"
                        data-uuid={t.uuid}
                        data-author={t.author}
                      >
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                        </svg>
                      </Button>
                    </div>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
      {testimonials.length > 0 && (
        <div class="px-6 py-4 border-t border-border">
          <p class="text-sm text-muted-foreground">
            <span class="font-medium text-foreground">{testimonials.length}</span> testimonio{testimonials.length !== 1 ? 's' : ''} en total
          </p>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  // ── Delete ──────────────────────────────────────────────────────────────────
  document.querySelectorAll<HTMLElement>('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const uuid = btn.dataset.uuid || '';
      const author = btn.dataset.author || '';
      if (!confirm(`¿Eliminar el testimonio de "${author}"? Esta acción no se puede deshacer.`)) return;

      fetch('/api/testimonials/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ uuid }),
      })
        .then((r) => r.json())
        .then((data) => {
          if (data.success) window.location.href = '/admin/testimonials?success=deleted';
          else alert('Error al eliminar: ' + data.message);
        })
        .catch(() => alert('Error al eliminar el testimonio.'));
    });
  });

  // ── Drag and drop ───────────────────────────────────────────────────────────
  const tbody = document.getElementById('sortable-list') as HTMLElement;
  const toast = document.getElementById('save-toast') as HTMLElement;
  let dragRow: HTMLElement | null = null;

  function showToast() {
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 3000);
  }

  tbody?.addEventListener('dragstart', (e) => {
    dragRow = (e.target as HTMLElement).closest('tr');
    setTimeout(() => dragRow?.classList.add('opacity-40'), 0);
  });

  tbody?.addEventListener('dragend', () => {
    dragRow?.classList.remove('opacity-40');
    dragRow = null;
    document.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over', 'border-t-2', 'border-primary'));
  });

  tbody?.addEventListener('dragover', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('tr') as HTMLElement;
    if (!target || target === dragRow) return;
    document.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over', 'border-t-2', 'border-primary'));
    target.classList.add('drag-over', 'border-t-2', 'border-primary');
  });

  tbody?.addEventListener('drop', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('tr') as HTMLElement;
    if (!target || target === dragRow || !dragRow) return;

    const rows = Array.from(tbody.querySelectorAll('tr[data-uuid]'));
    const fromIndex = rows.indexOf(dragRow);
    const toIndex = rows.indexOf(target);

    if (fromIndex === -1 || toIndex === -1) return;

    if (fromIndex < toIndex) {
      target.after(dragRow);
    } else {
      target.before(dragRow);
    }

    const updated = Array.from(tbody.querySelectorAll('tr[data-uuid]')).map((row, i) => ({
      uuid: (row as HTMLElement).dataset.uuid!,
      sort_order: i,
    }));

    fetch('/api/testimonials/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: updated }),
    })
      .then((r) => r.json())
      .then((data) => { if (data.success) showToast(); })
      .catch(() => {});
  });
</script>
