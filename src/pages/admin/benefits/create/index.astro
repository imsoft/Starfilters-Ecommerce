---
import AdminLayout from '@/layouts/adminLayout.astro';
import { getAuthenticatedUser } from '@/lib/auth-utils';
import { isUserAdmin } from '@/lib/database';
import { createBenefit, getNextBenefitSortOrder } from '@/lib/benefit-service';

export const prerender = false;

const user = getAuthenticatedUser(Astro.cookies);
if (!user) return Astro.redirect('/login');

const userIsAdmin = await isUserAdmin(user.id);
if (!userIsAdmin) return Astro.redirect('/');

let errorMessage = '';
let formData = { text_es: '', text_en: '', is_active: true };

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  formData = {
    text_es: data.get('text_es')?.toString() || '',
    text_en: data.get('text_en')?.toString() || '',
    is_active: data.get('is_active') === 'on',
  };

  if (!formData.text_es.trim() || !formData.text_en.trim()) {
    errorMessage = 'El texto en ambos idiomas es requerido';
  } else {
    try {
      const sort_order = await getNextBenefitSortOrder();
      await createBenefit({
        text_es: formData.text_es.trim(),
        text_en: formData.text_en.trim(),
        is_active: formData.is_active,
        sort_order,
      });
      return Astro.redirect('/admin/benefits');
    } catch (error) {
      console.error('Error creating benefit:', error);
      errorMessage = 'Error al crear el beneficio';
    }
  }
}
---

<AdminLayout title="Crear Beneficio">
  <div class="px-4 sm:px-6 lg:px-8">
    <div class="mb-8">
      <a href="/admin/benefits" class="text-sm font-medium text-primary hover:text-foreground">
        ← Volver a beneficios
      </a>
    </div>

    <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Crear Beneficio</h2>

    {errorMessage && (
      <div class="mt-4 rounded-md bg-red-50 p-4">
        <p class="text-sm font-medium text-red-800">{errorMessage}</p>
      </div>
    )}

    <form method="POST" class="mt-8 space-y-8">
      <div class="grid grid-cols-1 gap-x-6 gap-y-8 sm:grid-cols-6">

        <div class="sm:col-span-6">
          <label for="text_es" class="block text-sm font-medium text-foreground">Texto en Español *</label>
          <input
            type="text"
            name="text_es"
            id="text_es"
            required
            maxlength="255"
            value={formData.text_es}
            class="mt-2 block w-full rounded-md border-0 px-3 py-2 text-foreground shadow-sm ring-1 ring-inset ring-border placeholder:text-muted-foreground focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm"
            placeholder="Más de 40 años de experiencia en filtración industrial"
          />
        </div>

        <div class="sm:col-span-6">
          <label for="text_en" class="block text-sm font-medium text-foreground">Text in English *</label>
          <input
            type="text"
            name="text_en"
            id="text_en"
            required
            maxlength="255"
            value={formData.text_en}
            class="mt-2 block w-full rounded-md border-0 px-3 py-2 text-foreground shadow-sm ring-1 ring-inset ring-border placeholder:text-muted-foreground focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm"
            placeholder="Over 40 years of experience in industrial filtration"
          />
        </div>

        <div class="sm:col-span-6">
          <div class="flex items-center">
            <input
              type="checkbox"
              name="is_active"
              id="is_active"
              checked={formData.is_active}
              class="h-4 w-4 rounded border-border text-primary focus:ring-primary"
            />
            <label for="is_active" class="ml-2 block text-sm text-foreground">Beneficio activo</label>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-end gap-x-6 border-t border-border pt-6">
        <a href="/admin/benefits" class="text-sm font-semibold text-foreground">Cancelar</a>
        <button type="submit" class="rounded-md bg-primary px-3 py-2 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary/90">
          Crear beneficio
        </button>
      </div>
    </form>
  </div>
</AdminLayout>
