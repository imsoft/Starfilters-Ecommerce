---
import AdminLayout from '@/layouts/adminLayout.astro';
import { getAuthenticatedUser } from '@/lib/auth-utils';
import { isUserAdmin } from '@/lib/database';
import { getAllBenefits, deleteBenefit } from '@/lib/benefit-service';

export const prerender = false;

const user = getAuthenticatedUser(Astro.cookies);
if (!user) return Astro.redirect('/login');

const userIsAdmin = await isUserAdmin(user.id);
if (!userIsAdmin) return Astro.redirect('/');

let successMessage = '';
let errorMessage = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action');
  const id = formData.get('id');

  if (action === 'delete' && id) {
    try {
      await deleteBenefit(parseInt(id as string));
      successMessage = 'Beneficio eliminado exitosamente';
    } catch (error) {
      console.error('Error deleting benefit:', error);
      errorMessage = 'Error al eliminar el beneficio';
    }
  }
}

const benefits = await getAllBenefits();
---

<AdminLayout title="Beneficios del Banner">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="mt-10 mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">Beneficios del Banner</h1>
        <p class="mt-2 text-muted-foreground">
          Arrastra las filas para cambiar el orden de aparición
        </p>
      </div>
      <a href="/admin/benefits/create">
        <button class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-sm hover:bg-primary/90">
          <svg class="mr-2 h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19,13H13V19H11V13H5V11H11V5H13V11H19V13Z"/>
          </svg>
          Agregar Beneficio
        </button>
      </a>
    </div>

    {successMessage && (
      <div class="mb-4 rounded-md bg-green-50 p-4">
        <p class="text-sm font-medium text-green-800">{successMessage}</p>
      </div>
    )}
    {errorMessage && (
      <div class="mb-4 rounded-md bg-red-50 p-4">
        <p class="text-sm font-medium text-red-800">{errorMessage}</p>
      </div>
    )}

    <div id="save-toast" class="hidden mb-4 rounded-md bg-green-50 p-3 text-sm font-medium text-green-800">
      ✅ Orden guardado correctamente
    </div>

    <div class="overflow-hidden rounded-lg border border-border bg-background shadow">
      {benefits.length === 0 ? (
        <div class="p-12 text-center">
          <svg class="mx-auto h-12 w-12 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" />
          </svg>
          <h3 class="mt-2 text-sm font-medium text-foreground">No hay beneficios</h3>
          <p class="mt-1 text-sm text-muted-foreground">Comienza creando el primer beneficio.</p>
          <div class="mt-6">
            <a href="/admin/benefits/create" class="inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90">
              Crear el primer beneficio
            </a>
          </div>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-border">
            <thead class="bg-muted/50">
              <tr>
                <th class="px-3 py-3 w-10"></th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-muted-foreground">Español</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-muted-foreground">English</th>
                <th class="px-6 py-3 text-left text-xs font-medium uppercase tracking-wider text-muted-foreground">Estado</th>
                <th class="px-6 py-3 text-right text-xs font-medium uppercase tracking-wider text-muted-foreground">Acciones</th>
              </tr>
            </thead>
            <tbody id="sortable-list" class="divide-y divide-border bg-background">
              {benefits.map((benefit) => (
                <tr
                  class="hover:bg-muted/50 cursor-grab active:cursor-grabbing drag-row"
                  draggable="true"
                  data-id={benefit.id}
                >
                  <td class="px-3 py-4 text-muted-foreground">
                    <svg class="h-5 w-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"></path>
                    </svg>
                  </td>
                  <td class="px-6 py-4 text-sm text-foreground max-w-xs truncate">{benefit.text_es}</td>
                  <td class="px-6 py-4 text-sm text-muted-foreground max-w-xs truncate">{benefit.text_en}</td>
                  <td class="whitespace-nowrap px-6 py-4 text-sm">
                    <span class={`inline-flex rounded-full px-2 text-xs font-semibold ${benefit.is_active ? 'bg-green-100 text-green-800' : 'bg-muted text-muted-foreground'}`}>
                      {benefit.is_active ? 'Activo' : 'Inactivo'}
                    </span>
                  </td>
                  <td class="whitespace-nowrap px-6 py-4 text-right text-sm font-medium">
                    <div class="flex items-center justify-end gap-2">
                      <a href={`/admin/benefits/edit/${benefit.id}`} class="text-primary hover:text-foreground" title="Editar">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                      </a>
                      <form method="POST" style="display: inline;">
                        <input type="hidden" name="action" value="delete" />
                        <input type="hidden" name="id" value={benefit.id} />
                        <button type="submit" class="text-destructive hover:text-destructive/80" title="Eliminar" onclick="return confirm('¿Estás seguro de eliminar este beneficio?')">
                          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                          </svg>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<script>
  const tbody = document.getElementById('sortable-list') as HTMLElement;
  const toast = document.getElementById('save-toast') as HTMLElement;
  let dragRow: HTMLElement | null = null;

  function showToast() {
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 3000);
  }

  tbody?.addEventListener('dragstart', (e) => {
    dragRow = (e.target as HTMLElement).closest('tr');
    setTimeout(() => dragRow?.classList.add('opacity-40'), 0);
  });

  tbody?.addEventListener('dragend', () => {
    dragRow?.classList.remove('opacity-40');
    dragRow = null;
    document.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over', 'border-t-2', 'border-primary'));
  });

  tbody?.addEventListener('dragover', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('tr') as HTMLElement;
    if (!target || target === dragRow) return;
    document.querySelectorAll('.drag-over').forEach((el) => el.classList.remove('drag-over', 'border-t-2', 'border-primary'));
    target.classList.add('drag-over', 'border-t-2', 'border-primary');
  });

  tbody?.addEventListener('drop', (e) => {
    e.preventDefault();
    const target = (e.target as HTMLElement).closest('tr') as HTMLElement;
    if (!target || target === dragRow || !dragRow) return;

    const rows = Array.from(tbody.querySelectorAll('tr[data-id]'));
    const fromIndex = rows.indexOf(dragRow);
    const toIndex = rows.indexOf(target);

    if (fromIndex === -1 || toIndex === -1) return;

    if (fromIndex < toIndex) {
      target.after(dragRow);
    } else {
      target.before(dragRow);
    }

    const updated = Array.from(tbody.querySelectorAll('tr[data-id]')).map((row, i) => ({
      id: parseInt((row as HTMLElement).dataset.id!),
      sort_order: i,
    }));

    fetch('/api/benefits/reorder', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: updated }),
    })
      .then((r) => r.json())
      .then((data) => { if (data.success) showToast(); })
      .catch(() => {});
  });
</script>
