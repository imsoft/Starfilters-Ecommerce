---
import AdminLayout from "@/layouts/adminLayout.astro";
import { getAuthenticatedUser } from '@/lib/auth-utils';
import { isUserAdmin } from '@/lib/database';
import {
  getHeroType, updateHeroType,
  getHeroImage, updateHeroImage,
  getHeroVideo, updateHeroVideo,
} from '@/lib/site-settings-service';
import { uploadImage, deleteImage, getPublicIdFromUrl } from '@/lib/cloudinary';
import { getYouTubeId, getYouTubeThumbnail } from '@/lib/video-utils';

export const prerender = false;

const user = getAuthenticatedUser(Astro.cookies);
if (!user) return Astro.redirect('/login');

const userIsAdmin = await isUserAdmin(user.id);
if (!userIsAdmin) return Astro.redirect('/');

let heroType  = await getHeroType();
let heroImage = await getHeroImage();
let heroVideo = await getHeroVideo();
let error: string | null = null;
let success: string | null = null;

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action") as string;

    // ── Cambiar tipo (imagen / video) ─────────────────────────────────
    if (action === "update_hero_type") {
      const type = formData.get("hero_type") as 'video' | 'image';
      if (type === 'video' || type === 'image') {
        await updateHeroType(type);
        heroType = type;
        success = `Tipo de fondo cambiado a: ${type === 'video' ? 'Video' : 'Imagen'}`;
      }

    // ── Subir imagen ──────────────────────────────────────────────────
    } else if (action === "upload_image") {
      const file = formData.get("hero_image") as File;
      if (!file || file.size === 0) { error = "Selecciona una imagen"; }
      else {
        if (heroImage && !heroImage.includes('hero-default')) {
          const publicId = getPublicIdFromUrl(heroImage);
          if (publicId) await deleteImage(publicId);
        }
        const buffer = await file.arrayBuffer();
        const url = await uploadImage(Buffer.from(buffer), { folder: 'starfilters-ecommerce/hero', public_id: `hero-img-${Date.now()}`, resource_type: 'image' });
        await updateHeroImage(url);
        await updateHeroType('image');
        heroImage = url;
        heroType  = 'image';
        success = "Imagen del Hero actualizada y activada";
      }

    // ── URL de imagen ─────────────────────────────────────────────────
    } else if (action === "image_url") {
      const url = formData.get("hero_image_url") as string;
      if (!url) { error = "Ingresa una URL"; }
      else {
        await updateHeroImage(url);
        await updateHeroType('image');
        heroImage = url;
        heroType  = 'image';
        success = "URL de imagen activada en el Hero";
      }

    // ── Subir video ───────────────────────────────────────────────────
    } else if (action === "upload_video") {
      const file = formData.get("hero_video") as File;
      if (!file || file.size === 0) { error = "Selecciona un video"; }
      else {
        const buffer = await file.arrayBuffer();
        const url = await uploadImage(Buffer.from(buffer), { folder: 'starfilters-ecommerce/hero', public_id: `hero-vid-${Date.now()}`, resource_type: 'video' });
        await updateHeroVideo(url);
        await updateHeroType('video');
        heroVideo = url;
        heroType  = 'video';
        success = "Video del Hero actualizado y activado";
      }

    // ── URL de video ──────────────────────────────────────────────────
    } else if (action === "video_url") {
      const url = formData.get("hero_video_url") as string;
      if (!url) { error = "Ingresa una URL"; }
      else {
        await updateHeroVideo(url);
        await updateHeroType('video');
        heroVideo = url;
        heroType  = 'video';
        success = "URL de video activada en el Hero";
      }
    }
  } catch (err) {
    console.error("Error en hero settings:", err);
    error = err instanceof Error ? err.message : "Error desconocido";
  }
}

// ── Datos para la vista previa del fondo activo ──────────────────────
const heroVideoYouTubeId = getYouTubeId(heroVideo);
const isVideoYouTube = !!heroVideoYouTubeId;
---

<AdminLayout title="Configuración del Hero">
  <div class="container mx-auto max-w-4xl px-4 py-8">

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Configuración del Hero</h1>
      <p class="mt-2 text-gray-600">Elige si el fondo de la portada es un <strong>video</strong> o una <strong>imagen</strong>, y sube el archivo o pega la URL.</p>
    </div>

    {error && (
      <div class="mb-6 rounded-lg border border-red-300 bg-red-50 p-4 text-sm font-medium text-red-800">{error}</div>
    )}
    {success && (
      <div class="mb-6 rounded-lg border border-green-300 bg-green-50 p-4 text-sm font-medium text-green-800">{success}</div>
    )}

    <!-- ── Vista previa del fondo activo ──────────────────────────────── -->
    <div class="mb-8 rounded-2xl border-2 border-primary/30 bg-primary/5 overflow-hidden">
      <div class="flex items-center justify-between gap-3 px-5 py-3 border-b border-primary/20 bg-primary/10">
        <div class="flex items-center gap-2">
          <span class="relative flex h-2.5 w-2.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-green-400 opacity-75"></span>
            <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-green-500"></span>
          </span>
          <p class="font-semibold text-gray-900">
            Esto es lo que se ve ahora en la portada:
            <span class="text-primary">{heroType === 'video' ? (isVideoYouTube ? 'Video de YouTube' : 'Video') : 'Imagen'}</span>
          </p>
        </div>
      </div>

      <div class="p-5">
        <!-- Preview visual 16:9 -->
        <div class="relative mx-auto aspect-video w-full max-w-xl overflow-hidden rounded-xl border border-gray-200 bg-gray-900 shadow-sm">
          {heroType === 'image' ? (
            <img src={heroImage} alt="Fondo actual" class="h-full w-full object-cover" onerror="this.src='/images/placeholder.svg'" />
          ) : isVideoYouTube ? (
            <Fragment>
              <img src={getYouTubeThumbnail(heroVideoYouTubeId!)} alt="Miniatura del video de YouTube" class="h-full w-full object-cover" />
              <div class="absolute inset-0 flex items-center justify-center bg-black/30">
                <div class="flex h-14 w-14 items-center justify-center rounded-full bg-white/90 shadow-lg">
                  <svg class="h-6 w-6 translate-x-0.5 text-primary" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z" /></svg>
                </div>
              </div>
            </Fragment>
          ) : (
            <video src={heroVideo} class="h-full w-full object-cover" muted loop autoplay playsinline></video>
          )}
        </div>
        <p class="mt-3 text-center text-xs text-gray-500 break-all">{heroType === 'video' ? heroVideo : heroImage}</p>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <!-- ── Columna VIDEO ─────────────────────────────────────────────── -->
      <div class="space-y-4">
        <div class="flex items-center gap-2 mb-2">
          <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
          </svg>
          <h2 class="text-lg font-bold text-gray-900">Video de fondo</h2>
          {heroType === 'video' && <span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-700">Activo</span>}
        </div>

        <!-- Subir video -->
        <div class="rounded-lg border border-gray-200 bg-white p-5">
          <p class="text-sm font-semibold text-gray-700 mb-3">Subir archivo de video</p>
          <form method="POST" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="action" value="upload_video" />
            <input
              type="file"
              name="hero_video"
              accept="video/mp4,video/webm,video/mov"
              class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
            />
            <p class="text-xs text-gray-400">MP4, WebM o MOV. Recomendado: menos de 20 MB.</p>
            <button type="submit" class="w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
              Subir y activar video
            </button>
          </form>
        </div>

        <!-- URL de video -->
        <div class="rounded-lg border border-gray-200 bg-white p-5">
          <p class="text-sm font-semibold text-gray-700 mb-1">O pegar un enlace de YouTube</p>
          <p class="text-xs text-gray-400 mb-3">Pega el enlace de un video de YouTube (ej. https://youtu.be/ABC123) o la URL de un archivo .mp4.</p>
          <form method="POST" class="space-y-3">
            <input type="hidden" name="action" value="video_url" />
            <input
              type="url"
              name="hero_video_url"
              value={heroVideo}
              placeholder="https://youtu.be/tu-video"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500"
            />
            <button type="submit" class="w-full rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">
              Guardar enlace y activar video
            </button>
          </form>
        </div>
      </div>

      <!-- ── Columna IMAGEN ────────────────────────────────────────────── -->
      <div class="space-y-4">
        <div class="flex items-center gap-2 mb-2">
          <svg class="h-5 w-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <h2 class="text-lg font-bold text-gray-900">Imagen de fondo</h2>
          {heroType === 'image' && <span class="rounded-full bg-purple-100 px-2 py-0.5 text-xs font-semibold text-purple-700">Activa</span>}
        </div>

        <!-- Preview imagen actual -->
        {heroType === 'image' && (
          <div class="rounded-lg overflow-hidden border border-gray-200 aspect-video bg-gray-100">
            <img src={heroImage} alt="Hero actual" class="h-full w-full object-cover" onerror="this.src='/images/placeholder.svg'" />
          </div>
        )}

        <!-- Subir imagen -->
        <div class="rounded-lg border border-gray-200 bg-white p-5">
          <p class="text-sm font-semibold text-gray-700 mb-3">Subir archivo de imagen</p>
          <form method="POST" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="action" value="upload_image" />
            <input
              type="file"
              name="hero_image"
              accept="image/*"
              class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100"
            />
            <p class="text-xs text-gray-400">JPG, PNG o WebP. Recomendado: 1920×1080 px.</p>
            <button type="submit" class="w-full rounded-lg bg-purple-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-purple-700 transition-colors">
              Subir y activar imagen
            </button>
          </form>
        </div>

        <!-- URL de imagen -->
        <div class="rounded-lg border border-gray-200 bg-white p-5">
          <p class="text-sm font-semibold text-gray-700 mb-3">O pegar URL de imagen</p>
          <form method="POST" class="space-y-3">
            <input type="hidden" name="action" value="image_url" />
            <input
              type="url"
              name="hero_image_url"
              value={heroType === 'image' ? heroImage : ''}
              placeholder="https://ejemplo.com/imagen.jpg"
              class="w-full rounded-md border border-gray-300 px-3 py-2 text-sm focus:border-purple-500 focus:outline-none focus:ring-1 focus:ring-purple-500"
            />
            <button type="submit" class="w-full rounded-lg bg-gray-700 px-4 py-2.5 text-sm font-semibold text-white hover:bg-gray-800 transition-colors">
              Guardar URL y activar imagen
            </button>
          </form>
        </div>
      </div>
    </div>

    <!-- Cambiar solo el tipo sin subir nada -->
    <div class="mt-8 rounded-lg border border-gray-200 bg-white p-5">
      <p class="text-sm font-semibold text-gray-700 mb-3">Cambiar el tipo de fondo sin subir archivo</p>
      <p class="text-xs text-gray-500 mb-4">Útil si ya tienes imagen y video guardados y solo quieres alternar entre ellos.</p>
      <form method="POST" class="flex gap-4 flex-wrap">
        <input type="hidden" name="action" value="update_hero_type" />
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="hero_type" value="video" checked={heroType === 'video'} class="accent-blue-600" />
          <span class="text-sm font-medium text-gray-700">Video</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <input type="radio" name="hero_type" value="image" checked={heroType === 'image'} class="accent-purple-600" />
          <span class="text-sm font-medium text-gray-700">Imagen</span>
        </label>
        <button type="submit" class="rounded-lg bg-primary px-5 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors">
          Aplicar
        </button>
      </form>
    </div>

  </div>
</AdminLayout>
