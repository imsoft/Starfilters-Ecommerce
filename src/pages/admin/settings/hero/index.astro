---
import AdminLayout from "@/layouts/adminLayout.astro";
import { getAuthenticatedUser } from '@/lib/auth-utils';
import { isUserAdmin } from '@/lib/database';
import {
  getHeroType, updateHeroType,
  getHeroImage, updateHeroImage,
  getHeroVideo, updateHeroVideo,
} from '@/lib/site-settings-service';
import { uploadImage, uploadVideo, deleteImage, getPublicIdFromUrl } from '@/lib/cloudinary';
import { getYouTubeId } from '@/lib/video-utils';

export const prerender = false;

const user = getAuthenticatedUser(Astro.cookies);
if (!user) return Astro.redirect('/login');

const userIsAdmin = await isUserAdmin(user.id);
if (!userIsAdmin) return Astro.redirect('/');

let heroType  = await getHeroType();
let heroImage = await getHeroImage();
let heroVideo = await getHeroVideo();
let error: string | null = null;
let success: string | null = null;

// ¿La petición viene por AJAX (subida con barra de progreso)? -> responder JSON
const wantsJson = Astro.request.headers.get("x-requested-with") === "XMLHttpRequest";

if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action") as string;

    // ── Cambiar tipo (imagen / video) ─────────────────────────────────
    if (action === "update_hero_type") {
      const type = formData.get("hero_type") as 'video' | 'image';
      if (type === 'video' || type === 'image') {
        await updateHeroType(type);
        heroType = type;
        success = `Tipo de fondo cambiado a: ${type === 'video' ? 'Video' : 'Imagen'}`;
      }

    // ── Subir imagen ──────────────────────────────────────────────────
    } else if (action === "upload_image") {
      const file = formData.get("hero_image") as File;
      if (!file || file.size === 0) { error = "Selecciona una imagen"; }
      else {
        if (heroImage && !heroImage.includes('hero-default')) {
          const publicId = getPublicIdFromUrl(heroImage);
          if (publicId) await deleteImage(publicId);
        }
        const buffer = await file.arrayBuffer();
        const url = await uploadImage(Buffer.from(buffer), { folder: 'starfilters-ecommerce/hero', public_id: `hero-img-${Date.now()}`, resource_type: 'image' });
        await updateHeroImage(url);
        await updateHeroType('image');
        heroImage = url;
        heroType  = 'image';
        success = "Imagen del Hero actualizada y activada";
      }

    // ── Subir video ───────────────────────────────────────────────────
    } else if (action === "upload_video") {
      const file = formData.get("hero_video") as File;
      const MAX_VIDEO_BYTES = 100 * 1024 * 1024; // 100 MB
      if (!file || file.size === 0) {
        error = "Selecciona un video antes de subir.";
      } else if (file.size > MAX_VIDEO_BYTES) {
        const mb = (file.size / (1024 * 1024)).toFixed(0);
        error = `El video pesa ${mb} MB y el máximo es 100 MB. Comprímelo o usa uno más liviano.`;
      } else {
        const buffer = await file.arrayBuffer();
        const url = await uploadVideo(Buffer.from(buffer), { folder: 'starfilters-ecommerce/hero', public_id: `hero-vid-${Date.now()}` });
        await updateHeroVideo(url);
        await updateHeroType('video');
        heroVideo = url;
        heroType  = 'video';
        success = "Video del Hero actualizado y activado";
      }
    }
  } catch (err) {
    console.error("Error en hero settings:", err);
    error = err instanceof Error ? err.message : "Error desconocido";
  }

  // Respuesta JSON para subidas AJAX (no recargamos la página completa)
  if (wantsJson) {
    return new Response(
      JSON.stringify({
        ok: !error,
        message: error || success || "",
        heroType,
        heroVideo,
        heroImage,
      }),
      {
        status: error ? 400 : 200,
        headers: { "Content-Type": "application/json" },
      }
    );
  }
}

// ── Datos para la vista previa del fondo activo ──────────────────────
const heroVideoYouTubeId = getYouTubeId(heroVideo);
const isVideoYouTube = !!heroVideoYouTubeId;
---

<AdminLayout title="Configuración del Hero">
  <div class="container mx-auto max-w-4xl px-4 py-8">

    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Configuración del Hero</h1>
      <p class="mt-2 text-gray-600">Elige si el fondo de la portada es un <strong>video</strong> o una <strong>imagen</strong> y sube el archivo desde tu computadora.</p>
    </div>

    {error && (
      <div class="mb-6 rounded-lg border border-red-300 bg-red-50 p-4 text-sm font-medium text-red-800">{error}</div>
    )}
    {success && (
      <div class="mb-6 rounded-lg border border-green-300 bg-green-50 p-4 text-sm font-medium text-green-800">{success}</div>
    )}

    <!-- ── Vista previa del fondo activo ──────────────────────────────── -->
    <div class="mb-8 rounded-2xl border-2 border-primary/30 bg-primary/5 overflow-hidden">
      <div class="p-5">
        <!-- Preview visual 16:9 -->
        <div id="active-preview" class="relative mx-auto aspect-video w-full max-w-xl overflow-hidden rounded-xl border border-gray-200 bg-gray-900 shadow-sm">
          {heroType === 'image' ? (
            <img src={heroImage} alt="Fondo actual" class="h-full w-full object-cover" onerror="this.src='/images/placeholder.svg'" />
          ) : isVideoYouTube ? (
            <iframe
              src={`https://www.youtube.com/embed/${heroVideoYouTubeId}?autoplay=1&mute=1&loop=1&playlist=${heroVideoYouTubeId}&modestbranding=1&rel=0&playsinline=1`}
              title="Vista previa del video"
              class="h-full w-full"
              frameborder="0"
              allow="autoplay; encrypted-media"
              allowfullscreen
            ></iframe>
          ) : (
            <video class="h-full w-full object-cover" muted loop autoplay playsinline preload="auto" poster="/images/home-page/Cuarto Limpio Sala Blanca ISO 14644.jpeg">
              <source src={heroVideo} type="video/mp4" />
            </video>
          )}
        </div>
      </div>
    </div>

    <!-- Form oculto: los radios (en cada columna) lo envían automáticamente al cambiar -->
    <form id="hero-type-form" method="POST" class="hidden">
      <input type="hidden" name="action" value="update_hero_type" />
    </form>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <!-- ── Columna VIDEO ─────────────────────────────────────────────── -->
      <div class="space-y-4">
        <label class="flex items-center gap-2 mb-2 cursor-pointer">
          <input type="radio" name="hero_type" value="video" form="hero-type-form" checked={heroType === 'video'} onchange="this.form.submit()" class="h-4 w-4 accent-blue-600" />
          <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.723v6.554a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8z"/>
          </svg>
          <h2 class="text-lg font-bold text-gray-900">Video de fondo</h2>
          {heroType === 'video' && <span class="rounded-full bg-blue-100 px-2 py-0.5 text-xs font-semibold text-blue-700">Activo</span>}
        </label>

        <!-- Subir video -->
        <div class="rounded-lg border border-gray-200 bg-white p-5">
          <p class="text-sm font-semibold text-gray-700 mb-3">Subir archivo de video</p>
          <form id="video-upload-form" method="POST" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="action" value="upload_video" />
            <input
              id="video-input"
              type="file"
              name="hero_video"
              required
              accept="video/mp4,video/webm,video/quicktime"
              class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
            />
            <p class="text-xs text-gray-400">MP4, WebM o MOV. Máximo 100 MB (recomendado: menos de 20 MB para que cargue rápido).</p>

            <!-- Vista previa del archivo seleccionado -->
            <div id="video-preview-box" class="hidden rounded-lg border border-gray-200 bg-gray-50 p-3">
              <video id="video-preview" class="w-full rounded-md bg-black aspect-video object-contain" muted controls playsinline></video>
              <p id="video-file-info" class="mt-2 text-xs text-gray-500"></p>
            </div>

            <!-- Estado de subida (barra de progreso + mensaje) -->
            <div id="video-status" class="hidden space-y-2">
              <div class="h-2.5 w-full overflow-hidden rounded-full bg-gray-200">
                <div id="video-progress-bar" class="h-full w-0 rounded-full bg-blue-600 transition-all duration-200"></div>
              </div>
              <p id="video-status-text" class="text-xs font-medium text-blue-700"></p>
            </div>

            <button id="video-submit-btn" type="submit" class="flex w-full items-center justify-center gap-2 rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors disabled:opacity-60 disabled:cursor-not-allowed">
              <svg id="video-spinner" class="hidden h-4 w-4 animate-spin" viewBox="0 0 24 24" fill="none">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.4 0 0 5.4 0 12h4z"></path>
              </svg>
              <span id="video-submit-label">Subir y activar video</span>
            </button>
          </form>
        </div>
      </div>

      <!-- ── Columna IMAGEN ────────────────────────────────────────────── -->
      <div class="space-y-4">
        <label class="flex items-center gap-2 mb-2 cursor-pointer">
          <input type="radio" name="hero_type" value="image" form="hero-type-form" checked={heroType === 'image'} onchange="this.form.submit()" class="h-4 w-4 accent-purple-600" />
          <svg class="h-5 w-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <h2 class="text-lg font-bold text-gray-900">Imagen de fondo</h2>
          {heroType === 'image' && <span class="rounded-full bg-purple-100 px-2 py-0.5 text-xs font-semibold text-purple-700">Activa</span>}
        </label>

        <!-- Subir imagen -->
        <div class="rounded-lg border border-gray-200 bg-white p-5">
          <p class="text-sm font-semibold text-gray-700 mb-3">Subir archivo de imagen</p>
          <form method="POST" enctype="multipart/form-data" class="space-y-3">
            <input type="hidden" name="action" value="upload_image" />
            <input
              type="file"
              name="hero_image"
              required
              accept="image/*"
              class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-purple-50 file:text-purple-700 hover:file:bg-purple-100"
            />
            <p class="text-xs text-gray-400">JPG, PNG o WebP. Recomendado: 1920×1080 px.</p>
            <button type="submit" class="w-full rounded-lg bg-purple-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-purple-700 transition-colors">
              Subir y activar imagen
            </button>
          </form>
        </div>
      </div>
    </div>

  </div>

  <script is:inline>
    (function () {
      const MAX = 100 * 1024 * 1024; // 100 MB

      const form     = document.getElementById("video-upload-form");
      const input    = document.getElementById("video-input");
      const previewBox = document.getElementById("video-preview-box");
      const preview  = document.getElementById("video-preview");
      const fileInfo = document.getElementById("video-file-info");
      const status   = document.getElementById("video-status");
      const bar      = document.getElementById("video-progress-bar");
      const statusTxt= document.getElementById("video-status-text");
      const btn      = document.getElementById("video-submit-btn");
      const spinner  = document.getElementById("video-spinner");
      const label    = document.getElementById("video-submit-label");
      const activePreview = document.getElementById("active-preview");

      if (!form || !input) return;

      function fmtMB(bytes) {
        return (bytes / (1024 * 1024)).toFixed(1) + " MB";
      }

      // 1) Vista previa inmediata al seleccionar el archivo
      input.addEventListener("change", function () {
        status.classList.add("hidden");
        const file = input.files && input.files[0];
        if (!file) {
          previewBox.classList.add("hidden");
          return;
        }
        const url = URL.createObjectURL(file);
        preview.src = url;
        previewBox.classList.remove("hidden");
        const tooBig = file.size > MAX;
        fileInfo.textContent =
          file.name + " · " + fmtMB(file.size) +
          (tooBig ? "  ⚠️ Supera 100 MB, no se podrá subir." : "");
        fileInfo.className = "mt-2 text-xs " + (tooBig ? "text-red-600 font-semibold" : "text-gray-500");
      });

      // 2) Subida por AJAX con barra de progreso real
      form.addEventListener("submit", function (e) {
        const file = input.files && input.files[0];
        if (!file) return; // deja que el navegador muestre "selecciona un archivo"
        if (file.size > MAX) {
          e.preventDefault();
          alert("El video supera los 100 MB. Comprímelo o usa uno más liviano.");
          return;
        }

        e.preventDefault();

        btn.disabled = true;
        spinner.classList.remove("hidden");
        label.textContent = "Subiendo...";
        status.classList.remove("hidden");
        bar.style.width = "0%";
        bar.className = "h-full w-0 rounded-full bg-blue-600 transition-all duration-200";
        statusTxt.className = "text-xs font-medium text-blue-700";
        statusTxt.textContent = "Preparando subida...";

        const xhr = new XMLHttpRequest();
        xhr.open("POST", window.location.pathname, true);
        xhr.setRequestHeader("X-Requested-With", "XMLHttpRequest");

        // Progreso de la subida (navegador -> servidor)
        xhr.upload.addEventListener("progress", function (ev) {
          if (!ev.lengthComputable) return;
          const pct = Math.round((ev.loaded / ev.total) * 100);
          bar.style.width = pct + "%";
          statusTxt.textContent = "Subiendo video... " + pct + "%";
          if (pct >= 100) {
            statusTxt.textContent = "Procesando en el servidor... no cierres esta página.";
          }
        });

        xhr.onload = function () {
          let data = {};
          try { data = JSON.parse(xhr.responseText); } catch (_) {}

          if (xhr.status >= 200 && xhr.status < 300 && data.ok) {
            bar.style.width = "100%";
            bar.className = "h-full w-full rounded-full bg-green-600 transition-all duration-200";
            statusTxt.className = "text-xs font-medium text-green-700";
            statusTxt.textContent = "✓ " + (data.message || "Video subido y activado");
            // Actualizar la vista previa del fondo activo con el nuevo video
            if (data.heroVideo && activePreview) {
              activePreview.innerHTML =
                '<video class="h-full w-full object-cover" muted loop autoplay playsinline preload="auto" poster="/images/home-page/Cuarto Limpio Sala Blanca ISO 14644.jpeg"><source src="' + data.heroVideo + '" type="video/mp4"></video>';
            }
            spinner.classList.add("hidden");
            label.textContent = "Subir y activar video";
            btn.disabled = false;
          } else {
            onError(data.message || "No se pudo subir el video. Intenta de nuevo.");
          }
        };

        xhr.onerror = function () {
          onError("Error de conexión al subir el video.");
        };

        function onError(msg) {
          bar.className = "h-full w-full rounded-full bg-red-500 transition-all duration-200";
          bar.style.width = "100%";
          statusTxt.className = "text-xs font-medium text-red-700";
          statusTxt.textContent = "✗ " + msg;
          spinner.classList.add("hidden");
          label.textContent = "Reintentar subida";
          btn.disabled = false;
        }

        const fd = new FormData(form);
        xhr.send(fd);
      });
    })();
  </script>
</AdminLayout>
