<script is:inline>
  // Importar tamaños desde Excel en "Agregar producto": el producto aún no
  // existe, así que se importa directo a la categoría de filtro seleccionada.
  (function () {
    var fileInput = document.getElementById('import-sizes-file');
    var submitBtn = document.getElementById('import-sizes-btn');
    var btnText = document.getElementById('import-sizes-btn-text');
    var categorySelect = document.getElementById('filter_category_id');
    if (!fileInput || !submitBtn || !btnText || !categorySelect) return;

    var notify = function (message, type) {
      if (window.showToast) window.showToast(message, type);
      else alert(message);
    };

    submitBtn.addEventListener('click', function (e) {
      e.preventDefault();

      var categoryId = categorySelect.value;
      if (!categoryId) {
        notify('Selecciona primero el tipo de filtro (arriba, en Categorización): los tamaños se guardan en esa categoría.', 'error');
        categorySelect.focus();
        return;
      }
      if (!fileInput.files || fileInput.files.length === 0) {
        notify('Selecciona un archivo Excel (.xlsx o .xls)', 'error');
        return;
      }

      var fd = new FormData();
      fd.append('file', fileInput.files[0]);
      submitBtn.disabled = true;
      btnText.textContent = 'Importando...';
      var loadingToast = window.showLoadingToast
        ? window.showLoadingToast('Importando tamaños desde Excel…')
        : { success: function (m) { alert(m); }, error: function (m) { alert(m); } };

      fetch('/api/filter-categories/' + categoryId + '/import-sizes', {
        method: 'POST',
        body: fd
      })
        .then(function (r) { return r.json(); })
        .then(function (data) {
          if (data.success) {
            var msg = data.message || 'Tamaños importados.';
            if (data.errors && data.errors.length) {
              msg += ' Algunos errores: ' + data.errors.slice(0, 3).join('; ');
            }
            loadingToast.success(msg);
            fileInput.value = '';
          } else {
            loadingToast.error(data.message || 'Error al importar');
          }
        })
        .catch(function (err) {
          loadingToast.error('Error de conexión: ' + (err && err.message ? err.message : 'Error desconocido'));
        })
        .finally(function () {
          submitBtn.disabled = false;
          btnText.textContent = 'Subir tamaños desde Excel';
        });
    });
  })();
</script>
