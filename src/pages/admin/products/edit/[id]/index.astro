---
import AdminLayout from "@/layouts/adminLayout.astro";
import {
  getProductById,
  updateProduct as updateProductService,
} from "@/lib/product-service";
import { getActiveCategories, getCategoryVariants, addCategoryVariant, updateCategoryVariant, deleteCategoryVariant, type FilterCategoryVariant } from "@/lib/filter-category-service";
import { getProductImages } from "@/lib/database";
import { getAuthenticatedUser } from '@/lib/auth-utils';
import { isUserAdmin } from '@/lib/database';
import { getExchangeRate } from "@/lib/currency-service";
import ProductImageManagerEdit from "@/components/admin/ProductImageManagerEdit.astro";
import DynamicListInput from "@/components/admin/DynamicListInput.astro";
import ProductSizesTable from "@/components/admin/ProductSizesTable.astro";

export const prerender = false;

const user = getAuthenticatedUser(Astro.cookies);

if (!user) {
  return Astro.redirect('/login');
}

const userIsAdmin = await isUserAdmin(user.id);

if (!userIsAdmin) {
  return Astro.redirect('/');
}

const { id } = Astro.params;
const productId = parseInt(id || "0");

let product = await getProductById(productId);
if (!product) {
  return Astro.redirect("/admin/products");
}

let images = await getProductImages(productId);

// Obtener categorías de filtro para el selector
const filterCategories = await getActiveCategories();

let error: string | null = null;
let success: string | null = null;

// Procesar formulario
if (Astro.request.method === "POST") {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get("action") as string;

    if (action === "update_product") {
      // Procesar todos los campos
      const category = formData.get("category") as string || product.category;
      const productType = (formData.get("product_type") as string || product.product_type || "filter") as "filter" | "special";
      const filterCategoryIdStr = formData.get("filter_category_id") as string;
      const filterCategoryId = filterCategoryIdStr ? parseInt(filterCategoryIdStr) : null;

      // Procesar tabla de tamaños
      const sizesJson = formData.get("product_sizes") as string;
      console.log('📦 JSON recibido del formulario (raw):', sizesJson);
      let sizes: Array<{nominal_size: string; real_size: string; price: number; currency: 'MXN' | 'USD'; bind_code: string; product_code?: string}> = [];
      if (sizesJson) {
        try {
          const parsed = JSON.parse(sizesJson);
          console.log('📦 JSON parseado:', parsed);
          console.log('📦 Es array?', Array.isArray(parsed));
          console.log('📦 Longitud:', Array.isArray(parsed) ? parsed.length : 'N/A');
          
          // Asegurar que sea un array y filtrar filas vacías o inválidas
          if (Array.isArray(parsed)) {
            sizes = parsed.filter((size: any, index: number) => {
              const hasData = size && (size.nominal_size || size.real_size || size.bind_code || size.price);
              if (!hasData) {
                console.log(`⚠️ Filtrando fila ${index} sin datos:`, size);
              }
              return hasData;
            });
          }
          console.log(`📦 Tamaños procesados después del filtro: ${sizes.length}`);
          console.log('📦 Tamaños finales:', sizes);
        } catch (error) {
          console.error('❌ Error parseando tamaños:', error);
          console.error('❌ JSON que causó el error:', sizesJson);
        }
      } else {
        console.warn('⚠️ No se recibió product_sizes en el formulario');
      }

      // Usar el primer tamaño si existe, o mantener valores actuales
      const firstSize = sizes.length > 0 ? sizes[0] : null;
      const currency = firstSize?.currency || product.currency || 'MXN';

      // Actualizar el producto con todos los campos
      const updated = await updateProductService(productId, {
        product_type: productType,
        filter_category_id: filterCategoryId,
        bind_code: firstSize?.bind_code || product.bind_code || null,
        sku: product.sku || null, // Mantener SKU del producto si existe
        name: formData.get("name") as string,
        name_en: (formData.get("name_en") as string) || undefined,
        description: (formData.get("description") as string) || undefined,
        description_en: (formData.get("description_en") as string) || undefined,
        price: firstSize?.price ?? product.price ?? 0,
        currency: currency as 'MXN' | 'USD',
        price_usd: currency === 'USD' ? (firstSize?.price ?? product.price ?? 0) : null,
        nominal_size: firstSize?.nominal_size || product.nominal_size || null,
        real_size: firstSize?.real_size || product.real_size || null,
        category: category,
        stock: 0,
        status: (formData.get("status") as "active" | "inactive" | "draft") || "active",
        // Campos técnicos
        efficiency: processListField(formData.get("efficiency")),
        efficiency_en: processListField(formData.get("efficiency_en")),
        efficiency_class: null,
        characteristics: processListField(formData.get("characteristics")),
        characteristics_en: processListField(formData.get("characteristics_en")),
        frame_material: null,
        max_temperature: null,
        typical_installation: formData.get("typical_installation") as string || null,
        typical_installation_en: formData.get("typical_installation_en") as string || null,
        air_flow: (formData.get("air_flow") as string)?.trim() || null,
        initial_pressure_drop: (formData.get("initial_pressure_drop") as string)?.trim() || null,
        recommended_final_pressure_drop: (formData.get("recommended_final_pressure_drop") as string)?.trim() || null,
        applications: processListField(formData.get("applications")),
        applications_en: processListField(formData.get("applications_en")),
        benefits: processListField(formData.get("benefits")),
        benefits_en: processListField(formData.get("benefits_en")),
      });

      // Actualizar imagen principal si viene del componente
      const mainImageFromComponent = formData.get("main_image") as string;
      if (mainImageFromComponent) {
        // La imagen principal se maneja a través de product_images
        // El componente CategoryImageManager se encargará de esto
      }

      // Sincronizar variantes de categoría si hay filter_category_id y tamaños
      if (updated && filterCategoryId && sizes.length > 0) {
        try {
          // Obtener tasa de cambio para calcular price_usd
          const exchangeRate = await getExchangeRate();
          
          // Obtener variantes existentes de la categoría
          const existingVariants = await getCategoryVariants(filterCategoryId);
          
          // Crear un mapa de variantes existentes por bind_code
          const existingVariantsMap = new Map<string, FilterCategoryVariant>();
          existingVariants.forEach(v => {
            if (v.bind_code) {
              existingVariantsMap.set(v.bind_code, v);
            }
          });
          
          // Procesar cada tamaño del formulario
          const processedBindCodes = new Set<string>();
          let savedCount = 0;
          let skippedCount = 0;
          
          for (const size of sizes) {
            // Solo procesar si tiene bind_code (requerido para variantes)
            if (!size.bind_code || !size.bind_code.trim()) {
              console.log('⚠️ Filtrando tamaño sin bind_code:', size);
              skippedCount++;
              continue;
            }
            
            processedBindCodes.add(size.bind_code.trim());
            
            // Calcular price_usd si es necesario
            let priceUsd: number | null = null;
            if (size.currency === 'USD') {
              priceUsd = size.price;
            } else if (size.currency === 'MXN') {
              // Convertir MXN a USD usando tasa de cambio
              priceUsd = size.price / exchangeRate;
            }
            
            const variantData = {
              category_id: filterCategoryId,
              bind_code: size.bind_code.trim(),
              product_code: size.product_code?.trim() || null,
              air_flow: size.air_flow?.trim() || null,
              nominal_size: size.nominal_size?.trim() || '',
              real_size: size.real_size?.trim() || '',
              price: size.price || 0,
              currency: size.currency || 'MXN',
              price_usd: priceUsd,
              stock: 0, // Stock se maneja a nivel de producto
              is_active: true
            };
            
            try {
              // Si existe una variante con este bind_code, actualizarla
              const existingVariant = existingVariantsMap.get(size.bind_code.trim());
              if (existingVariant) {
                await updateCategoryVariant(existingVariant.id, variantData);
                console.log(`✅ Variante actualizada: ${size.bind_code}`);
              } else {
                // Si no existe, crearla
                const newId = await addCategoryVariant(variantData);
                if (newId) {
                  console.log(`✅ Variante creada: ${size.bind_code} (ID: ${newId})`);
                } else {
                  console.error(`❌ Error creando variante: ${size.bind_code}`);
                }
              }
              savedCount++;
            } catch (error) {
              console.error(`❌ Error procesando variante ${size.bind_code}:`, error);
            }
          }
          
          // Eliminar variantes que ya no están en el formulario (marcar como inactivas en lugar de eliminar)
          for (const existingVariant of existingVariants) {
            if (existingVariant.bind_code && !processedBindCodes.has(existingVariant.bind_code)) {
              // Marcar como inactiva en lugar de eliminar
              await updateCategoryVariant(existingVariant.id, {
                ...existingVariant,
                is_active: false
              });
            }
          }
          
          console.log(`✅ ${savedCount} variantes guardadas, ${skippedCount} omitidas (sin bind_code), de ${sizes.length} totales para categoría ${filterCategoryId}`);
        } catch (variantError) {
          console.error('Error sincronizando variantes de categoría:', variantError);
          // No fallar el guardado del producto si hay error en variantes
        }
      }

      if (updated) {
        return Astro.redirect("/admin/products");
      } else {
        error = "Error al actualizar el producto";
      }
    }
  } catch (err: any) {
    console.error("Error procesando formulario:", err);
    const detail = err?.sqlMessage || err?.message || "Error desconocido";
    error = `Error al actualizar el producto: ${detail}`;
  }
}

// Función helper para procesar campos de lista
function processListField(field: string | FormDataEntryValue | null): string | null {
  if (!field) return null;
  if (typeof field === 'string') {
    try {
      const parsed = JSON.parse(field);
      if (Array.isArray(parsed)) {
        return parsed.filter(item => item && item.trim()).join('\n');
      }
      return field;
    } catch {
      return field;
    }
  }
  return null;
}

// Función helper para convertir texto a array para DynamicListInput
function textToArray(text: string | null | undefined): string[] {
  if (!text) return [];

  // Intentar parsear como JSON primero (por si viene de la base de datos como JSON string)
  try {
    const parsed = JSON.parse(text);
    if (Array.isArray(parsed)) {
      // Manejar doble serialización: si el primer elemento es un string JSON, parsearlo también
      const result: string[] = [];
      for (const item of parsed) {
        if (typeof item === 'string') {
          // Verificar si el item es un JSON string (array)
          try {
            const innerParsed = JSON.parse(item);
            if (Array.isArray(innerParsed)) {
              result.push(...innerParsed.filter((i: any) => typeof i === 'string' && i.trim()));
            } else {
              result.push(item.trim());
            }
          } catch {
            // No es JSON, es un string normal
            if (item.trim()) {
              result.push(item.trim());
            }
          }
        }
      }
      return result.filter(item => item);
    }
  } catch {
    // No es JSON válido, continuar con split por líneas
  }

  return text.split('\n').filter(item => item && item.trim());
}

// Preparar tamaños para la tabla
// Cargar variantes de categoría si existe filter_category_id
let productSizes: Array<{nominal_size: string; real_size: string; price: number; currency: 'MXN' | 'USD'; bind_code: string; product_code?: string; air_flow?: string}> = [];

if (product.filter_category_id) {
  try {
    // Cargar variantes de la categoría
    const categoryVariants = await getCategoryVariants(product.filter_category_id);
    // Solo incluir variantes activas
    const activeVariants = categoryVariants.filter(v => v.is_active);
    
    if (activeVariants.length > 0) {
      // Usar las variantes de categoría
      productSizes = activeVariants.map(v => ({
        nominal_size: v.nominal_size || '',
        real_size: v.real_size || '',
        price: v.price || 0,
        currency: (v.currency as 'MXN' | 'USD') || 'MXN',
        bind_code: v.bind_code || '',
        product_code: v.product_code || '',
        air_flow: v.air_flow || ''
      }));
    } else {
      // Si no hay variantes de categoría, usar el producto actual como fallback
      if (product.nominal_size || product.real_size || product.bind_code || product.price) {
        productSizes.push({
          nominal_size: product.nominal_size || '',
          real_size: product.real_size || '',
          price: product.price || 0,
          currency: (product.currency as 'MXN' | 'USD') || 'MXN',
          bind_code: product.bind_code || ''
        });
      }
    }
  } catch (error) {
    console.error('Error cargando variantes de categoría:', error);
    // Fallback al producto actual
    if (product.nominal_size || product.real_size || product.bind_code || product.price) {
      productSizes.push({
        nominal_size: product.nominal_size || '',
        real_size: product.real_size || '',
        price: product.price || 0,
        currency: (product.currency as 'MXN' | 'USD') || 'MXN',
        bind_code: product.bind_code || ''
      });
    }
  }
} else {
  // Si no hay filter_category_id, usar solo el producto actual
  if (product.nominal_size || product.real_size || product.bind_code || product.price) {
    productSizes.push({
      nominal_size: product.nominal_size || '',
      real_size: product.real_size || '',
      price: product.price || 0,
      currency: (product.currency as 'MXN' | 'USD') || 'MXN',
      bind_code: product.bind_code || ''
    });
  }
}


// Log para debugging
console.log('📦 Producto:', { 
  id: product.id, 
  name: product.name,
  nominal_size: product.nominal_size,
  real_size: product.real_size,
  price: product.price,
  bind_code: product.bind_code
});
console.log('📦 Imágenes encontradas:', images.length);
console.log('📦 Tamaños preparados:', productSizes.length);
---

<AdminLayout title={`Editar: ${product.name}`}>
  <div class="container mx-auto px-4 py-8">
    <!-- Header -->
    <div class="mb-8">
      <div class="flex items-center gap-4">
        <a
          href="/admin/products"
          class="text-gray-600 hover:text-gray-900"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
        </a>
        <div>
          <h1 class="text-3xl font-bold text-gray-900">
            Editar: {product.name}
          </h1>
          <p class="mt-2 text-gray-600">ID: {product.id} | UUID: {product.uuid}</p>
        </div>
      </div>
    </div>

    <!-- Mensajes -->
    {
      error && (
        <div class="mb-6 rounded-lg border border-red-300 bg-red-50 p-4">
          <div class="flex">
            <svg
              class="h-5 w-5 text-red-400"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                clip-rule="evenodd"
              />
            </svg>
            <div class="ml-3">
              <p class="text-sm font-medium text-red-800">{error}</p>
            </div>
          </div>
        </div>
      )
    }

    {
      success && (
        <div class="mb-6 rounded-lg border border-green-300 bg-green-50 p-4">
          <div class="flex">
            <svg
              class="h-5 w-5 text-green-400"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"
              />
            </svg>
            <div class="ml-3">
              <p class="text-sm font-medium text-green-800">{success}</p>
            </div>
          </div>
        </div>
      )
    }

    <!-- Contenido completo sin tabs -->
    <div class="space-y-8">
      <form method="POST" id="product-form" class="space-y-8">
        <input type="hidden" name="action" value="update_product" />

        <!-- Tipo de Producto -->
        <div class="rounded-lg border-2 border-primary/30 bg-primary/5 p-6 shadow-sm">
          <p class="text-sm font-bold text-gray-900 mb-4">Tipo de producto</p>
          <div class="flex gap-4">
            <label class="flex items-center gap-3 cursor-pointer rounded-lg border border-border bg-white px-4 py-3 has-[:checked]:border-primary has-[:checked]:bg-primary/5 transition-colors flex-1">
              <input type="radio" name="product_type" value="filter" checked={!product.product_type || product.product_type === 'filter'} class="accent-primary" />
              <div>
                <p class="text-sm font-semibold text-gray-900">Filtro de Aire</p>
                <p class="text-xs text-gray-500">Aparece en /productos con filtros de eficiencia</p>
              </div>
            </label>
            <label class="flex items-center gap-3 cursor-pointer rounded-lg border border-border bg-white px-4 py-3 has-[:checked]:border-primary has-[:checked]:bg-primary/5 transition-colors flex-1">
              <input type="radio" name="product_type" value="special" checked={product.product_type === 'special'} class="accent-primary" />
              <div>
                <p class="text-sm font-semibold text-gray-900">Accesorio / Equipo</p>
                <p class="text-xs text-gray-500">Aparece en /accesorios (manómetros, etc.)</p>
              </div>
            </label>
          </div>
        </div>

        <!-- Información Básica -->
        <div class="rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
          <div class="mb-6 flex items-center gap-3 border-b border-gray-200 pb-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-blue-100">
              <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h2 class="text-xl font-bold text-gray-900">
                Información Básica
              </h2>
              <p class="mt-1 text-sm text-gray-500">
                Nombre y descripción del producto en español e inglés
              </p>
            </div>
          </div>

          <div class="grid gap-6 md:grid-cols-2">
            <div>
              <label for="name" class="mb-2 flex items-center gap-2 text-sm font-semibold text-gray-700">
                <span>Nombre (Español)</span>
                <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                value={product.name}
                required
                placeholder="Ej: Mini pleat sello gel downstream"
                class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
              />
              <p class="mt-1.5 text-xs text-gray-500">
                Nombre principal del producto en español
              </p>
            </div>

            <div>
              <label
                for="name_en"
                class="mb-2 block text-sm font-semibold text-gray-700"
              >
                Nombre (Inglés)
              </label>
              <input
                type="text"
                id="name_en"
                name="name_en"
                value={product.name_en || ""}
                placeholder="Ej: Mini pleat gel seal downstream"
                class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
              />
              <p class="mt-1.5 text-xs text-gray-500">
                Nombre del producto en inglés (opcional)
              </p>
            </div>
          </div>

          <div class="mt-6 grid gap-6 md:grid-cols-2">
            <div>
              <label
                for="description"
                class="mb-2 block text-sm font-semibold text-gray-700"
              >
                Descripción (Español)
              </label>
              <textarea
                id="description"
                name="description"
                rows="5"
                placeholder="Describe el producto, su función, características principales y uso típico..."
                class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
              >{product.description || ""}</textarea>
              <p class="mt-1.5 text-xs text-gray-500">
                Descripción detallada del producto en español
              </p>
            </div>

            <div>
              <label
                for="description_en"
                class="mb-2 block text-sm font-semibold text-gray-700"
              >
                Descripción (Inglés)
              </label>
              <textarea
                id="description_en"
                name="description_en"
                rows="5"
                placeholder="Describe the product, its function, main characteristics and typical use..."
                class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
              >{product.description_en || ""}</textarea>
              <p class="mt-1.5 text-xs text-gray-500">
                Descripción detallada del producto en inglés (opcional)
              </p>
            </div>
          </div>
        </div>

      <!-- Categoría de Filtro -->
      <div class="mt-12 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
        <div class="mb-6 flex items-center gap-3 border-b border-gray-200 pb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-100">
            <svg class="h-6 w-6 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
            </svg>
          </div>
          <div>
            <h2 class="text-xl font-bold text-gray-900">
              Categoría de Filtro
            </h2>
            <p class="mt-1 text-sm text-gray-500">
              Asigna este producto a una categoría de filtro
            </p>
          </div>
        </div>

        <div>
          <label for="filter_category_id" class="mb-2 block text-sm font-semibold text-gray-700">
            Categoría
          </label>
          <select
            id="filter_category_id"
            name="filter_category_id"
            class="mt-1 block w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm transition-colors focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500/20"
          >
            <option value="">Sin categoría</option>
            {filterCategories.map((cat) => (
              <option value={cat.id} selected={product.filter_category_id === cat.id}>{cat.name}</option>
            ))}
          </select>
          <p class="mt-1.5 text-xs text-gray-500">
            Selecciona la categoría de filtro a la que pertenece este producto
          </p>
        </div>
      </div>

      <!-- Especificaciones Técnicas -->
      <div class="mt-12 rounded-lg border border-gray-200 bg-white p-6 shadow-sm">
