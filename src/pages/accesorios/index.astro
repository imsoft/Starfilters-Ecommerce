---
import WebsiteLayout from "@/layouts/websiteLayout.astro";
import SEO from "@/components/shared/SEO.astro";
import LazyImage from "@/components/shared/LazyImage.astro";
import { getSpecialProducts } from "@/lib/product-service";
import { getProductPlaceholderImage } from "@/lib/image-utils";
import { getProductImages } from "@/lib/database";
import { generateBreadcrumbSchema } from "@/lib/seo-utils";
import { getExchangeRate } from "@/lib/currency-service";
import { getProductPriceAndCurrency, formatPriceByCurrency } from "@/lib/i18n-helpers";
import { getLangFromUrl } from "@/i18n/utils";
import { getProductName, getProductDescription, getProductCategory } from "@/lib/i18n-helpers";

export const prerender = false;

const lang = getLangFromUrl(Astro.url);
const exchangeRate = await getExchangeRate();

let products: Array<{
  id: number;
  uuid: string;
  name: string;
  description: string;
  category: string;
  price: number;
  currency: string;
  stock: number;
  imageUrl: string;
  nominal_size?: string;
}> = [];

try {
  const raw = await getSpecialProducts();

  products = await Promise.all(raw.map(async (product) => {
    const imgs = await getProductImages(product.id);
    const primary = imgs.find((i) => i.is_primary) ?? imgs[0];
    const imageUrl = primary?.image_url ?? product.image_url ?? getProductPlaceholderImage(product.category || 'productos');

    const { price: displayPrice, currency: displayCurrency } = getProductPriceAndCurrency(product, lang);
    let finalPrice = displayPrice;
    let finalCurrency = displayCurrency;
    if (lang === 'es' && displayCurrency === 'USD') {
      finalPrice = displayPrice * exchangeRate;
      finalCurrency = 'MXN';
    }

    return {
      id: product.id,
      uuid: product.uuid,
      name: getProductName(product, lang),
      description: getProductDescription(product, lang),
      category: getProductCategory(product, lang),
      price: finalPrice,
      currency: finalCurrency,
      priceUSD: product.price_usd || null,
      stock: product.stock || 0,
      imageUrl,
      nominal_size: product.nominal_size || undefined,
    };
  }));
} catch (error) {
  console.error('❌ Error en página /accesorios:', error);
}

const formatPrice = (price: number, currency: 'MXN' | 'USD' = 'MXN'): string =>
  formatPriceByCurrency(price, currency);

const categories = [...new Set(products.map(p => p.category).filter(Boolean))];

const siteUrl = Astro.site?.href || Astro.url.origin;
const breadcrumbSchema = generateBreadcrumbSchema([
  { name: 'Inicio', url: siteUrl },
  { name: 'Accesorios y Equipos', url: `${siteUrl}/accesorios` },
]);
---

<WebsiteLayout
  title="Accesorios y Equipos"
  seoTitle="Accesorios y Equipos - Star Filters"
  description="Manómetros, accesorios e instrumentación para sistemas de filtración industrial. Envío a toda la República Mexicana."
  keywords={['manómetros', 'accesorios filtración', 'instrumentación industrial', 'Star Filters']}
>
  <SEO
    slot="seo"
    title="Accesorios y Equipos"
    description="Manómetros, accesorios e instrumentación para sistemas de filtración industrial."
    ogType="website"
    keywords={['manómetros', 'accesorios filtración', 'instrumentación industrial']}
  />
  <script slot="seo" type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />

  <div class="bg-background py-24">
    <!-- Breadcrumb -->
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2 text-sm text-muted-foreground">
          <li><a href="/" class="hover:text-foreground transition-colors">Inicio</a></li>
          <li>
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
          </li>
          <li class="text-foreground font-medium">Accesorios y Equipos</li>
        </ol>
      </nav>
    </div>

    <section class="mx-auto max-w-xl px-4 sm:px-6 lg:max-w-7xl lg:px-8">
      <div class="mb-12">
        <h1 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
          Accesorios y Equipos
        </h1>
        <p class="mt-4 text-lg text-muted-foreground">
          Manómetros, instrumentación y accesorios para complementar tu sistema de filtración industrial.
        </p>
      </div>

      <div class="flex flex-col lg:flex-row gap-8">

        <!-- ── Panel de filtros ───────────────────────────────────────── -->
        <aside class="w-full lg:w-64 flex-shrink-0 space-y-6">

          <!-- Búsqueda -->
          <div>
            <label for="search-products" class="block text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2">Buscar</label>
            <div class="relative">
              <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                <svg class="h-4 w-4 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
              </div>
              <input
                type="text"
                id="search-products"
                placeholder="Nombre del producto..."
                class="w-full rounded-md border border-border bg-background pl-9 pr-3 py-2 text-sm text-foreground placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent"
              />
            </div>
          </div>

          <!-- Categoría -->
          {categories.length > 0 && (
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-3">Categoría</p>
              <div class="flex flex-col gap-2">
                <button class="filter-btn rounded-md px-3 py-1.5 text-sm font-medium border border-primary bg-primary text-primary-foreground text-left transition-colors" data-category="all">
                  Todas las categorías
                </button>
                {categories.map((cat) => (
                  <button
                    class="filter-btn rounded-md px-3 py-1.5 text-sm font-medium border border-border bg-background text-foreground text-left hover:bg-muted transition-colors"
                    data-category={cat}
                  >
                    {cat}
                  </button>
                ))}
              </div>
            </div>
          )}

          <!-- Disponibilidad -->
          <div>
            <label for="stock-filter" class="block text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2">Disponibilidad</label>
            <select id="stock-filter" class="w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary">
              <option value="all">Todos</option>
              <option value="in-stock">En stock</option>
              <option value="out-of-stock">Agotados</option>
            </select>
          </div>

          <!-- Ordenar por -->
          <div>
            <label for="sort-by" class="block text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-2">Ordenar por</label>
            <select id="sort-by" class="w-full rounded-md border border-border bg-background px-3 py-2 text-sm text-foreground focus:outline-none focus:ring-2 focus:ring-primary">
              <option value="default">Por defecto</option>
              <option value="price-asc">Precio: menor a mayor</option>
              <option value="price-desc">Precio: mayor a menor</option>
              <option value="name-asc">Nombre: A–Z</option>
              <option value="name-desc">Nombre: Z–A</option>
            </select>
          </div>

          <!-- Precio máximo -->
          <div>
            <div class="flex items-center justify-between mb-2">
              <label for="price-range" class="text-xs font-semibold uppercase tracking-widest text-muted-foreground">Precio máx.</label>
              <span id="price-range-value" class="text-sm font-medium text-foreground">$10,000</span>
            </div>
            <input type="range" id="price-range" min="0" max="10000" value="10000" step="500" class="w-full accent-primary" />
            <div class="flex justify-between text-xs text-muted-foreground mt-1">
              <span>$0</span><span>$10,000</span>
            </div>
          </div>

          <p class="text-xs text-muted-foreground">
            <span id="results-count">{products.length}</span> productos encontrados
          </p>
        </aside>

        <!-- ── Grid de productos ──────────────────────────────────────── -->
        <div class="flex-1">
          <div class="grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-3 xl:gap-x-8" id="products-grid">
            {products.map((product) => (
              <div
                class="group product-card relative flex flex-col"
                data-product-uuid={product.uuid}
                data-category={product.category}
                data-price={product.price}
                data-stock={product.stock}
                data-currency={product.currency || 'MXN'}
              >
                <a href={`/product/${product.uuid}`} class="block flex-shrink-0">
                  <div class="w-full h-72 overflow-hidden rounded-lg bg-muted">
                    <LazyImage
                      src={product.imageUrl}
                      alt={product.name}
                      class="h-full w-full object-contain object-center group-hover:opacity-75 transition-opacity"
                    />
                  </div>
                  <h3 class="mt-4 text-sm text-foreground font-medium hover:text-foreground transition-colors line-clamp-2 min-h-[2.5rem]">
                    {product.name}
                  </h3>
                </a>
                <p class="mt-1 text-sm text-muted-foreground">{product.category}</p>
                <div class="mt-2 flex items-center justify-between">
                  <p class="text-lg font-medium text-foreground">
                    {formatPrice(product.price, product.currency as 'MXN' | 'USD')}
                  </p>
                  {product.stock > 0 ? (
                    <span class="text-xs text-green-600 font-medium">En stock</span>
                  ) : (
                    <span class="text-xs text-red-600 font-medium">Agotado</span>
                  )}
                </div>
                {product.nominal_size && (
                  <p class="mt-1 text-xs text-muted-foreground">Tamaño: {product.nominal_size}</p>
                )}
                <div class="mt-auto pt-3">
                  {product.stock > 0 ? (
                    <button
                      type="button"
                      class="relative z-10 w-full rounded-md bg-primary px-3 py-2 text-sm font-semibold text-primary-foreground hover:bg-primary/90 transition-colors"
                      onclick={`event.stopPropagation(); addToCartQuick('${product.uuid}', ${product.id}, '${product.name}', ${product.price}, '${product.imageUrl}', '${product.category || ''}', '${product.currency || 'MXN'}')`}
                    >
                      Agregar al Carrito
                    </button>
                  ) : (
                    <button type="button" disabled class="relative z-10 w-full rounded-md bg-gray-300 px-3 py-2 text-sm font-semibold text-gray-500 cursor-not-allowed">
                      No Disponible
                    </button>
                  )}
                </div>
              </div>
            ))}
          </div>

          {products.length === 0 && (
            <div class="text-center py-24 border-2 border-dashed border-border rounded-xl">
              <svg class="mx-auto h-12 w-12 text-muted-foreground/40" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
              </svg>
              <h3 class="mt-4 text-lg font-medium text-foreground">Próximamente</h3>
              <p class="mt-2 text-sm text-muted-foreground max-w-sm mx-auto">
                Estamos agregando manómetros, accesorios e instrumentación. Contáctanos para consultar disponibilidad.
              </p>
              <a
                href="https://wa.me/523322569541?text=Hola%2C%20me%20interesa%20información%20sobre%20accesorios%20y%20equipos."
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex items-center gap-2 rounded-md bg-[#25D366] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#1ebe5d] transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Consultar por WhatsApp
              </a>
            </div>
          )}
        </div>
      </div>
    </section>
  </div>
</WebsiteLayout>

<script>
  const allProducts = document.querySelectorAll('.product-card');
  let currentCategory = 'all';
  let currentSortBy = 'default';
  let currentStockFilter = 'all';
  let currentMaxPrice = 10000;
  let currentSearchTerm = '';

  function applyFilters(): void {
    const productCards = Array.from(allProducts);
    let visibleCount = 0;

    productCards.forEach(card => {
      const element = card as HTMLElement;
      const productName = element.querySelector('h3')?.textContent?.toLowerCase() || '';
      const productCategory = element.getAttribute('data-category') || '';
      const price = parseFloat(element.getAttribute('data-price') || '0');
      const stockText = element.querySelector('.text-xs.text-green-600, .text-xs.text-red-600')?.textContent || '';
      const inStock = stockText.includes('En stock');

      const matchesSearch = currentSearchTerm === '' || productName.includes(currentSearchTerm.toLowerCase());
      const matchesCategory = currentCategory === 'all' || productCategory === currentCategory;
      const matchesPrice = price <= currentMaxPrice;
      const matchesStock = currentStockFilter === 'all' ||
        (currentStockFilter === 'in-stock' && inStock) ||
        (currentStockFilter === 'out-of-stock' && !inStock);

      if (matchesSearch && matchesCategory && matchesPrice && matchesStock) {
        element.style.display = '';
        visibleCount++;
      } else {
        element.style.display = 'none';
      }
    });

    const resultsCount = document.getElementById('results-count');
    if (resultsCount) resultsCount.textContent = visibleCount.toString();

    sortProducts();
  }

  function sortProducts(): void {
    const grid = document.getElementById('products-grid');
    if (!grid) return;

    const visibleCards = Array.from(grid.querySelectorAll('.product-card'))
      .filter(card => (card as HTMLElement).style.display !== 'none');

    visibleCards.sort((a, b) => {
      const aEl = a as HTMLElement;
      const bEl = b as HTMLElement;
      switch (currentSortBy) {
        case 'price-asc': return parseFloat(aEl.getAttribute('data-price') || '0') - parseFloat(bEl.getAttribute('data-price') || '0');
        case 'price-desc': return parseFloat(bEl.getAttribute('data-price') || '0') - parseFloat(aEl.getAttribute('data-price') || '0');
        case 'name-asc': return (aEl.querySelector('h3')?.textContent || '').localeCompare(bEl.querySelector('h3')?.textContent || '');
        case 'name-desc': return (bEl.querySelector('h3')?.textContent || '').localeCompare(aEl.querySelector('h3')?.textContent || '');
        default: return 0;
      }
    });

    visibleCards.forEach(card => grid.appendChild(card));
  }

  function filterByCategory(category: string): void {
    currentCategory = category;
    document.querySelectorAll('.filter-btn').forEach(btn => {
      const isActive = btn.getAttribute('data-category') === category;
      btn.classList.toggle('bg-primary', isActive);
      btn.classList.toggle('text-primary-foreground', isActive);
      btn.classList.toggle('border-primary', isActive);
      btn.classList.toggle('bg-background', !isActive);
      btn.classList.toggle('text-foreground', !isActive);
      btn.classList.toggle('border-border', !isActive);
    });
    applyFilters();
  }

  async function addToCartQuick(uuid: string, product_id: number, name: string, price: number, image_url: string, category: string, currency: string = 'MXN'): Promise<void> {
    const cartData = localStorage.getItem('starfilters_cart');
    let cart = cartData ? JSON.parse(cartData) : { items: [], total: 0, itemCount: 0, currency };

    const existingItemIndex = cart.items.findIndex((item: any) => item.uuid === uuid);
    if (existingItemIndex >= 0) {
      cart.items[existingItemIndex].quantity += 1;
    } else {
      cart.items.push({ uuid, product_id, name, price, currency, quantity: 1, image_url, category });
    }

    cart.total = cart.items.reduce((t: number, i: any) => t + i.price * i.quantity, 0);
    cart.itemCount = cart.items.reduce((c: number, i: any) => c + i.quantity, 0);
    localStorage.setItem('starfilters_cart', JSON.stringify(cart));

    const notification = document.createElement('div');
    notification.className = 'fixed top-20 right-4 bg-green-500 text-white px-6 py-3 rounded-lg shadow-lg z-50 transition-all duration-300';
    notification.innerHTML = `<div class="flex items-center gap-2"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg><span>${name} agregado al carrito</span></div>`;
    document.body.appendChild(notification);
    setTimeout(() => { notification.style.opacity = '0'; setTimeout(() => notification.remove(), 300); }, 3000);

    window.dispatchEvent(new CustomEvent('cartUpdated', { detail: cart }));
  }

  (window as any).addToCartQuick = addToCartQuick;

  document.addEventListener('DOMContentLoaded', () => {
    document.getElementById('search-products')?.addEventListener('input', (e) => {
      currentSearchTerm = (e.target as HTMLInputElement).value;
      applyFilters();
    });

    document.getElementById('sort-by')?.addEventListener('change', (e) => {
      currentSortBy = (e.target as HTMLSelectElement).value;
      applyFilters();
    });

    document.getElementById('stock-filter')?.addEventListener('change', (e) => {
      currentStockFilter = (e.target as HTMLSelectElement).value;
      applyFilters();
    });

    const priceRange = document.getElementById('price-range');
    const priceRangeValue = document.getElementById('price-range-value');
    if (priceRange && priceRangeValue) {
      priceRange.addEventListener('input', (e) => {
        const value = parseInt((e.target as HTMLInputElement).value);
        currentMaxPrice = value;
        priceRangeValue.textContent = new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', minimumFractionDigits: 0 }).format(value);
        applyFilters();
      });
    }

    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => filterByCategory(btn.getAttribute('data-category') || 'all'));
    });
  });
</script>
