---
import AuthLayout from "@/layouts/authLayout.astro";

// Obtener el email de la URL
const url = new URL(Astro.request.url);
const email = url.searchParams.get('email');
---

<AuthLayout title="Registro Exitoso">
  <div class="flex min-h-screen flex-col justify-center px-6 py-12 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-sm">
      <!-- Icono de éxito -->
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
        <svg class="h-8 w-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      
      <h2 class="mt-6 text-center text-2xl/9 font-bold tracking-tight text-foreground">
        ¡Registro Exitoso!
      </h2>
      
      <p class="mt-4 text-center text-sm text-muted-foreground">
        Tu cuenta ha sido creada correctamente
      </p>
    </div>

    <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm">
      <div class="rounded-md bg-background border border-border p-6">
        <div class="text-center">
          <h3 class="text-lg font-medium text-foreground mb-4">
            Próximos pasos
          </h3>
          
          <div class="space-y-4 text-sm text-muted-foreground">
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-primary/10">
                  <span class="text-xs font-medium text-primary">1</span>
                </div>
              </div>
              <div>
                <p class="font-medium text-foreground">Verifica tu email</p>
                <p>Hemos enviado un enlace de verificación a:</p>
                <p class="font-medium text-primary">{email}</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-primary/10">
                  <span class="text-xs font-medium text-primary">2</span>
                </div>
              </div>
              <div>
                <p class="font-medium text-foreground">Revisa tu bandeja de entrada</p>
                <p>Haz clic en el enlace para activar tu cuenta</p>
              </div>
            </div>
            
            <div class="flex items-start space-x-3">
              <div class="flex-shrink-0">
                <div class="flex h-6 w-6 items-center justify-center rounded-full bg-primary/10">
                  <span class="text-xs font-medium text-primary">3</span>
                </div>
              </div>
              <div>
                <p class="font-medium text-foreground">¡Comienza a comprar!</p>
                <p>Una vez verificado, podrás acceder a todos nuestros productos</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 space-y-4">
        <a
          href="/login"
          class="flex w-full justify-center rounded-md bg-primary px-3 py-2 text-sm font-semibold text-primary-foreground shadow-sm hover:bg-primary/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          Ir a Iniciar Sesión
        </a>
        
        <a
          href="/"
          class="flex w-full justify-center rounded-md bg-background border border-border px-3 py-2 text-sm font-semibold text-foreground shadow-sm hover:bg-muted focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          Volver al Inicio
        </a>
      </div>

      <div class="mt-6 text-center">
        <p class="text-xs text-muted-foreground">
          ¿No recibiste el email?
          <button
            type="button"
            id="resend-verification"
            data-email={email || ''}
            data-lang="es"
            class="font-medium text-primary hover:text-foreground underline underline-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Reenviar correo de verificación
          </button>
        </p>
        <p id="resend-status" class="mt-2 text-xs hidden"></p>
      </div>
    </div>
  </div>
</AuthLayout>

<script>
  // Con ClientRouter este módulo solo se evalúa una vez por sesión: hay que
  // re-inicializar en cada DOMContentLoaded.
  function initResendVerification() {
    const btn = document.getElementById('resend-verification') as HTMLButtonElement | null;
    if (!btn || btn.hasAttribute('data-init')) return;
    btn.setAttribute('data-init', 'true');

    const status = document.getElementById('resend-status') as HTMLElement | null;
    const isEn = btn.getAttribute('data-lang') === 'en';

    const show = (msg: string, ok: boolean) => {
      if (!status) return;
      status.textContent = msg;
      status.classList.remove('hidden', 'text-green-600', 'text-red-600');
      status.classList.add(ok ? 'text-green-600' : 'text-red-600');
    };

    btn.addEventListener('click', async () => {
      const email = btn.getAttribute('data-email') || '';
      if (!email) {
        show(isEn ? 'We could not detect your email. Please sign up again.' : 'No pudimos detectar tu correo. Regístrate de nuevo.', false);
        return;
      }

      btn.disabled = true;
      const originalLabel = btn.textContent;
      btn.textContent = isEn ? 'Sending…' : 'Enviando…';

      try {
        const res = await fetch('/api/users/resend-verification', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, lang: isEn ? 'en' : 'es' }),
        });
        const data = await res.json();

        if (data.success && data.alreadyVerified) {
          show(isEn ? 'Your account is already verified. You can sign in.' : 'Tu cuenta ya está verificada. Ya puedes iniciar sesión.', true);
        } else if (data.success) {
          show(isEn ? 'Email sent! Check your inbox (and spam folder).' : '¡Correo enviado! Revisa tu bandeja de entrada (y la carpeta de spam).', true);
        } else {
          show(data.message || (isEn ? 'The email could not be sent. Try again later.' : 'No se pudo enviar el correo. Intenta más tarde.'), false);
        }
      } catch {
        show(isEn ? 'The email could not be sent. Try again later.' : 'No se pudo enviar el correo. Intenta más tarde.', false);
      } finally {
        // Anti-spam: permitir reintentar después de 30 segundos
        setTimeout(() => {
          btn.disabled = false;
          btn.textContent = originalLabel;
        }, 30000);
      }
    });
  }

  initResendVerification();
  document.addEventListener('astro:page-load', initResendVerification);
</script>
