---
import FooterSection from "@/components/shared/FooterSection.astro";
import WhatsAppButton from "@/components/shared/WhatsAppButton.astro";
import "../styles/global.css";
import Navbar from "@/components/shared/Navbar.astro";
import { ClientRouter } from "astro:transitions";

export interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  ogImage?: string;
  keywords?: string[];
  noindex?: boolean;
}

const {
  title,
  seoTitle,
  description,
  ogImage,
  keywords,
  noindex: noindexProp = false
} = Astro.props;

// Si la variable PUBLIC_NOINDEX=true está en el entorno (staging), forzar noindex en todo el sitio
const noindex = noindexProp || import.meta.env.PUBLIC_NOINDEX === 'true';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#1d4ed8" />
    <title>{seoTitle || title}</title>
    {description && <meta name="description" content={description} />}
    {keywords && keywords.length > 0 && <meta name="keywords" content={keywords.join(', ')} />}
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <slot name="seo" />
    <ClientRouter />
  </head>
  <body>
    <Navbar />
    <main class="pt-16">
      <slot />
    </main>
    <FooterSection />
    <WhatsAppButton />
    <script
      src="https://api.leadwaycrm.com/js/external-tracking.js"
      data-tracking-id="tk_bb313237f99845bf8bd6ee7ad62f8806"
      is:inline
    ></script>
  </body>
</html>
