---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const cards = [
  {
    href: lang === 'en' ? '/en/cleanrooms' : '/cuartos-limpios',
    title: t('features.certifications.title'),
    description: t('features.certifications.description'),
    image: '/images/home-page/cuarto-limpio-sala-blanca.jpg',
    imageAlt: 'Cuarto Limpio Sala Blanca ISO 14644 Star Filters',
    objectPosition: 'object-center',
  },
  {
    href: lang === 'en' ? '/en/filters' : '/filtros',
    title: t('features.installation.title'),
    description: t('features.installation.description'),
    image: '/images/home-page/filtros-de-aire-star.jpg',
    imageAlt: 'Filtros de Aire Industriales Star Filters',
    objectPosition: 'object-center',
  },
  {
    href: lang === 'en' ? '/en/services' : '/servicios',
    title: t('features.technology.title'),
    description: t('features.technology.description'),
    image: '/images/home-page/validacion-cuartos-limpios.jpg',
    imageAlt: 'Validación de Cuartos Limpios - Servicios de Validación Star Filters',
    objectPosition: 'object-top',
  },
  {
    href: lang === 'en' ? '/en/products?category=cuartos-limpios' : '/productos?category=cuartos-limpios',
    title: t('features.support.title'),
    description: t('features.support.description'),
    image: '/images/home-page/filtros-de-estrella-cuarto-limpio.jpg',
    imageAlt: 'Accesorios para Cuartos Limpios Star Filters',
    objectPosition: 'object-center',
  },
];
---

<div class="bg-background py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <h2 class="text-center text-base/7 font-semibold text-primary">
      {t('features.title')}
    </h2>
    <p class="mx-auto mt-2 max-w-3xl text-center text-4xl font-semibold tracking-tight text-balance text-foreground sm:text-5xl">
      {t('features.subtitle')}
    </p>
    <div class="mt-4 text-center">
      <a
        href={lang === 'en' ? '/en/about' : '/acerca-de'}
        class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-primary/80 transition-colors"
      >
        {lang === 'en' ? 'Learn more about Star Filters' : 'Conocer más sobre Star Filters'}
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
    <div class="mt-8 grid gap-3 sm:mt-10 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
      {cards.map((card) => (
        <a
          href={card.href}
          class="relative group cursor-pointer transition-transform hover:scale-[1.02] h-full"
        >
          <div class="absolute inset-px rounded-lg bg-primary/10" />
          <div class="relative flex h-full flex-col overflow-hidden rounded-[calc(var(--radius-lg)+1px)]">
            <!-- Image -->
            <div class="px-6 pt-6 sm:px-8 sm:pt-8">
              <img
                src={card.image}
                alt={card.imageAlt}
                class={`w-full h-52 rounded-lg object-cover shadow-sm ${card.objectPosition}`}
              />
            </div>
            <!-- Text -->
            <div class="flex flex-1 flex-col px-6 pt-4 pb-4 sm:px-8">
              <p class="text-lg font-semibold tracking-tight text-foreground">
                {card.title}
              </p>
              <p class="mt-2 text-sm/6 text-muted-foreground flex-1">
                {card.description}
              </p>
              <!-- CTA -->
              <div class="mt-4 pt-4 border-t border-border">
                <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary group-hover:gap-2 transition-all duration-200">
                  {t('features.cta')}
                  <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </div>
          </div>
          <div class="pointer-events-none absolute inset-px rounded-lg shadow-sm outline outline-black/5" />
        </a>
      ))}
    </div>
  </div>
</div>
