---
export interface Props {
  badge?: string;
  title: string;
  description: string;
  primaryButtonText: string;
  primaryButtonHref: string;
  secondaryButtonText?: string;
  secondaryButtonHref?: string;
  image: string;
  imageAlt?: string;
}

const {
  badge,
  title,
  description,
  primaryButtonText,
  primaryButtonHref,
  secondaryButtonText,
  secondaryButtonHref,
  image,
  imageAlt = '',
} = Astro.props;
---

<div class="relative bg-white overflow-hidden">
  <!-- Image: stacked on mobile, absolute left half on md+ -->
  <div class="relative h-72 overflow-hidden bg-primary md:absolute md:left-0 md:h-full md:w-1/3 lg:w-1/2">
    <img
      src={image}
      alt={imageAlt}
      class="size-full object-cover"
      loading="lazy"
    />
    <!-- Decorative gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-r from-primary/40 to-transparent mix-blend-multiply"></div>
    <!-- Decorative blob -->
    <svg
      viewBox="0 0 926 676"
      aria-hidden="true"
      class="absolute -bottom-24 left-24 w-[57.875rem] transform-gpu blur-[100px] opacity-30"
    >
      <path
        fill="url(#split-cta-gradient)"
        fill-opacity=".5"
        d="m254.325 516.878-90.89 158.015 100.886-3.808 34.408-157.878-44.404 3.671Zm151.257-134.088-10.829 183.889 31.588 76.327 42.764-191.082-63.523-69.134Zm-182.529 67.99 28.445-100.361-10.329 183.135L264.788 516.29l-41.735 68.49Zm0 0-20.358 138.895 86.476-41.695-66.118-97.2Zm-10.329 183.135 51.99 52.845-31.588-76.327-20.402 23.482Zm318.04-190.605 63.523 69.134-31.588-76.327-31.935 7.193Z"
      />
      <defs>
        <linearGradient
          id="split-cta-gradient"
          x1="926"
          x2="-109.431"
          y1=".879"
          y2="624.502"
          gradientUnits="userSpaceOnUse"
        >
          <stop stop-color="var(--color-primary, #0369a1)" />
          <stop offset="1" stop-color="var(--color-primary, #0ea5e9)" stop-opacity="0.3" />
        </linearGradient>
      </defs>
    </svg>
  </div>

  <!-- Text content: offset to the right on md+ -->
  <div class="relative mx-auto max-w-7xl py-20 sm:py-28 lg:px-8 lg:py-36">
    <div class="pr-6 pl-6 md:ml-auto md:w-2/3 md:pl-16 lg:w-1/2 lg:pr-0 lg:pl-24 xl:pl-32">
      {badge && (
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">{badge}</p>
      )}
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
        {title}
      </h2>
      <p class="mt-5 text-base/7 text-gray-600">
        {description}
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <a
          href={primaryButtonHref}
          class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-sm transition hover:bg-primary/90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
        >
          {primaryButtonText}
        </a>
        {secondaryButtonText && secondaryButtonHref && (
          <a
            href={secondaryButtonHref}
            class="inline-flex items-center justify-center rounded-md border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-900 shadow-sm transition hover:bg-gray-50"
          >
            {secondaryButtonText}
          </a>
        )}
      </div>
    </div>
  </div>
</div>
