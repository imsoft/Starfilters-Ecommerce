---
import Navbar from "./Navbar.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const heroVideoSrc = "/videos/VIDEO-2026-05-19-13-33-53.mp4";
---

<div class="bg-background p-3 sm:p-4 min-h-screen">
  <!-- Contenedor redondeado que envuelve TODO: navbar + imagen + tarjeta -->
  <div class="relative min-h-[calc(100vh-1.5rem)] sm:min-h-[calc(100vh-2rem)] flex flex-col rounded-2xl overflow-hidden">

    <!-- Fondo: video local en todos los dispositivos -->
    <div class="absolute inset-0 z-0">
      <video
        id="hero-video"
        class="h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        poster="/images/home-page/Cuarto Limpio Sala Blanca ISO 14644.jpeg"
      >
        <source src={heroVideoSrc} type="video/mp4" />
      </video>
      <div class="absolute inset-0 bg-black/20"></div>
    </div>

    <!-- Navbar encima de la imagen -->
    <div class="relative z-20">
      <Navbar />
    </div>

    <!-- Tarjeta blanca flotante - bottom left -->
    <div class="relative z-10 flex flex-1 items-end pb-16 px-6 sm:px-12 lg:px-16">
      <div class="hero-card bg-white/40 backdrop-blur-md rounded-2xl p-8 sm:p-10 max-w-lg w-full shadow-xl">
        <h1 class="hero-title text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl leading-[1.08]">
          {t('hero.title')}
        </h1>
        <p class="hero-description mt-4 text-base text-gray-600 leading-relaxed sm:text-lg hidden md:block">
          {t('hero.description')}
        </p>
        <div class="hero-cta mt-8 flex flex-wrap gap-3">
          <a
            href={lang === 'en' ? '/en/filters' : '/filtros'}
            class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary/90 transition-colors shadow-sm"
          >
            {t('hero.cta')}
          </a>
          <a
            href={lang === 'en' ? '/en/contact' : '/contacto'}
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/80 px-6 py-3 text-sm font-semibold text-gray-900 hover:border-primary hover:text-primary transition-colors bg-white/30 backdrop-blur-sm"
          >
            {t('hero.ctaSecondary')}
          </a>
        </div>
      </div>
    </div>

  </div>
</div>

<script>
  function ensureVideoPlays() {
    const video = document.getElementById('hero-video') as HTMLVideoElement | null;
    if (video) {
      // Intentar reproducir el video
      video.play().catch(err => {
        console.warn("Autoplay del video hero bloqueado por políticas del navegador:", err);
        // Fallback: reproducir en el primer clic o toque táctil en cualquier parte de la pantalla
        const playOnInteraction = () => {
          video.play().catch(e => console.error("Error al reproducir tras interacción:", e));
          document.removeEventListener('click', playOnInteraction);
          document.removeEventListener('touchstart', playOnInteraction);
        };
        document.addEventListener('click', playOnInteraction);
        document.addEventListener('touchstart', playOnInteraction);
      });
    }
  }

  // Ejecutar en la carga inicial de la página
  ensureVideoPlays();

  // Ejecutar después de transiciones de página (ClientRouter de Astro)
  document.addEventListener('astro:page-load', ensureVideoPlays);
</script>
