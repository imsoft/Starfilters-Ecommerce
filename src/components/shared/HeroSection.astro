---
import Navbar from "./Navbar.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { getHeroType, getHeroImage, getHeroVideo } from "@/lib/site-settings-service";
import { getYouTubeId } from "@/lib/video-utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const heroType  = await getHeroType();
const heroImage = await getHeroImage();
const heroVideo = await getHeroVideo();

// Si el video es de YouTube, lo mostramos con un iframe de fondo; si no, como <video> (.mp4)
const youtubeId = heroType === 'video' ? getYouTubeId(heroVideo) : null;
---

<div class="bg-background p-3 sm:p-4 min-h-screen">
  <!-- Contenedor redondeado que envuelve TODO: navbar + imagen + tarjeta -->
  <div class="relative min-h-[calc(100vh-1.5rem)] sm:min-h-[calc(100vh-2rem)] flex flex-col rounded-2xl overflow-hidden">

    <!-- Fondo: video o imagen según configuración del admin -->
    <div class="absolute inset-0 z-0">
      {heroType === 'video' && youtubeId ? (
        <div class="absolute inset-0 overflow-hidden">
          <div
            id="hero-youtube"
            data-video-id={youtubeId}
            class="pointer-events-none absolute left-1/2 top-1/2 h-[56.25vw] min-h-full w-[177.78vh] min-w-full -translate-x-1/2 -translate-y-1/2"
          ></div>
        </div>
      ) : heroType === 'video' ? (
        <video
          class="h-full w-full object-cover"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          poster="/images/home-page/Cuarto Limpio Sala Blanca ISO 14644.jpeg"
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
      ) : (
        <img
          src={heroImage}
          alt="Hero background"
          class="h-full w-full object-cover"
        />
      )}
      <div class="absolute inset-0 bg-black/20"></div>
    </div>

    {heroType === 'video' && youtubeId && (
      <script is:inline>
        (function () {
          var el = document.getElementById('hero-youtube');
          if (!el) return;
          var videoId = el.getAttribute('data-video-id');
          if (!videoId) return;

          function createPlayer() {
            new YT.Player('hero-youtube', {
              videoId: videoId,
              width: '100%',
              height: '100%',
              playerVars: {
                autoplay: 1, mute: 1, controls: 0, modestbranding: 1,
                playsinline: 1, rel: 0, disablekb: 1, fs: 0,
                iv_load_policy: 3, showinfo: 0
              },
              events: {
                onReady: function (e) { e.target.mute(); e.target.playVideo(); },
                onStateChange: function (e) {
                  if (e.data === YT.PlayerState.ENDED) { e.target.seekTo(0); e.target.playVideo(); }
                }
              }
            });
          }

          if (window.YT && window.YT.Player) {
            createPlayer();
          } else {
            var prev = window.onYouTubeIframeAPIReady;
            window.onYouTubeIframeAPIReady = function () { if (prev) prev(); createPlayer(); };
            if (!document.getElementById('youtube-iframe-api')) {
              var tag = document.createElement('script');
              tag.id = 'youtube-iframe-api';
              tag.src = 'https://www.youtube.com/iframe_api';
              document.head.appendChild(tag);
            }
          }
        })();
      </script>
    )}

    <!-- Navbar encima de la imagen -->
    <div class="relative z-20">
      <Navbar />
    </div>

    <!-- Tarjeta blanca flotante - bottom left -->
    <div class="relative z-10 flex flex-1 items-end pb-16 px-6 sm:px-12 lg:px-16">
      <div class="hero-card bg-white/40 backdrop-blur-md rounded-2xl p-8 sm:p-10 max-w-lg w-full shadow-xl">
        <h1 class="hero-title text-4xl font-bold tracking-tight text-gray-900 sm:text-5xl leading-[1.08]">
          {t('hero.title')}
        </h1>
        <p class="hero-description mt-4 text-base text-gray-600 leading-relaxed sm:text-lg">
          {t('hero.description')}
        </p>
        <div class="hero-cta mt-8 flex flex-wrap gap-3">
          <a
            href={lang === 'en' ? '/en/filters' : '/filtros'}
            class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary/90 transition-colors shadow-sm"
          >
            {t('hero.cta')}
          </a>
          <a
            href={lang === 'en' ? '/en/contact' : '/contacto'}
            class="inline-flex items-center gap-2 rounded-full border-2 border-white/80 px-6 py-3 text-sm font-semibold text-gray-900 hover:border-primary hover:text-primary transition-colors bg-white/30 backdrop-blur-sm"
          >
            {t('hero.ctaSecondary')}
          </a>
        </div>
      </div>
    </div>

  </div>
</div>
