---
import PageHero from "@/components/shared/PageHero.astro";
import SectionVideo from "@/components/shared/SectionVideo.astro";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const productsRoute = lang === 'en' ? '/en/products' : '/productos';
const contactUrl = lang === 'en' ? '/en/contact' : '/contacto';

// Tipos de filtros industriales (estructura definida por el cliente):
// tres bloques con foto, lista y botón a su sección del webshop.
const filterTypes = [
  {
    title: lang === 'en' ? 'Low efficiency' : 'Baja eficiencia',
    image: '/images/filters-page/filtros-baja-eficiencia.jpg',
    href: `${productsRoute}?category=filtros-de-baja-eficiencia`,
    items: lang === 'en'
      ? ['Pleat filters (coarse particle prefiltration)', 'Metallic filters', 'Activated carbon filters (odor and gas control)']
      : ['Filtros pleat (prefiltración de partículas gruesas)', 'Filtros metálicos', 'Filtros de carbón activado (control de olores y gases)'],
  },
  {
    title: lang === 'en' ? 'Medium efficiency' : 'Media eficiencia',
    image: '/images/filters-page/filtros-media-eficiencia.jpg',
    href: `${productsRoute}?category=filtros-de-mediana-eficiencia`,
    items: lang === 'en'
      ? ['Bag filters (for high air volumes)', 'W filters (V-bank)']
      : ['Filtros de bolsa (para altos volúmenes de aire)', 'Filtros W (V-bank)'],
  },
  {
    title: 'HEPA',
    image: '/images/filters-page/filtros-hepa.jpg',
    href: `${productsRoute}?category=filtros-hepa-de-alta-eficiencia`,
    items: lang === 'en'
      ? ['Gel seal', 'Neoprene', 'High capacity', 'High temperature', 'Dust collector']
      : ['Sello gel', 'Neopreno', 'Alta capacidad', 'Alta temperatura', 'Colector de polvo'],
  },
];

const steps = lang === 'en'
  ? [
      { n: '01', title: 'Technical Advice',        desc: 'We analyze your application, airflow and required efficiency to recommend the right filter for your process.' },
      { n: '02', title: 'Quote',                   desc: 'You receive a clear quote with delivery times. We manufacture standard and special sizes.' },
      { n: '03', title: 'Manufacturing',           desc: 'We manufacture your filters with certified materials and quality control at every stage.' },
      { n: '04', title: 'Delivery & Installation', desc: 'We ship throughout Mexico and, if you need it, our certified technicians install them.' },
      { n: '05', title: 'Maintenance & Replacement', desc: 'We schedule periodic replacement to keep your air systems running at peak efficiency.' },
    ]
  : [
      { n: '01', title: 'Asesoría técnica',         desc: 'Analizamos tu aplicación, caudal y eficiencia requerida para recomendarte el filtro adecuado a tu proceso.' },
      { n: '02', title: 'Cotización',               desc: 'Recibes una cotización clara con tiempos de entrega. Fabricamos medidas estándar y especiales.' },
      { n: '03', title: 'Fabricación',              desc: 'Fabricamos tus filtros con materiales certificados y control de calidad en cada etapa.' },
      { n: '04', title: 'Entrega e instalación',    desc: 'Enviamos a toda la República Mexicana y, si lo necesitas, nuestros técnicos certificados los instalan.' },
      { n: '05', title: 'Mantenimiento y reemplazo', desc: 'Programamos el reemplazo periódico para mantener tus sistemas de aire en máxima eficiencia.' },
    ];
---

<!-- ── HERO ──────────────────────────────────────────────────────────── -->
<PageHero
  title={lang === 'en' ? 'Industrial Air Filters' : 'Filtros de Aire Industriales'}
  description={lang === 'en'
    ? 'We manufacture high-performance industrial air filters for demanding environments. Our solutions guarantee efficient filtration, long service life, and adaptation to every industrial process. Our air filters comply with EN779, ISO 16890, ASHRAE 52.2 (low and medium efficiency filters) and EN 1822 (HEPA and ULPA filters) standards.'
    : 'Fabricamos filtros de aire industriales de alto rendimiento para entornos exigentes. Nuestras soluciones garantizan una filtración eficiente, larga vida útil y adaptación a cada proceso industrial. Nuestros filtros de aire cumplen con las normativas EN779, ISO 16890, ASHRAE 52.2 (filtros de baja y mediana eficiencia) y EN 1822 (filtros HEPA y ULPA).'}
  image="/images/cleanrooms-page/Filtros%20Star%20Cuarto%20Limpio.JPG"
  primaryCta={{ label: lang === 'en' ? 'View products' : 'Ver productos', href: productsRoute }}
  secondaryCta={{ label: lang === 'en' ? 'Request a quote' : 'Solicitar cotización', href: contactUrl }}
/>

<!-- ── TIPOS DE FILTROS INDUSTRIALES ─────────────────────────────────── -->
<div class="bg-background py-16">
  <section
    aria-labelledby="filter-types-heading"
    class="mx-auto max-w-7xl px-6 lg:px-8"
  >
    <h2 id="filter-types-heading" class="mb-10 text-center text-3xl font-bold text-foreground sm:text-4xl reveal">
      {lang === 'en' ? 'Industrial Filter Types' : 'Tipos de Filtros Industriales'}
    </h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {filterTypes.map((type) => (
        <div class="group flex flex-col overflow-hidden rounded-2xl border border-border bg-white shadow-sm hover:shadow-xl hover:border-primary/40 transition-all duration-300">
          <div class="h-56 w-full overflow-hidden bg-muted">
            <img
              src={type.image}
              alt={type.title}
              class="h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="flex flex-col flex-1 p-5">
            <h3 class="text-lg font-semibold text-foreground group-hover:text-primary transition-colors">
              {type.title}
            </h3>
            <ul class="mt-3 space-y-2 flex-1">
              {type.items.map((item) => (
                <li class="flex items-start gap-2 text-sm/6 text-muted-foreground">
                  <svg class="mt-1 h-4 w-4 flex-shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <a
              href={type.href}
              class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-primary hover:text-primary/80 transition-colors"
            >
              {lang === 'en' ? 'View products' : 'Ver productos'}
              <svg class="h-4 w-4 translate-x-0 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </section>
</div>

<!-- ── FABRICACIÓN PROPIA + DISPONIBILIDAD Y LOGÍSTICA ───────────────── -->
<div class="bg-primary/10 py-20 border-t border-border">
  <div class="mx-auto max-w-6xl px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2">

      <!-- Fabricación propia -->
      <div class="reveal flex flex-col rounded-2xl bg-white border border-border shadow-sm p-8 sm:p-10">
        <div class="flex items-center gap-4">
          <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 21h16.5M4.5 21V8.25l5.25 3V8.25l5.25 3V4.5A1.5 1.5 0 0116.5 3h1.5a1.5 1.5 0 011.5 1.5V21M7.5 15h.008v.008H7.5V15zm3.75 0h.008v.008h-.008V15zm3.75 0h.008v.008H15V15z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-foreground">
            {lang === 'en' ? 'In-house manufacturing of industrial filters' : 'Fabricación propia de filtros industriales'}
          </h2>
        </div>
        <ul class="mt-8 space-y-4 flex-1">
          {(lang === 'en'
            ? ['In-house production with total quality control', 'Made-to-measure filters for each installation', 'Fast and flexible deliveries', 'Specialized technical advice']
            : ['Producción propia con control total de calidad', 'Filtros a medida según instalación', 'Entregas rápidas y flexibles', 'Asesoramiento técnico especializado']
          ).map((item) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-base text-muted-foreground">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Disponibilidad y logística -->
      <div class="reveal flex flex-col rounded-2xl bg-white border border-border shadow-sm p-8 sm:p-10" style="transition-delay:100ms">
        <div class="flex items-center gap-4">
          <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.177v-.958c0-.568-.422-1.048-.987-1.106a48.554 48.554 0 00-10.026 0 1.106 1.106 0 00-.987 1.106v7.635m12-6.677v6.677m0 4.5v-4.5m0 0h-12"/>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-foreground">
            {lang === 'en' ? 'Availability and logistics' : 'Disponibilidad y logística'}
          </h2>
        </div>
        <ul class="mt-8 space-y-4">
          {(lang === 'en'
            ? ['Large warehouse in Guadalajara', 'Strategic warehouse in Mexico City (CDMX)', 'Permanent stock of industrial filters', 'Fast nationwide deliveries']
            : ['Amplio almacén en Guadalajara', 'Almacén estratégico en Ciudad de México (CDMX)', 'Stock permanente de filtros industriales', 'Entregas rápidas a nivel nacional']
          ).map((item) => (
            <li class="flex items-start gap-3">
              <svg class="mt-0.5 h-5 w-5 flex-shrink-0 text-primary" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
              <span class="text-base text-muted-foreground">{item}</span>
            </li>
          ))}
        </ul>
        <p class="mt-6 border-t border-border pt-5 text-sm/6 text-muted-foreground">
          {lang === 'en'
            ? 'This allows us to offer fast response times and high availability for our industrial customers.'
            : 'Esto nos permite ofrecer tiempos de respuesta rápidos y alta disponibilidad para nuestros clientes industriales.'}
        </p>
      </div>

    </div>
  </div>
</div>

<!-- ── PROCESO ───────────────────────────────────────────────────────── -->
<div class="bg-background py-20 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">
        {lang === 'en' ? 'How we work' : 'Cómo trabajamos'}
      </p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
        {lang === 'en' ? 'Our process' : 'Nuestro proceso'}
      </h2>
      <p class="mt-4 text-muted-foreground max-w-xl mx-auto text-sm">
        {lang === 'en'
          ? 'From technical advice to preventive replacement — we take care of the entire life cycle of your filters.'
          : 'De la asesoría técnica al reemplazo preventivo — nos encargamos de todo el ciclo de vida de tus filtros.'}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-8">
      {steps.map((step, i, arr) => (
        <div class="reveal relative flex flex-col items-center text-center" style={`transition-delay: ${i * 80}ms`}>
          {i < arr.length - 1 && (
            <div class="hidden lg:block absolute top-7 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-border z-0"></div>
          )}
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground text-lg font-bold shadow-md mb-4">
            {step.n}
          </div>
          <h3 class="text-sm font-bold text-foreground mb-2 leading-snug">{step.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ── VIDEO ─────────────────────────────────────────────────────────── -->
<SectionVideo
  videoId="EziLQznVOZ0"
  videoTitle={lang === 'en' ? 'Air Filters - Star Filters' : 'Filtros de Aire - Star Filters'}
  heading={lang === 'en' ? 'Get to know our filters' : 'Conoce nuestros filtros'}
/>

<!-- ── SERVICIO DE MANTENIMIENTO ─────────────────────────────────────── -->
<div class="bg-background py-20 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">
        {lang === 'en' ? 'Maintenance Service' : 'Servicio de mantenimiento'}
      </p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
        {lang === 'en' ? 'We install and replace your filters' : 'Instalamos y reemplazamos tus filtros'}
      </h2>
      <p class="mt-4 text-muted-foreground max-w-2xl mx-auto">
        {lang === 'en'
          ? 'Our certified technicians carry out preventive and corrective maintenance of air filters in cleanrooms, UMA units, air showers, and HVAC systems across Mexico.'
          : 'Nuestros técnicos certificados realizan el mantenimiento preventivo y correctivo de filtros de aire en cuartos limpios, unidades UMA, air showers y sistemas de climatización en toda la República Mexicana.'}
      </p>
    </div>

    <!-- Galería de 3 fotos -->
    <div class="grid grid-cols-1 gap-5 sm:grid-cols-3 reveal">
      <div class="overflow-hidden rounded-2xl shadow-md aspect-[4/3]">
        <img
          src="/images/services/mantenimiento/mantenimiento-1.png"
          alt={lang === 'en' ? 'Filter installation in laminar flow cabinet' : 'Instalación de filtro en cabina de flujo laminar'}
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
      <div class="overflow-hidden rounded-2xl shadow-md aspect-[4/3]">
        <img
          src="/images/services/mantenimiento/mantenimiento-2.png"
          alt={lang === 'en' ? 'Filter replacement in rooftop UMA unit' : 'Reemplazo de filtros en unidad UMA en azotea'}
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
      <div class="overflow-hidden rounded-2xl shadow-md aspect-[4/3]">
        <img
          src="/images/services/mantenimiento/mantenimiento-3.png"
          alt={lang === 'en' ? 'Air handler filter maintenance' : 'Mantenimiento de filtros en manejadora de aire'}
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
      </div>
    </div>

    <!-- Puntos clave + CTA -->
    <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-3 lg:grid-cols-3 text-center">
      <div class="flex flex-col items-center gap-2">
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-primary/10 text-primary">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-foreground">{lang === 'en' ? 'Certified technicians' : 'Técnicos certificados'}</p>
        <p class="text-xs text-muted-foreground">{lang === 'en' ? 'ISO 14644 and GMP trained personnel' : 'Personal capacitado en ISO 14644 y BPM'}</p>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-primary/10 text-primary">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-foreground">{lang === 'en' ? 'Nationwide coverage' : 'Cobertura nacional'}</p>
        <p class="text-xs text-muted-foreground">{lang === 'en' ? 'Service throughout Mexico' : 'Servicio en toda la República Mexicana'}</p>
      </div>
      <div class="flex flex-col items-center gap-2">
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-primary/10 text-primary">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-foreground">{lang === 'en' ? 'Scheduled or emergency' : 'Programado o urgente'}</p>
        <p class="text-xs text-muted-foreground">{lang === 'en' ? 'We adapt to your operation schedule' : 'Nos adaptamos a tu horario de operación'}</p>
      </div>
    </div>

    <div class="mt-10 text-center">
      <a
        href={contactUrl}
        class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-3 text-sm font-semibold text-white hover:bg-primary/90 transition-colors shadow-sm"
      >
        {lang === 'en' ? 'Request maintenance service' : 'Solicitar servicio de mantenimiento'}
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

  </div>
</div>

<!-- ── ¿POR QUÉ STAR FILTERS? + CTA ──────────────────────────────────── -->
<div class="bg-primary/10 py-16 sm:py-20 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 items-stretch">

      <!-- ¿Por qué Star Filters? -->
      <div class="reveal flex flex-col rounded-2xl bg-white border border-border shadow-sm p-8 sm:p-10">
        <div class="flex items-center gap-4">
          <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-foreground">
            {t('filters.whyStarFilters.title')}
          </h2>
        </div>
        <div class="mt-8 grid grid-cols-2 gap-x-6 gap-y-6 flex-1">
          {([
            t('filters.whyStarFilters.benefit1'),
            t('filters.whyStarFilters.benefit2'),
            t('filters.whyStarFilters.benefit3'),
            t('filters.whyStarFilters.benefit4'),
            t('filters.whyStarFilters.benefit5'),
            t('filters.whyStarFilters.benefit6'),
            t('filters.whyStarFilters.benefit7'),
          ]).map((label, i) => (
            <div class="flex items-center gap-3">
              <img src={`/images/category-filters/iconos filtros-0${i + 1}.png`} alt="" class="h-12 w-12 flex-shrink-0 object-contain" width="48" height="48" loading="lazy" />
              <span class="text-sm font-medium text-foreground">{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA de cotización -->
      <div class="reveal flex flex-col items-center justify-center text-center rounded-2xl bg-white border border-border shadow-sm p-8 sm:p-10" style="transition-delay:100ms">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">Star Filters</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          {lang === 'en' ? 'Request Your Air Filter Quote' : 'Solicita tu Cotización de Filtros'}
        </h2>
        <p class="mt-5 text-base/7 text-gray-600">
          {lang === 'en'
            ? 'Tell us which filters you need and we will prepare a quote with clear delivery times. We manufacture standard and special sizes, with shipping throughout Mexico.'
            : 'Cuéntanos qué filtros necesitas y te preparamos una cotización con tiempos de entrega claros. Fabricamos medidas estándar y especiales, con envío a toda la República Mexicana.'}
        </p>
        <div class="mt-8 flex justify-center">
          <a
            href={`https://wa.me/523322569541?text=${encodeURIComponent(lang === 'en' ? 'Hello, I would like a quote for air filters for my company.' : 'Hola, me gustaría cotizar filtros de aire para mi empresa.')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 rounded-md bg-[#25D366] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#1ebe5d]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 flex-shrink-0">
