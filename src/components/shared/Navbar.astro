---
import { Button } from "../ui/button";
import UserDropdown from "../ui/UserDropdown.astro";
import CartIcon from "../ui/CartIcon.astro";
import LanguageSelector from "./LanguageSelector";
import { getAuthenticatedUser } from "@/lib/auth-utils";
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import { isUserAdmin, getUserById } from '@/lib/database';

// Obtener idioma actual
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Detectar si estamos en la página principal
const isHomePage = Astro.url.pathname === '/' || Astro.url.pathname === '/en';

// Obtener usuario autenticado
const user = getAuthenticatedUser(Astro.cookies);

// Obtener datos completos del usuario para la foto de perfil
let fullUser = null;
if (user) {
  fullUser = await getUserById(user.id);
}

// Verificar si es admin
let userIsAdmin = false;
if (user) {
  userIsAdmin = await isUserAdmin(user.id);
}


const empresaLinks = [
  { href: lang === 'en' ? '/en/blog' : '/blog',      label: lang === 'en' ? 'Blog'     : t('nav.blog') },
  { href: lang === 'en' ? '/en/about' : '/acerca-de', label: lang === 'en' ? 'About us' : 'Acerca de' },
];

const cleanroomsHref  = lang === 'en' ? '/en/cleanrooms' : '/cuartos-limpios';
const cleanroomsLabel = lang === 'en' ? 'Cleanrooms' : t('nav.cleanrooms');
const serviciosHref   = lang === 'en' ? '/en/services' : '/servicios';
const serviciosLabel  = lang === 'en' ? 'Validation Services' : t('nav.services');

const contactoHref  = lang === 'en' ? '/en/contact' : '/contacto';
const contactoLabel = lang === 'en' ? 'Contact' : t('nav.contact');

---

<header class={`${isHomePage ? 'navbar' : ''} absolute inset-x-0 top-0 z-50 bg-white/30 backdrop-blur-sm`}>
  <div class="mx-auto max-w-7xl">
    <div class="px-6 py-6 lg:px-8">
      <nav
        aria-label="Global"
        class="flex items-center justify-between lg:gap-x-12"
      >
        <!-- Logo - fijo a la izquierda -->
        <div class="flex lg:flex-1">
          <a href={lang === 'en' ? '/en' : '/'} class="-m-1.5 p-1.5 flex-shrink-0">
            <span class="sr-only">Starfilters</span>
            <img
              src="/images/home-page/Logo%20de%20Star%20Filters.png"
              alt="Star Filters"
              class="h-14 w-auto object-contain"
              loading="eager"
              fetchpriority="high"
              style="image-rendering: -webkit-optimize-contrast; height: 56px; width: auto;"
            />
          </a>
        </div>

        <!-- Mobile menu button -->
        <Button
          type="button"
          data-action="show-modal"
          data-target="mobile-menu"
          className="-m-2.5 rounded-md p-2.5 text-white lg:hidden"
        >
          <span class="sr-only">Open main menu</span>
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            data-slot="icon"
            aria-hidden="true"
            class="size-6"
          >
            <path
              d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </Button>

        <!-- Menú de navegación - centrado -->
        <div class="hidden lg:flex lg:items-center lg:gap-x-8">

          <!-- Filtros de Aire dropdown -->
          <div class="relative group">
            <button class="flex items-center gap-1 text-sm/6 font-semibold text-foreground hover:text-primary transition-colors whitespace-nowrap">
              {lang === 'en' ? 'Air Filters' : 'Filtros de Aire'}
              <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block z-50">
              <div class="w-52 rounded-xl border border-border bg-white shadow-lg overflow-hidden">
                <a href={lang === 'en' ? '/en/filters' : '/filtros'} class="block px-4 py-2.5 text-sm text-foreground hover:bg-muted hover:text-primary transition-colors">
                  {lang === 'en' ? 'General information' : 'Información general'}
                </a>
                <a href={lang === 'en' ? '/en/products' : '/productos'} class="block px-4 py-2.5 text-sm text-foreground hover:bg-muted hover:text-primary transition-colors">
                  {lang === 'en' ? 'Online store' : 'Tienda en línea'}
                </a>
              </div>
            </div>
          </div>

          <!-- Cuartos Limpios dropdown -->
          <div class="relative group">
            <button class="flex items-center gap-1 text-sm/6 font-semibold text-foreground hover:text-primary transition-colors whitespace-nowrap">
              {cleanroomsLabel}
              <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block z-50">
              <div class="w-52 rounded-xl border border-border bg-white shadow-lg overflow-hidden">
                <a href={cleanroomsHref} class="block px-4 py-2.5 text-sm text-foreground hover:bg-muted hover:text-primary transition-colors">
                  {lang === 'en' ? 'General information' : 'Información general'}
                </a>
                <a href={lang === 'en' ? '/en/products?category=cleanrooms' : '/productos?category=cuartos-limpios'} class="block px-4 py-2.5 text-sm text-foreground hover:bg-muted hover:text-primary transition-colors">
                  {lang === 'en' ? 'Products' : 'Productos'}
                </a>
              </div>
            </div>
          </div>

          <!-- Servicios directo -->
          <a href={serviciosHref} class="text-sm/6 font-semibold text-foreground hover:text-primary transition-colors whitespace-nowrap">
            {serviciosLabel}
          </a>

          <!-- Casos de Éxito directo -->
          <a href={lang === 'en' ? '/en/success-cases' : '/casos-de-exito'} class="text-sm/6 font-semibold text-foreground hover:text-primary transition-colors whitespace-nowrap">
            {lang === 'en' ? 'Success Cases' : 'Casos de Éxito'}
          </a>

          <!-- Dropdown: Empresa -->
          <div class="relative group">
            <button class="flex items-center gap-1 text-sm/6 font-semibold text-foreground hover:text-primary transition-colors">
              {lang === 'en' ? 'Company' : 'Empresa'}
              <svg class="h-4 w-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute left-0 top-full pt-2 hidden group-hover:block z-50">
              <div class="w-52 rounded-xl border border-border bg-white shadow-lg overflow-hidden">
                {empresaLinks.map((link) => (
                  <a href={link.href} class="block px-4 py-2.5 text-sm text-foreground hover:bg-muted hover:text-primary transition-colors">
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>

          <!-- Contacto directo -->
          <a href={contactoHref} class="text-sm/6 font-semibold text-foreground hover:text-primary transition-colors">
            {contactoLabel}
          </a>

        </div>

        <!-- Controles del lado derecho - idioma, carrito, usuario -->
        <div class="hidden lg:flex lg:flex-1 lg:items-center lg:gap-x-1 lg:justify-end">
          <LanguageSelector client:load />

          <!-- Ícono carrito (siempre visible) -->
          <CartIcon />

          <!-- Ícono login / usuario -->
          {!user ? (
            <!-- Dropdown: Iniciar sesión / Crear cuenta -->
            <div class="relative group">
              <button
                aria-label={lang === 'en' ? 'Account' : 'Cuenta'}
                class="group/btn flex items-center justify-center w-11 h-11 rounded-full hover:bg-black/10 transition-colors"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-foreground group-hover/btn:text-primary transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.7">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                </svg>
              </button>
              <div class="absolute right-0 top-full pt-2 hidden group-hover:block z-50">
                <div class="w-52 rounded-xl border border-border bg-white shadow-lg overflow-hidden">
                  <a href={lang === 'en' ? '/en/login' : '/login'} class="flex items-center gap-2 px-4 py-3 text-sm text-foreground hover:bg-muted hover:text-primary transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
                    </svg>
                    {lang === 'en' ? 'Log in' : 'Iniciar sesión'}
                  </a>
                  <a href={lang === 'en' ? '/en/signup' : '/signup'} class="flex items-center gap-2 px-4 py-3 text-sm font-semibold text-primary hover:bg-muted transition-colors border-t border-border">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.7">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0ZM3 19.235v-.11a6.375 6.375 0 0 1 12.75 0v.109A12.318 12.318 0 0 1 9.374 21c-2.331 0-4.512-.645-6.374-1.766Z" />
                    </svg>
                    {lang === 'en' ? 'Create account' : 'Crear cuenta'}
                  </a>
                </div>
              </div>
            </div>
          ) : (
            <UserDropdown user={user} />
          )}
        </div>
      </nav>
    </div>
  </div>
  <el-dialog>
    <dialog id="mobile-menu" class="backdrop:bg-transparent lg:hidden">
      <div tabindex="0" class="fixed inset-0 focus:outline-none">
        <el-dialog-panel
          class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-background p-6 sm:max-w-sm sm:ring-1 sm:ring-border"
        >
          <div class="flex items-center justify-between">
            <a href={lang === 'en' ? '/en' : '/'} class="-m-1.5 p-1.5">
              <span class="sr-only">Starfilters</span>
              <img
                src="/images/home-page/Logo%20de%20Star%20Filters.png"
                alt="Star Filters"
                class="h-14 w-auto object-contain"
                loading="eager"
                fetchpriority="high"
                style="image-rendering: -webkit-optimize-contrast; height: 56px;"
              />
            </a>
            <Button
              type="button"
              data-action="close"
              data-target="mobile-menu"
              className="-m-2.5 rounded-md p-2.5 text-white hover:opacity-80 transition-opacity"
            >
              <span class="sr-only">Close menu</span>
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                data-slot="icon"
                aria-hidden="true"
                class="size-6"
              >
                <path
                  d="M6 18 18 6M6 6l12 12"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </Button>
          </div>
          <div class="mt-6 flow-root">
            <div class="-my-6 divide-y divide-border">
              <div class="space-y-1 py-6">

                <!-- Filtros de Aire acordeón móvil -->
                <details class="group/fa">
                  <summary class="-mx-3 flex cursor-pointer items-center justify-between rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted list-none">
                    {lang === 'en' ? 'Air Filters' : 'Filtros de Aire'}
                    <svg class="h-4 w-4 transition-transform group-open/fa:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="mt-1 ml-3 space-y-1">
                    <a href={lang === 'en' ? '/en/filters' : '/filtros'} class="-mx-3 block rounded-lg px-6 py-1.5 text-sm text-muted-foreground hover:bg-muted hover:text-foreground transition-colors">
                      {lang === 'en' ? 'General information' : 'Información general'}
                    </a>
                    <a href={lang === 'en' ? '/en/products' : '/productos'} class="-mx-3 block rounded-lg px-6 py-1.5 text-sm text-muted-foreground hover:bg-muted hover:text-foreground transition-colors">
                      {lang === 'en' ? 'Online store' : 'Tienda en línea'}
                    </a>
                  </div>
                </details>

                <!-- Cuartos Limpios acordeón móvil -->
                <details class="group/cl">
                  <summary class="-mx-3 flex cursor-pointer items-center justify-between rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted list-none">
                    {cleanroomsLabel}
                    <svg class="h-4 w-4 transition-transform group-open/cl:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="mt-1 ml-3 space-y-1">
                    <a href={cleanroomsHref} class="-mx-3 block rounded-lg px-6 py-1.5 text-sm text-muted-foreground hover:bg-muted hover:text-foreground transition-colors">
                      {lang === 'en' ? 'General information' : 'Información general'}
                    </a>
                    <a href={lang === 'en' ? '/en/products?category=cleanrooms' : '/productos?category=cuartos-limpios'} class="-mx-3 block rounded-lg px-6 py-1.5 text-sm text-muted-foreground hover:bg-muted hover:text-foreground transition-colors">
                      {lang === 'en' ? 'Products' : 'Productos'}
                    </a>
                  </div>
                </details>

                <!-- Servicios directo -->
                <a href={serviciosHref} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted">
                  {serviciosLabel}
                </a>

                <!-- Acordeón: Empresa -->
                <details class="group/emp">
                  <summary class="-mx-3 flex cursor-pointer items-center justify-between rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted list-none">
                    {lang === 'en' ? 'Company' : 'Empresa'}
                    <svg class="h-4 w-4 transition-transform group-open/emp:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="mt-1 ml-3 space-y-1">
                    {empresaLinks.map((link) => (
                      <a href={link.href} class="-mx-3 block rounded-lg px-6 py-1.5 text-sm text-muted-foreground hover:bg-muted hover:text-foreground transition-colors">
                        {link.label}
                      </a>
                    ))}
                  </div>
                </details>

                <!-- Casos de Éxito directo -->
                <a href={lang === 'en' ? '/en/success-cases' : '/casos-de-exito'} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted">
                  {lang === 'en' ? 'Success Cases' : 'Casos de Éxito'}
                </a>

                <!-- Contacto directo -->
                <a href={contactoHref} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted">
                  {contactoLabel}
                </a>

                {!user && (
                  <>
                    <a href={lang === 'en' ? '/en/login' : '/login'} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted">
                      {t('nav.login')}
                    </a>
                    <a href={lang === 'en' ? '/en/signup' : '/signup'} class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-primary hover:bg-muted">
                      {lang === 'en' ? 'Create account' : 'Crear cuenta'}
                    </a>
                  </>
                )}
              </div>

              <!-- Selector de idioma móvil -->
              <div class="py-4 flex items-center gap-2">
                <span class="text-sm text-muted-foreground">{lang === 'en' ? 'Language:' : 'Idioma:'}</span>
                <LanguageSelector client:load />
              </div>

              <div class="py-6">
                {user ? (
                  <div class="space-y-2">
                    <div class="-mx-3 block rounded-lg px-3 py-2.5">
                      <div class="flex items-center gap-x-3">
                        <div class="avatar-circle bg-primary text-primary-foreground text-sm font-medium overflow-hidden">
                          {fullUser?.profile_image ? (
                            <img 
                              src={fullUser.profile_image} 
                              alt={`${user.firstName} ${user.lastName}`}
                              class="w-full h-full object-cover"
                              onerror="this.style.display='none'; this.parentElement.querySelector('.avatar-initials').style.display='flex';"
                            />
                          ) : null}
                          <div class={`avatar-initials w-full h-full flex items-center justify-center ${fullUser?.profile_image ? 'hidden' : ''}`}>
                            {user.firstName.charAt(0)}{user.lastName.charAt(0)}
                          </div>
                        </div>
                        <div>
                          <p class="text-base font-semibold text-foreground">{user.firstName} {user.lastName}</p>
                          <p class="text-sm text-muted-foreground">{user.email}</p>
                        </div>
                      </div>
                    </div>
                    <div class="-mx-3 block rounded-lg px-3 py-2">
                      <a href={lang === 'en' ? '/en/cart' : '/carrito'} class="flex items-center gap-x-3">
                        <CartIcon />
                        <span class="text-base/7 font-semibold text-foreground">{t('nav.cart')}</span>
                      </a>
                    </div>
                    <a
                      href={lang === 'en' ? '/en/profile' : '/profile'}
                      class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted"
                      >{t('nav.profile')}</a
                    >
                    <a
                      href={lang === 'en' ? '/en/change-password' : '/change-password'}
                      class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted"
                      >{t('nav.changePassword')}</a
                    >
                    <a
                      href={lang === 'en' ? '/en/orders' : '/orders'}
                      class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted"
                      >{t('nav.myOrders')}</a
                    >
                    <a
                      href={lang === 'en' ? '/en/cart' : '/carrito'}
                      class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted"
                      >{t('nav.cart')}</a
                    >
                    {userIsAdmin && (
                      <a
                        href="/admin/dashboard"
                        class="-mx-3 flex items-center gap-2 rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted"
                      >
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                        Dashboard Admin
                      </a>
                    )}
                    <a
                      href="/logout"
                      class="-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold text-foreground hover:bg-muted"
                      >{t('nav.logout')}</a
                    >
                  </div>
                ) : null}
              </div>
            </div>
          </div>
        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</header>

<script>
  // Con ClientRouter este módulo solo se evalúa una vez por sesión. Se usa
  // delegación en document para que el menú móvil funcione en todas las
  // páginas y tras cada navegación (antes se enganchaba en DOMContentLoaded
  // y el botón hamburguesa dejaba de abrir el menú al navegar).
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    if (!target) return;

    const modal = document.getElementById("mobile-menu") as HTMLDialogElement | null;
    if (!modal) return;

    if (target.closest('[data-action="show-modal"]')) {
      modal.showModal();
    } else if (target.closest('[data-action="close"]')) {
      modal.close();
    }
  });

  // Cerrar el menú móvil al navegar (si quedó abierto al tocar un enlace)
  document.addEventListener("astro:before-swap", () => {
    (document.getElementById("mobile-menu") as HTMLDialogElement | null)?.close();
  });
</script>
