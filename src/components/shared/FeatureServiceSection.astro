---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import PageHero from "@/components/shared/PageHero.astro";
import SectionVideo from "@/components/shared/SectionVideo.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    img: '/images/services/Prueba%20de%20Integridad%20Filtros%20HEPA.png',
    alt: 'Prueba de integridad de filtros HEPA',
    title: t('services.hepaIntegrity.title'),
    desc:  t('services.hepaIntegrity.description'),
    color: 'blue',
  },
  {
    img: '/images/services/Conteo%20Particulas%20Aire%20Cuarto%20Limpio.jpg',
    alt: 'Conteo de partículas de aire',
    title: t('services.particleCount.title'),
    desc:  t('services.particleCount.description'),
    color: 'primary',
  },
  {
    img: '/images/services/Prueba%20hermeticidad%20ductos%20aire.png',
    alt: 'Prueba de hermeticidad de ductos',
    title: t('services.ductLeakage.title'),
    desc:  t('services.ductLeakage.description'),
    color: 'slate',
  },
  {
    img: '/images/services/Balanceo%20Aire%20Presion%20Diferencial%20Cuarto%20Limpio.jpg',
    alt: 'Balanceo y control de presión',
    title: t('services.airBalancing.title'),
    desc:  t('services.airBalancing.description'),
    color: 'green',
  },
];

const steps = lang === 'en'
  ? [
      { n: '01', title: 'Test Selection',      desc: 'We identify the required tests based on applicable standards (ISO 14644, NEBB, ASHRAE) and your process needs.' },
      { n: '02', title: 'Schedule the Service', desc: 'We schedule at your convenience. We offer flexibility in date and time to minimize impact on your operations.' },
      { n: '03', title: 'Field Execution',     desc: 'Certified technicians perform all measurements and tests on-site.' },
      { n: '04', title: 'Technical Report',    desc: 'We deliver a detailed report with results, observations and corrective actions.' },
    ]
  : [
      { n: '01', title: 'Selección de prueba', desc: 'Identificamos las pruebas requeridas de acuerdo a las normativas aplicables (ISO 14644, NEBB, ASHRAE) y las necesidades de tu proceso.' },
      { n: '02', title: 'Agendar el servicio', desc: 'Coordinamos la visita a tu conveniencia. Contamos con flexibilidad de fecha y horario para minimizar el impacto en tus operaciones.' },
      { n: '03', title: 'Ejecución en campo',  desc: 'Técnicos certificados realizan todas las mediciones y pruebas en sitio.' },
      { n: '04', title: 'Reporte técnico',     desc: 'Entregamos reporte detallado con resultados, observaciones y acciones correctivas.' },
    ];
---

<!-- ── HERO ──────────────────────────────────────────────────────────── -->
<PageHero
  title={t('services.title')}
  description={t('services.description')}
  image="/images/home-page/Validacion%20Cuartos%20Limpios.jpg"
  primaryCta={{ label: lang === 'en' ? 'Request a quote' : 'Solicitar cotización', href: lang === 'en' ? '/en/contact' : '/contacto' }}
/>

<!-- ── Servicios ─────────────────────────────────────────────────────── -->
<div class="bg-background py-20 sm:py-24">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">

    <h2 class="mb-10 text-center text-3xl font-bold text-foreground sm:text-4xl reveal">
      {lang === 'en' ? 'Available Validation Services' : 'Servicios de Validación Disponibles'}
    </h2>

    <!-- Cards de servicios -->
    <div class="mx-auto max-w-7xl">
      <dl class="grid grid-cols-1 gap-x-6 gap-y-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-x-8">
        {services.map((s, i) => (
          <div class="reveal service-card group flex flex-col overflow-hidden rounded-2xl border border-border bg-white shadow-sm hover:shadow-xl hover:border-primary/40 transition-all duration-300"
               style={`transition-delay: ${i * 80}ms`}>
            <div class="overflow-hidden">
              <img
                src={s.img}
                alt={s.alt}
                class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105 sm:h-56 lg:h-52"
                loading="lazy"
              />
            </div>
            <div class="flex flex-col flex-1 p-5">
              <dt class="text-base font-semibold text-foreground group-hover:text-primary transition-colors sm:min-h-12">
                {s.title}
              </dt>
              <dd class="mt-2 text-sm/6 text-muted-foreground flex-1">
                {s.desc}
              </dd>
            </div>
          </div>
        ))}
      </dl>
    </div>
  </div>
</div>

<!-- ── Proceso de trabajo ──────────────────────────────────────────────── -->
<div class="bg-background py-20 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">
        {lang === 'en' ? 'How we work' : 'Cómo trabajamos'}
      </p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
        {lang === 'en' ? 'Our process' : 'Nuestro proceso'}
      </h2>
      <p class="mt-4 text-muted-foreground max-w-xl mx-auto">
        {lang === 'en'
          ? 'A systematic and certified methodology to ensure every test meets international standards.'
          : 'Metodología sistemática y certificada para garantizar que cada prueba cumpla con las normas internacionales.'}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {steps.map((step, i) => (
        <div class="reveal relative flex flex-col items-center text-center" style={`transition-delay: ${i * 100}ms`}>
          <!-- conector horizontal (desktop) -->
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-7 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-border z-0"></div>
          )}
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground text-lg font-bold shadow-md mb-4">
            {step.n}
          </div>
          <h3 class="text-base font-bold text-foreground mb-2">{step.title}</h3>
          <p class="text-sm text-muted-foreground leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ── VIDEO ──────────────────────────────────────────────────────────── -->
<SectionVideo
  videoId="7TH3CgAz3fk"
  videoTitle={lang === 'en' ? 'Validation Services - Star Filters' : 'Servicios de Validación - Star Filters'}
  heading={lang === 'en' ? 'Get to know our validation services' : 'Conoce nuestros servicios de validación'}
/>

<!-- ── ¿POR QUÉ CONTRATARNOS? + CTA ──────────────────────────────────── -->
<div class="bg-primary/10 py-16 sm:py-20 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 items-stretch">

      <!-- ¿Por qué contratarnos? -->
      <div class="reveal flex flex-col rounded-2xl bg-white border border-border shadow-sm p-8 sm:p-10">
        <div class="flex items-center gap-4">
          <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
            <svg class="h-7 w-7" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-foreground">
            {t('services.cta.benefitsTitle')}
          </h2>
        </div>
        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-6 flex-1">
          {([
            t('services.cta.benefit1'),
            t('services.cta.benefit2'),
            t('services.cta.benefit3'),
            t('services.cta.benefit4'),
            t('services.cta.benefit5'),
          ]).map((label, i) => (
            <div class="flex items-center gap-3">
              <img src={`/images/services/Servicios de validacion 2-0${i + 1}.png`} alt="" class="h-12 w-12 flex-shrink-0 object-contain" width="48" height="48" loading="lazy" />
              <span class="text-sm font-medium text-foreground">{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="reveal flex flex-col items-center justify-center text-center rounded-2xl bg-white border border-border shadow-sm p-8 sm:p-10" style="transition-delay:100ms">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">{lang === 'en' ? 'Start Today' : 'Empieza Hoy'}</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          {t('services.cta.title')}
        </h2>
        <p class="mt-5 text-base/7 text-gray-600">
          {t('services.cta.description')}
        </p>
        <div class="mt-8 flex justify-center">
          <a
            href={`https://wa.me/523322569541?text=${encodeURIComponent(lang === 'en' ? 'Hello, I would like more information about your industrial filtration services.' : 'Hola, me gustaría obtener más información sobre sus servicios de filtración industrial.')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 rounded-md bg-[#25D366] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#1ebe5d]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 flex-shrink-0">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {lang === 'en' ? 'Contact via WhatsApp' : 'Contactar por WhatsApp'}
          </a>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s ease, transform 0.55s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  document.querySelectorAll('.reveal').forEach(el => {
    new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.12 }).observe(el);
  });
</script>
