---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import SectionVideo from "@/components/shared/SectionVideo.astro";
import PageHero from "@/components/shared/PageHero.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const contactUrl = lang === 'en' ? '/en/contact' : '/contacto';
---

<!-- ── HERO ──────────────────────────────────────────────────────────── -->
<PageHero
  badge={t('cleanrooms.badge')}
  title={t('cleanrooms.title')}
  description={t('cleanrooms.description')}
  image="/images/home-page/Cuarto%20Limpio%20Sala%20Blanca%20ISO%2014644.jpeg"
  primaryCta={{ label: lang === 'en' ? 'Request a quote' : 'Solicitar cotización', href: contactUrl }}
  secondaryCta={{ label: lang === 'en' ? 'See projects' : 'Ver proyectos', href: lang === 'en' ? '/en/success-cases' : '/casos-de-exito' }}
/>

<!-- ── GALERÍA: PROYECTOS DESTACADOS ─────────────────────────────────── -->
<div class="bg-background py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <h2 class="mb-10 text-center text-3xl font-bold text-foreground sm:text-4xl reveal">
      {lang === 'en' ? 'Featured Projects' : 'Proyectos Destacados'}
    </h2>
    <div class="grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-4">
      <figure class="reveal space-y-2">
        <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
          <img
            src="/images/cleanrooms-page/Certificado%20ISO%2014644.JPG"
            alt={lang === 'en' ? 'Microelectronics industry cleanroom ISO 5' : 'Cuarto limpio ISO 5 para industria microelectrónica'}
            class="block size-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <figcaption class="text-center"><span class="inline-block rounded-full bg-muted px-4 py-2 text-xs font-medium text-muted-foreground whitespace-pre-line transition-colors duration-200 hover:bg-primary hover:text-primary-foreground">{t('cleanrooms.gallery.caption4')}</span></figcaption>
      </figure>
      <figure class="reveal space-y-2" style="transition-delay:80ms">
        <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
          <img
            src="/images/cleanrooms-page/Filtros%20Star%20Cuarto%20Limpio.JPG"
            alt={lang === 'en' ? 'Star Filters HEPA filtration system' : 'Filtros Star en cuarto limpio'}
            class="block size-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <figcaption class="text-center"><span class="inline-block rounded-full bg-muted px-4 py-2 text-xs font-medium text-muted-foreground whitespace-pre-line transition-colors duration-200 hover:bg-primary hover:text-primary-foreground">{t('cleanrooms.gallery.caption1')}</span></figcaption>
      </figure>
      <figure class="reveal space-y-2" style="transition-delay:160ms">
        <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
          <img
            src="/images/cleanrooms-page/Flujo%20Laminar%20Inyectables%20Clase%20A.jpg"
            alt={lang === 'en' ? 'Laminar flow for Class A injectables plant' : 'Flujo laminar para planta de inyectables Clase A'}
            class="block size-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <figcaption class="text-center"><span class="inline-block rounded-full bg-muted px-4 py-2 text-xs font-medium text-muted-foreground whitespace-pre-line transition-colors duration-200 hover:bg-primary hover:text-primary-foreground">{t('cleanrooms.gallery.caption5')}</span></figcaption>
      </figure>
      <figure class="reveal space-y-2" style="transition-delay:240ms">
        <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
          <img
            src="/images/cleanrooms-page/Construccion%20Cuartos%20Limpios%20Star%20Filters.JPG"
            alt={lang === 'en' ? 'Star Filters cleanroom construction' : 'Construcción de cuartos limpios Star Filters'}
            class="block size-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <figcaption class="text-center"><span class="inline-block rounded-full bg-muted px-4 py-2 text-xs font-medium text-muted-foreground whitespace-pre-line transition-colors duration-200 hover:bg-primary hover:text-primary-foreground">{t('cleanrooms.gallery.caption2')}</span></figcaption>
      </figure>
    </div>
  </div>
</div>

<!-- ── STATS ──────────────────────────────────────────────────────────── -->
<div class="bg-background py-14 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <h2 class="mb-10 text-center text-3xl font-bold text-foreground sm:text-4xl reveal">
      {lang === 'en' ? 'Our Experience in Numbers' : 'Nuestra Experiencia en Números'}
    </h2>
    <dl class="grid grid-cols-3 gap-x-6 gap-y-8 text-center reveal">
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-primary">
          <span class="counter-number" data-target="120">0</span>
        </dd>
        <dt class="text-base font-semibold text-foreground mt-2">{t('cleanrooms.numbers.installations')}</dt>
      </div>
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-primary">
          <span class="counter-number" data-target="40">0</span>
        </dd>
        <dt class="text-base font-semibold text-foreground mt-2">{t('cleanrooms.numbers.experience')}</dt>
      </div>
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-primary">
          <span class="counter-number" data-target="20">0</span>{t('cleanrooms.numbers.areaSuffix')}
        </dd>
        <dt class="text-base font-semibold text-foreground mt-2">{t('cleanrooms.numbers.area')}</dt>
      </div>
    </dl>
  </div>
</div>

<!-- ── ¿QUÉ ES UN CUARTO LIMPIO? ──────────────────────────────────────── -->
<div class="bg-primary/10 py-20 border-t border-border">
  <div class="mx-auto max-w-3xl px-6 lg:px-8 reveal">
    <h2 class="text-center text-3xl font-bold text-foreground sm:text-4xl mb-6">{lang === 'en' ? 'What is a cleanroom?' : '¿Qué es un cuarto limpio?'}</h2>
    <p class="text-base text-muted-foreground leading-relaxed">{t('cleanrooms.experience.p2')}</p>
    <p class="mt-5 text-base text-muted-foreground leading-relaxed">{t('cleanrooms.experience.p3')}</p>
    <p class="mt-5 text-base text-muted-foreground leading-relaxed [&_a]:text-primary [&_a]:hover:text-primary/80 [&_a]:font-medium" set:html={t('cleanrooms.experience.p4')} />
  </div>
</div>

<!-- ── PROCESO ─────────────────────────────────────────────────────────── -->
<div class="bg-background py-20 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">
        {lang === 'en' ? 'How we work' : 'Cómo trabajamos'}
      </p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
        {lang === 'en' ? 'Our process' : 'Nuestro proceso'}
      </h2>
      <p class="mt-4 text-muted-foreground max-w-xl mx-auto text-sm">
        {lang === 'en'
          ? 'From diagnosis to preventive maintenance — a complete, certified process for your cleanroom.'
          : 'Del diagnóstico al mantenimiento preventivo — un proceso completo y certificado para tu cuarto limpio.'}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-8">
      {[
        {
          n: '01',
          title: lang === 'en' ? 'Diagnosis' : 'Diagnóstico',
          desc: lang === 'en'
            ? 'We evaluate your project, needs and technical requirements to define the best solution.'
            : 'Evaluamos tu proyecto, necesidades y requerimientos técnicos para definir la mejor solución.',
        },
        {
          n: '02',
          title: lang === 'en' ? 'Design, Standards & Engineering' : 'Diseño, normativas e ingeniería',
          desc: lang === 'en'
            ? 'We design your cleanroom in compliance with ISO 14644, NOM-059 and GMP standards, adapted to your process.'
            : 'Diseñamos tu cuarto limpio conforme a ISO 14644, NOM-059 y GMP, adaptado a tu proceso productivo.',
        },
        {
          n: '03',
          title: lang === 'en' ? 'Fabrication & Construction' : 'Fabricación y construcción',
          desc: lang === 'en'
            ? 'We use certified high-quality equipment and materials, ensuring precise installation and regulatory compliance.'
            : 'Usamos equipos de alta calidad y materiales certificados, garantizando instalaciones precisas y cumplimiento normativo.',
        },
        {
          n: '04',
          title: lang === 'en' ? 'Validation & Certification' : 'Validación y certificación',
          desc: lang === 'en'
            ? 'We perform integrity tests, particle counting, air balancing and hermeticity tests. We deliver a detailed certification report.'
            : 'Realizamos pruebas de integridad, conteo de partículas, balanceo y hermeticidad. Entregamos informe de certificación detallado.',
        },
        {
          n: '05',
          title: lang === 'en' ? 'Operation & Preventive Maintenance' : 'Operación y mantenimiento preventivo',
          desc: lang === 'en'
            ? 'We inspect, clean and replace air filters to guarantee continuous and optimal performance of your cleanroom.'
            : 'Inspeccionamos, limpiamos y reemplazamos filtros de aire para garantizar un rendimiento continuo y óptimo de tu área.',
        },
      ].map((step, i, arr) => (
        <div class="reveal relative flex flex-col items-center text-center" style={`transition-delay: ${i * 80}ms`}>
          {i < arr.length - 1 && (
            <div class="hidden lg:block absolute top-7 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-border z-0"></div>
          )}
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground text-lg font-bold shadow-md mb-4">
            {step.n}
          </div>
          <h3 class="text-sm font-bold text-foreground mb-2 leading-snug">{step.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ── VIDEO ──────────────────────────────────────────────────────────── -->
<SectionVideo
  videoId="_Lc71ZZN6ow"
  videoTitle={lang === 'en' ? 'Cleanrooms - Star Filters' : 'Cuartos Limpios - Star Filters'}
/>

<!-- ── ¿POR QUÉ CONTRATARNOS? + CTA ──────────────────────────────────── -->
<div class="bg-white py-16 sm:py-20 lg:py-24 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-14 lg:grid-cols-2 lg:gap-12 items-center">

      <!-- ¿Por qué contratarnos? -->
      <div class="reveal">
        <h2 class="mb-8 text-center lg:text-left text-3xl font-bold text-foreground sm:text-4xl">
          {t('cleanrooms.cta.benefitsTitle')}
        </h2>
        <div class="grid grid-cols-2 gap-x-6 gap-y-6">
          {([
            t('cleanrooms.cta.benefit1'),
            t('cleanrooms.cta.benefit2'),
            t('cleanrooms.cta.benefit3'),
            t('cleanrooms.cta.benefit4'),
            t('cleanrooms.cta.benefit5'),
            t('cleanrooms.cta.benefit6'),
          ]).map((label, i) => (
            <div class="flex items-center gap-3">
              <img src={`/images/cleanrooms-page/Cuartos Limpios-0${i + 1}.png`} alt="" class="h-12 w-12 flex-shrink-0 object-contain" width="48" height="48" loading="lazy" />
              <span class="text-sm font-medium text-foreground">{label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center reveal" style="transition-delay:100ms">
        <p class="text-sm font-semibold uppercase tracking-widest text-primary">{t('cleanrooms.badge')}</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          {t('cleanrooms.cta.title')}
        </h2>
        <p class="mt-5 text-base/7 text-gray-600">
          {t('cleanrooms.cta.subtitle')}
        </p>
        <div class="mt-8 flex justify-center">
          <a
            href={`https://wa.me/523322569541?text=${encodeURIComponent(lang === 'en' ? 'Hello, I would like more information about your cleanroom construction and installation services.' : 'Hola, me gustaría obtener más información sobre sus servicios de construcción e instalación de cuartos limpios.')}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2.5 rounded-md bg-[#25D366] px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-[#1ebe5d]"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-5 w-5 flex-shrink-0">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {lang === 'en' ? 'Contact via WhatsApp' : 'Contactar por WhatsApp'}
          </a>
        </div>
      </div>

    </div>
  </div>
</div>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const duration = 1200;

  const animateCounter = (el: HTMLElement) => {
    const target = parseInt(el.getAttribute('data-target') || '0', 10);
    const startTime = performance.now();
    const update = (now: number) => {
      const progress = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 2.5);
      el.textContent = String(Math.round(target * eased));
      if (progress < 1) requestAnimationFrame(update);
      else el.textContent = String(target);
    };
    requestAnimationFrame(update);
  };

  // Con ClientRouter este módulo solo se evalúa una vez por sesión, así que
  // la inicialización debe repetirse en cada astro:page-load (que también
  // se dispara en la carga inicial).
  const initCounters = () => {
    const counters = document.querySelectorAll<HTMLElement>('.counter-number:not([data-counter-init])');
    if (counters.length === 0) return;

    const counterObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            if (!el.hasAttribute('data-animated')) {
              el.setAttribute('data-animated', 'true');
              animateCounter(el);
            }
            counterObserver.unobserve(el);
          }
        });
      },
      { threshold: 0.3 }
    );

    counters.forEach((counter) => {
      counter.setAttribute('data-counter-init', 'true');
      counterObserver.observe(counter);
    });
  };

  initCounters();
  document.addEventListener('astro:page-load', initCounters);
</script>
