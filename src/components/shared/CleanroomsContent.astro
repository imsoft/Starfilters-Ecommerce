---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import VideoSection from "@/components/shared/VideoSection.astro";
import SplitCTA from "@/components/shared/SplitCTA.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const contactUrl = lang === 'en' ? '/en/contact' : '/contacto';
---

<!-- ── HERO: Título + Galería lado a lado ─────────────────────────────── -->
<div class="bg-white pt-16 pb-0 overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-x-12 gap-y-10 lg:grid-cols-2 lg:items-center">

      <!-- Columna izquierda: texto + CTA -->
      <div class="max-w-xl">
        <p class="text-sm font-semibold text-primary uppercase tracking-widest">{t('cleanrooms.badge')}</p>
        <h1 class="mt-3 text-4xl font-semibold tracking-tight text-gray-900 sm:text-5xl leading-[1.1]">
          {t('cleanrooms.title')}
        </h1>
        <p class="mt-5 text-lg text-gray-600 leading-relaxed [&_strong]:font-semibold [&_strong]:text-gray-900" set:html={t('cleanrooms.description')} />
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href={contactUrl}
            class="inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white hover:bg-primary/90 transition-colors shadow-sm"
          >
            {lang === 'en' ? 'Request a quote' : 'Solicitar cotización'}
          </a>
          <a
            href={lang === 'en' ? '/en/success-cases' : '/casos-de-exito'}
            class="inline-flex items-center gap-2 rounded-full border-2 border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 hover:border-primary hover:text-primary transition-colors"
          >
            {lang === 'en' ? 'See projects' : 'Ver proyectos'}
          </a>
        </div>
      </div>

      <!-- Columna derecha: galería -->
      <div class="relative">
        <div class="grid grid-cols-2 gap-3 sm:gap-4">
          <figure class="space-y-2">
            <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
              <img
                src="/images/cleanrooms-page/Construccion%20Cuartos%20Limpios%20Star%20Filters.JPG"
                alt={lang === 'en' ? 'Star Filters cleanroom construction' : 'Construcción de cuartos limpios Star Filters'}
                class="block size-full object-cover"
              />
            </div>
            <figcaption class="text-center text-xs text-gray-500 whitespace-pre-line">{t('cleanrooms.gallery.caption2')}</figcaption>
          </figure>
          <figure class="mt-8 space-y-2">
            <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
              <img
                src="/images/cleanrooms-page/Filtros%20Star%20Cuarto%20Limpio.JPG"
                alt={lang === 'en' ? 'Star Filters HEPA filtration system' : 'Filtros Star en cuarto limpio'}
                class="block size-full object-cover"
              />
            </div>
            <figcaption class="text-center text-xs text-gray-500 whitespace-pre-line">{t('cleanrooms.gallery.caption1')}</figcaption>
          </figure>
          <figure class="space-y-2">
            <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
              <img
                src="/images/cleanrooms-page/Certificado%20ISO%2014644.JPG"
                alt={lang === 'en' ? 'ISO 14644 certification' : 'Certificación ISO 14644 para cuartos limpios'}
                class="block size-full object-cover"
              />
            </div>
            <figcaption class="text-center text-xs text-gray-500 whitespace-pre-line">{t('cleanrooms.gallery.caption4')}</figcaption>
          </figure>
          <figure class="mt-8 space-y-2">
            <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
              <img
                src="/images/cleanrooms-page/Puerta%20Giratoria%20Star%20Filters.JPG"
                alt={lang === 'en' ? 'Star Filters revolving airlock door' : 'Puerta giratoria para cuartos limpios Star Filters'}
                class="block size-full object-cover"
              />
            </div>
            <figcaption class="text-center text-xs text-gray-500 whitespace-pre-line">{t('cleanrooms.gallery.caption3')}</figcaption>
          </figure>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ── STATS ──────────────────────────────────────────────────────────── -->
<div class="bg-white py-14">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <dl class="grid grid-cols-3 gap-x-6 gap-y-8 border-t border-gray-100 pt-10 text-center">
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-gray-900">
          <span class="counter-number" data-target="120">0</span>
        </dd>
        <dt class="text-sm text-gray-500 mt-1">{t('cleanrooms.numbers.installations')}</dt>
      </div>
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-gray-900">
          <span class="counter-number" data-target="40">0</span>
        </dd>
        <dt class="text-sm text-gray-500 mt-1">{t('cleanrooms.numbers.experience')}</dt>
      </div>
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-gray-900">
          <span class="counter-number" data-target="20">0</span>{t('cleanrooms.numbers.areaSuffix')}
        </dd>
        <dt class="text-sm text-gray-500 mt-1">{t('cleanrooms.numbers.area')}</dt>
      </div>
    </dl>
  </div>
</div>

<!-- ── TEXTO + BENEFICIOS ─────────────────────────────────────────────── -->
<div class="bg-gray-50 py-16">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-x-12 gap-y-12 lg:grid-cols-2 lg:items-start">

      <!-- Texto (2 párrafos clave) -->
      <div>
        <h2 class="text-2xl font-semibold text-gray-900 mb-6">{lang === 'en' ? 'What is a cleanroom?' : '¿Qué es un cuarto limpio?'}</h2>
        <p class="text-base text-gray-600 leading-relaxed">{t('cleanrooms.experience.p2')}</p>
        <p class="mt-5 text-base text-gray-600 leading-relaxed">{t('cleanrooms.experience.p3')}</p>
        <p class="mt-5 text-sm text-gray-500 leading-relaxed [&_a]:text-primary [&_a]:hover:text-primary/80 [&_a]:font-medium" set:html={t('cleanrooms.experience.p4')} />
      </div>

      <!-- Beneficios -->
      <div>
        <h2 class="text-2xl font-semibold text-gray-900 mb-8">{t('cleanrooms.cta.benefitsTitle')}</h2>
        <div class="grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3">
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-01.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-gray-700 leading-snug">{t('cleanrooms.cta.benefit1')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-02.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-gray-700 leading-snug">{t('cleanrooms.cta.benefit2')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-03.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-gray-700 leading-snug">{t('cleanrooms.cta.benefit3')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-04.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-gray-700 leading-snug">{t('cleanrooms.cta.benefit4')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-05.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-gray-700 leading-snug">{t('cleanrooms.cta.benefit5')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-06.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-gray-700 leading-snug">{t('cleanrooms.cta.benefit6')}</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ── VIDEO (más pequeño, centrado) ─────────────────────────────────── -->
<div class="bg-white py-16">
  <div class="mx-auto max-w-4xl px-6 lg:px-8">
    <h2 class="text-center text-2xl font-semibold text-gray-900 mb-8">
      {lang === 'en' ? 'See our work' : 'Conoce nuestros proyectos'}
    </h2>
    <div class="rounded-2xl overflow-hidden shadow-lg">
      <VideoSection
        videoId="_Lc71ZZN6ow"
        title={lang === 'en' ? 'Cleanrooms - Star Filters' : 'Cuartos Limpios - Star Filters'}
        noPadding={true}
      />
    </div>
  </div>
</div>

<SplitCTA
  badge={t('cleanrooms.badge')}
  title={t('cleanrooms.cta.title')}
  description={t('cleanrooms.cta.subtitle')}
  whatsappMessage={lang === 'en' ? 'Hello, I would like more information about your cleanroom construction and installation services.' : 'Hola, me gustaría obtener más información sobre sus servicios de construcción e instalación de cuartos limpios.'}
/>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const counters = document.querySelectorAll('.counter-number');
    const duration = 1200;

    const animateCounter = (el) => {
      const target = parseInt(el.getAttribute('data-target') || '0', 10);
      const startTime = performance.now();

      const update = (currentTime) => {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 2.5);
        const current = Math.round(target * eased);
        el.textContent = String(current);

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          el.textContent = String(target);
        }
      };

      requestAnimationFrame(update);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target;
            if (!el.hasAttribute('data-animated')) {
              el.setAttribute('data-animated', 'true');
              animateCounter(el);
            }
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.3, rootMargin: '0px 0px -50px 0px' }
    );

    counters.forEach((counter) => observer.observe(counter));
  });
</script>
