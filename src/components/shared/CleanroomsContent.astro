---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import VideoSection from "@/components/shared/VideoSection.astro";
import SplitCTA from "@/components/shared/SplitCTA.astro";
import PageHero from "@/components/shared/PageHero.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const contactUrl = lang === 'en' ? '/en/contact' : '/contacto';
---

<!-- ── HERO ──────────────────────────────────────────────────────────── -->
<PageHero
  badge={t('cleanrooms.badge')}
  title={t('cleanrooms.title')}
  description={t('cleanrooms.description')}
  image="/images/home-page/Cuarto%20Limpio%20Sala%20Blanca%20ISO%2014644.JPG"
  primaryCta={{ label: lang === 'en' ? 'Request a quote' : 'Solicitar cotización', href: contactUrl }}
  secondaryCta={{ label: lang === 'en' ? 'See projects' : 'Ver proyectos', href: lang === 'en' ? '/en/success-cases' : '/casos-de-exito' }}
/>

<!-- ── GALERÍA ────────────────────────────────────────────────────────── -->
<div class="bg-background py-16 sm:py-20">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-4 sm:gap-6 lg:grid-cols-4">
      <figure class="reveal space-y-2">
        <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
          <img
            src="/images/cleanrooms-page/Construccion%20Cuartos%20Limpios%20Star%20Filters.JPG"
            alt={lang === 'en' ? 'Star Filters cleanroom construction' : 'Construcción de cuartos limpios Star Filters'}
            class="block size-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <figcaption class="text-center text-xs text-muted-foreground whitespace-pre-line">{t('cleanrooms.gallery.caption2')}</figcaption>
      </figure>
      <figure class="reveal space-y-2" style="transition-delay:80ms">
        <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
          <img
            src="/images/cleanrooms-page/Filtros%20Star%20Cuarto%20Limpio.JPG"
            alt={lang === 'en' ? 'Star Filters HEPA filtration system' : 'Filtros Star en cuarto limpio'}
            class="block size-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <figcaption class="text-center text-xs text-muted-foreground whitespace-pre-line">{t('cleanrooms.gallery.caption1')}</figcaption>
      </figure>
      <figure class="reveal space-y-2" style="transition-delay:160ms">
        <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
          <img
            src="/images/cleanrooms-page/Certificado%20ISO%2014644.JPG"
            alt={lang === 'en' ? 'ISO 14644 certification' : 'Certificación ISO 14644 para cuartos limpios'}
            class="block size-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <figcaption class="text-center text-xs text-muted-foreground whitespace-pre-line">{t('cleanrooms.gallery.caption4')}</figcaption>
      </figure>
      <figure class="reveal space-y-2" style="transition-delay:240ms">
        <div class="aspect-square overflow-hidden rounded-xl shadow-lg outline-1 -outline-offset-1 outline-black/10">
          <img
            src="/images/cleanrooms-page/Puerta%20Giratoria%20Star%20Filters.JPG"
            alt={lang === 'en' ? 'Star Filters revolving airlock door' : 'Puerta giratoria para cuartos limpios Star Filters'}
            class="block size-full object-cover transition-transform duration-500 hover:scale-105"
            loading="lazy"
          />
        </div>
        <figcaption class="text-center text-xs text-muted-foreground whitespace-pre-line">{t('cleanrooms.gallery.caption3')}</figcaption>
      </figure>
    </div>
  </div>
</div>

<!-- ── STATS ──────────────────────────────────────────────────────────── -->
<div class="bg-background py-14 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <dl class="grid grid-cols-3 gap-x-6 gap-y-8 text-center reveal">
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-primary">
          <span class="counter-number" data-target="120">0</span>
        </dd>
        <dt class="text-sm text-muted-foreground mt-1">{t('cleanrooms.numbers.installations')}</dt>
      </div>
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-primary">
          <span class="counter-number" data-target="40">0</span>
        </dd>
        <dt class="text-sm text-muted-foreground mt-1">{t('cleanrooms.numbers.experience')}</dt>
      </div>
      <div class="flex flex-col gap-y-1">
        <dd class="text-5xl font-semibold tracking-tight text-primary">
          <span class="counter-number" data-target="20">0</span>{t('cleanrooms.numbers.areaSuffix')}
        </dd>
        <dt class="text-sm text-muted-foreground mt-1">{t('cleanrooms.numbers.area')}</dt>
      </div>
    </dl>
  </div>
</div>

<!-- ── TEXTO + BENEFICIOS ─────────────────────────────────────────────── -->
<div class="bg-primary/10 py-20 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-x-12 gap-y-12 lg:grid-cols-2 lg:items-start">

      <!-- Texto -->
      <div class="reveal">
        <h2 class="text-2xl font-semibold text-foreground mb-6">{lang === 'en' ? 'What is a cleanroom?' : '¿Qué es un cuarto limpio?'}</h2>
        <p class="text-base text-muted-foreground leading-relaxed">{t('cleanrooms.experience.p2')}</p>
        <p class="mt-5 text-base text-muted-foreground leading-relaxed">{t('cleanrooms.experience.p3')}</p>
        <p class="mt-5 text-sm text-muted-foreground leading-relaxed [&_a]:text-primary [&_a]:hover:text-primary/80 [&_a]:font-medium" set:html={t('cleanrooms.experience.p4')} />
      </div>

      <!-- Beneficios -->
      <div class="reveal" style="transition-delay:100ms">
        <h2 class="text-2xl font-semibold text-foreground mb-8">{t('cleanrooms.cta.benefitsTitle')}</h2>
        <div class="grid grid-cols-2 gap-x-6 gap-y-8 sm:grid-cols-3">
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-01.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-foreground leading-snug">{t('cleanrooms.cta.benefit1')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-02.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-foreground leading-snug">{t('cleanrooms.cta.benefit2')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-03.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-foreground leading-snug">{t('cleanrooms.cta.benefit3')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-04.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-foreground leading-snug">{t('cleanrooms.cta.benefit4')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-05.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-foreground leading-snug">{t('cleanrooms.cta.benefit5')}</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <img src="/images/cleanrooms-page/Cuartos Limpios-06.png" alt="" class="h-12 w-12 object-contain" width="48" height="48" loading="lazy" />
            <span class="mt-3 text-xs font-medium text-foreground leading-snug">{t('cleanrooms.cta.benefit6')}</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ── PROCESO ─────────────────────────────────────────────────────────── -->
<div class="bg-background py-20 border-t border-border">
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="text-center mb-14 reveal">
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-2">
        {lang === 'en' ? 'How we work' : 'Cómo trabajamos'}
      </p>
      <h2 class="text-3xl font-bold text-foreground sm:text-4xl">
        {lang === 'en' ? 'Our process' : 'Nuestro proceso'}
      </h2>
      <p class="mt-4 text-muted-foreground max-w-xl mx-auto text-sm">
        {lang === 'en'
          ? 'From diagnosis to preventive maintenance — a complete, certified process for your cleanroom.'
          : 'Del diagnóstico al mantenimiento preventivo — un proceso completo y certificado para tu cuarto limpio.'}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-5 gap-8">
      {[
        {
          n: '01',
          title: lang === 'en' ? 'Diagnosis' : 'Diagnóstico',
          desc: lang === 'en'
            ? 'We evaluate your project, needs and technical requirements to define the best solution.'
            : 'Evaluamos tu proyecto, necesidades y requerimientos técnicos para definir la mejor solución.',
        },
        {
          n: '02',
          title: lang === 'en' ? 'Design, Standards & Engineering' : 'Diseño, normativas e ingeniería',
          desc: lang === 'en'
            ? 'We design your cleanroom in compliance with ISO 14644, NOM-059 and GMP standards, adapted to your process.'
            : 'Diseñamos tu cuarto limpio conforme a ISO 14644, NOM-059 y GMP, adaptado a tu proceso productivo.',
        },
        {
          n: '03',
          title: lang === 'en' ? 'Fabrication & Construction' : 'Fabricación y construcción',
          desc: lang === 'en'
            ? 'We use certified high-quality equipment and materials, ensuring precise installation and regulatory compliance.'
            : 'Usamos equipos de alta calidad y materiales certificados, garantizando instalaciones precisas y cumplimiento normativo.',
        },
        {
          n: '04',
          title: lang === 'en' ? 'Validation & Certification' : 'Validación y certificación',
          desc: lang === 'en'
            ? 'We perform integrity tests, particle counting, air balancing and hermeticity tests. We deliver a detailed certification report.'
            : 'Realizamos pruebas de integridad, conteo de partículas, balanceo y hermeticidad. Entregamos informe de certificación detallado.',
        },
        {
          n: '05',
          title: lang === 'en' ? 'Operation & Preventive Maintenance' : 'Operación y mantenimiento preventivo',
          desc: lang === 'en'
            ? 'We inspect, clean and replace air filters to guarantee continuous and optimal performance of your cleanroom.'
            : 'Inspeccionamos, limpiamos y reemplazamos filtros de aire para garantizar un rendimiento continuo y óptimo de tu área.',
        },
      ].map((step, i, arr) => (
        <div class="reveal relative flex flex-col items-center text-center" style={`transition-delay: ${i * 80}ms`}>
          {i < arr.length - 1 && (
            <div class="hidden lg:block absolute top-7 left-[calc(50%+2rem)] w-[calc(100%-4rem)] h-px bg-border z-0"></div>
          )}
          <div class="relative z-10 flex h-14 w-14 items-center justify-center rounded-full bg-primary text-primary-foreground text-lg font-bold shadow-md mb-4">
            {step.n}
          </div>
          <h3 class="text-sm font-bold text-foreground mb-2 leading-snug">{step.title}</h3>
          <p class="text-xs text-muted-foreground leading-relaxed">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</div>

<!-- ── VIDEO ──────────────────────────────────────────────────────────── -->
<div class="bg-primary/10 py-16 border-t border-border">
  <div class="mx-auto max-w-4xl px-6 lg:px-8 reveal">
    <h2 class="text-center text-2xl font-semibold text-foreground mb-8">
      {lang === 'en' ? 'See our work' : 'Conoce nuestros proyectos'}
    </h2>
    <div class="rounded-2xl overflow-hidden shadow-lg">
      <VideoSection
        videoId="_Lc71ZZN6ow"
        title={lang === 'en' ? 'Cleanrooms - Star Filters' : 'Cuartos Limpios - Star Filters'}
        noPadding={true}
      />
    </div>
  </div>
</div>

<SplitCTA
  badge={t('cleanrooms.badge')}
  title={t('cleanrooms.cta.title')}
  description={t('cleanrooms.cta.subtitle')}
  whatsappMessage={lang === 'en' ? 'Hello, I would like more information about your cleanroom construction and installation services.' : 'Hola, me gustaría obtener más información sobre sus servicios de construcción e instalación de cuartos limpios.'}
/>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  document.querySelectorAll('.reveal').forEach(el => {
    new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
    }, { threshold: 0.1 }).observe(el);
  });

  const counters = document.querySelectorAll('.counter-number');
  const duration = 1200;

  const animateCounter = (el: HTMLElement) => {
    const target = parseInt(el.getAttribute('data-target') || '0', 10);
    const startTime = performance.now();
    const update = (now: number) => {
      const progress = Math.min((now - startTime) / duration, 1);
      const eased = 1 - Math.pow(1 - progress, 2.5);
      el.textContent = String(Math.round(target * eased));
      if (progress < 1) requestAnimationFrame(update);
      else el.textContent = String(target);
    };
    requestAnimationFrame(update);
  };

  const counterObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          if (!el.hasAttribute('data-animated')) {
            el.setAttribute('data-animated', 'true');
            animateCounter(el);
          }
          counterObserver.unobserve(el);
        }
      });
    },
    { threshold: 0.3 }
  );

  counters.forEach((counter) => counterObserver.observe(counter));
</script>
