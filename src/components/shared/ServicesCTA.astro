---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";
import SplitCTA from "@/components/shared/SplitCTA.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const contactUrl = lang === 'en' ? '/en/contact' : '/contacto';
---

<div class="bg-background">
  <div class="px-6 pt-2 pb-16 sm:pt-4 sm:pb-20 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <!-- Beneficios: imagen arriba, texto abajo -->
      <h2 class="mb-10 text-center text-3xl font-semibold tracking-tight text-balance text-foreground sm:text-4xl">
        {t('services.cta.benefitsTitle')}
      </h2>
      <div class="mb-24 grid grid-cols-2 gap-x-6 gap-y-10 sm:grid-cols-3 lg:grid-cols-5 lg:gap-x-4">
        <div class="group flex cursor-default flex-col items-center text-center transition-colors">
          <img src="/images/services/Servicios de validacion 2-01.png" alt="" class="h-14 w-14 object-contain sm:h-16 sm:w-16" width="64" height="64" loading="lazy" />
          <span class="mt-3 text-sm font-medium text-foreground transition-colors group-hover:text-foreground">{t('services.cta.benefit1')}</span>
        </div>
        <div class="group flex cursor-default flex-col items-center text-center transition-colors">
          <img src="/images/services/Servicios de validacion 2-02.png" alt="" class="h-14 w-14 object-contain sm:h-16 sm:w-16" width="64" height="64" loading="lazy" />
          <span class="mt-3 text-sm font-medium text-foreground transition-colors group-hover:text-foreground">{t('services.cta.benefit2')}</span>
        </div>
        <div class="group flex cursor-default flex-col items-center text-center transition-colors">
          <img src="/images/services/Servicios de validacion 2-03.png" alt="" class="h-14 w-14 object-contain sm:h-16 sm:w-16" width="64" height="64" loading="lazy" />
          <span class="mt-3 text-sm font-medium text-foreground transition-colors group-hover:text-foreground">{t('services.cta.benefit3')}</span>
        </div>
        <div class="group flex cursor-default flex-col items-center text-center transition-colors">
          <img src="/images/services/Servicios de validacion 2-04.png" alt="" class="h-14 w-14 object-contain sm:h-16 sm:w-16" width="64" height="64" loading="lazy" />
          <span class="mt-3 text-sm font-medium text-foreground transition-colors group-hover:text-foreground">{t('services.cta.benefit4')}</span>
        </div>
        <div class="group flex cursor-default flex-col items-center text-center transition-colors">
          <img src="/images/services/Servicios de validacion 2-05.png" alt="" class="h-14 w-14 object-contain sm:h-16 sm:w-16" width="64" height="64" loading="lazy" />
          <span class="mt-3 text-sm font-medium text-foreground transition-colors group-hover:text-foreground">{t('services.cta.benefit5')}</span>
        </div>
      </div>

    </div>
  </div>
</div>

<SplitCTA
  badge={lang === 'en' ? 'Start Today' : 'Empieza Hoy'}
  title={t('services.cta.title')}
  description={t('services.cta.description')}
  primaryButtonText={t('services.cta.button')}
  primaryButtonHref={contactUrl}
  image="/images/services/Validacion%20Cuartos%20Limpios.jpg"
  imageAlt={lang === 'en' ? 'Star Filters cleanroom validation services' : 'Servicios de validación de cuartos limpios Star Filters'}
/>
