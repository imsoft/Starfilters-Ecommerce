---
import { getLangFromUrl, useTranslations } from "@/i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const industriesBase = '/images/home-page/industries-that-benefit';

const filtersHref = lang === 'en' ? '/en/filters' : '/filtros';

const industries = [
  { image: `${industriesBase}/farmaceutica-y-biotecnologia.jpg`, labelKey: 'industriesBenefit.pharma' },
  { image: `${industriesBase}/dispositivos-medicos.jpg`, labelKey: 'industriesBenefit.medical' },
  { image: `${industriesBase}/electronica-y-Optica.jpg`, labelKey: 'industriesBenefit.electronics' },
  { image: `${industriesBase}/alimentos-cosmeticos-y-quimica.jpg`, labelKey: 'industriesBenefit.food' },
  { image: `${industriesBase}/automotriz.jpg`, labelKey: 'industriesBenefit.automotive' },
];
---

<div class="bg-primary/10 py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <h2 class="mx-auto max-w-3xl text-center text-4xl font-semibold tracking-tight text-balance text-primary sm:text-5xl">
      {t('industriesBenefit.title')}
    </h2>
    <div class="mx-auto mt-10 max-w-7xl">
      <div class="grid grid-cols-2 gap-x-8 gap-y-12 sm:grid-cols-3 lg:grid-cols-5 items-center justify-items-center">
        {industries.map((item) => (
          <a
            href={filtersHref}
            class="group flex flex-col items-center justify-center gap-3 w-full"
            aria-label={`${t(item.labelKey)} — ${lang === 'en' ? 'See filters' : 'Ver filtros'}`}
          >
            <div class="w-full aspect-square overflow-hidden rounded-2xl shadow-md transition-shadow duration-300 group-hover:shadow-xl relative">
              <img
                src={item.image}
                alt=""
                class="w-full h-full object-cover"
                width="208"
                height="208"
                loading="lazy"
              />
              <!-- Overlay con CTA al hover -->
              <div class="absolute inset-0 bg-primary/70 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center rounded-2xl">
                <span class="text-white text-sm font-semibold px-4 text-center">
                  {lang === 'en' ? 'See filters →' : 'Ver filtros →'}
                </span>
              </div>
            </div>
            <p class="text-center text-sm font-medium text-foreground transition-colors group-hover:text-primary sm:text-base">
              {t(item.labelKey)}
            </p>
            <span class="inline-flex items-center gap-1 text-xs font-semibold text-primary">
              {lang === 'en' ? 'See filters' : 'Ver filtros'}
              <svg class="h-3 w-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>
