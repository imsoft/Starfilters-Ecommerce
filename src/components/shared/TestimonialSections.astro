---
import { getLangFromUrl, useTranslations } from '@/i18n/utils';
import { getActiveTestimonials } from '@/lib/database';
import type { Testimonial } from '@/lib/database';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';

let testimonials: Testimonial[] = [];
try {
  testimonials = await getActiveTestimonials();
} catch (error) {
  console.error('Error cargando testimonios desde DB:', error);
}
---

<div class="bg-background py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 lg:px-6">
    <div class="mx-auto max-w-2xl text-center mb-12">
      <h2 class="text-base/7 font-semibold text-primary">{t('testimonials.badge')}</h2>
      <p class="mt-2 text-4xl font-semibold tracking-tight text-balance text-foreground sm:text-5xl">
        {t('testimonials.title')}
      </p>
    </div>
  </div>

  <div class="overflow-hidden">
    <div class="testimonials-track flex items-stretch">
      {[...testimonials, ...testimonials].map((testimonial) => {
        const body = (isEn && testimonial.body_en) ? testimonial.body_en : testimonial.body;
        const role = (isEn && testimonial.role_en) ? testimonial.role_en : testimonial.role;
        const isLong = body.length > 200;

        return (
          <div class="testimonial-card flex-shrink-0 flex flex-col rounded-2xl bg-white border border-gray-200 shadow-sm mx-3 overflow-hidden" style="width: 300px;">
            <!-- Imagen del proyecto (opcional) -->
            {testimonial.project_image_url && (
              <div class="h-36 w-full overflow-hidden flex-shrink-0">
                <img
                  src={testimonial.project_image_url}
                  alt={`Proyecto ${testimonial.author}`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
            )}

            <!-- Contenido -->
            <div class="flex flex-1 flex-col p-5">
              <blockquote class="flex-1 text-foreground">
                <p class={`text-sm leading-relaxed testimonial-text${isLong ? ' line-clamp-4' : ''}`}>
                  {`"${body}"`}
                </p>
                {isLong && (
                  <button class="expand-btn mt-2 text-primary text-xs font-semibold hover:underline focus:outline-none">
                    Leer más +
                  </button>
                )}
              </blockquote>

              <figcaption class="mt-4 flex items-center gap-x-3 pt-4 border-t border-gray-100">
                <div class="flex size-12 items-center justify-center rounded-lg bg-white p-1.5 shadow-md flex-shrink-0">
                  {testimonial.company_logo_url ? (
                    <img
                      src={testimonial.company_logo_url}
                      alt={testimonial.author}
                      class="max-h-full max-w-full object-contain"
                    />
                  ) : (
                    <svg class="h-6 w-6 text-muted-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                    </svg>
                  )}
                </div>
                <div class="min-w-0">
                  <div class="font-bold text-base text-foreground">{testimonial.author}</div>
                  <div class="text-xs font-medium text-muted-foreground mt-0.5">{role}</div>
                </div>
              </figcaption>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</div>

<style>
  .testimonials-track {
    animation: scroll-testimonials 40s linear infinite;
    width: max-content;
  }

  .testimonials-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll-testimonials {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('.expand-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const text = btn.previousElementSibling as HTMLElement;
      const expanded = !text.classList.contains('line-clamp-4');
      if (expanded) {
        text.classList.add('line-clamp-4');
        btn.textContent = 'Leer más +';
      } else {
        text.classList.remove('line-clamp-4');
        btn.textContent = 'Leer menos −';
      }
    });
  });
</script>
